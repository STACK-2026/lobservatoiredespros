---
import BaseLayout from "./BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { siteConfig } from "../../site.config";
import { fullUrl } from "../utils/config";
import { jsonLdBreadcrumbs } from "../utils/seo";

interface Props {
  title: string;
  description?: string;
  lastUpdated?: Date;
}

const { title, description = "", lastUpdated } = Astro.props;

const breadcrumbs = [
  { name: "Accueil", url: siteConfig.url },
  { name: title, url: Astro.url.href },
];
---

<BaseLayout
  title={`${title} | ${siteConfig.name}`}
  description={description || `${title} - ${siteConfig.name}`}
  jsonLd={jsonLdBreadcrumbs(breadcrumbs)}
>
  <div class="max-w-3xl mx-auto px-4 py-12">
    <Breadcrumbs items={breadcrumbs} />
    <h1 class="mb-8">{title}</h1>
    {lastUpdated && (
      <p class="text-sm text-gray-500 mb-8">
        Derniere mise a jour :{" "}
        {lastUpdated.toLocaleDateString("fr-FR", {
          day: "numeric",
          month: "long",
          year: "numeric",
        })}
      </p>
    )}
    <div class="prose max-w-none">
      <slot />
    </div>
  </div>
</BaseLayout>

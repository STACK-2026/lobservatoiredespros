---
/**
 * SourceBadge , carte source officielle (INSEE, ADEME, Qualibat, Google).
 * Avec icone + lien officiel + tooltip glossaire.
 */
import GlossaireTerm from "./GlossaireTerm.astro";

interface Props {
  source: "insee" | "ademe" | "qualibat" | "google" | "dgccrf";
  info?: string; // ex: "SIRET 12345..., NAF 43.22A, cree 2011"
  verified?: boolean;
}

const { source, info, verified = true } = Astro.props;

const SOURCES = {
  insee: {
    label: "INSEE Sirene",
    url: "https://www.sirene.fr",
    glossaire: "sirene",
    icon: "building",
    color: "#19376D",
  },
  ademe: {
    label: "ADEME / France Rénov",
    url: "https://france-renov.gouv.fr/annuaire-rge",
    glossaire: "rge",
    icon: "leaf",
    color: "#4A913A",
  },
  qualibat: {
    label: "Qualibat",
    url: "https://www.qualibat.com",
    glossaire: "qualibat",
    icon: "shield",
    color: "#B8863D",
  },
  google: {
    label: "Google Business",
    url: "https://business.google.com",
    glossaire: undefined,
    icon: "globe",
    color: "#7A6E63",
  },
  dgccrf: {
    label: "DGCCRF SignalConso",
    url: "https://signal.conso.gouv.fr",
    glossaire: "dgccrf",
    icon: "alert",
    color: "#8B2E2A",
  },
};

const s = SOURCES[source];
---

<a class="source-badge" href={s.url} rel="noopener" target="_blank" style={`--sb-color: ${s.color};`}>
  <span class="sb-icon" aria-hidden="true">
    {s.icon === "building" && <svg viewBox="0 0 20 20" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="4" y="3" width="12" height="14" rx="1"/><line x1="8" y1="7" x2="8" y2="7"/><line x1="12" y1="7" x2="12" y2="7"/><line x1="8" y1="11" x2="8" y2="11"/><line x1="12" y1="11" x2="12" y2="11"/><line x1="4" y1="17" x2="16" y2="17"/></svg>}
    {s.icon === "leaf" && <svg viewBox="0 0 20 20" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M4 16 C 4 8 10 4 17 4 C 17 11 13 17 5 16 Z"/><line x1="4" y1="16" x2="9" y2="11"/></svg>}
    {s.icon === "shield" && <svg viewBox="0 0 20 20" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M10 3 L16 5 V 10 C 16 13 13 16 10 17 C 7 16 4 13 4 10 V 5 Z"/><path d="M7 10 L9 12 L13 8"/></svg>}
    {s.icon === "globe" && <svg viewBox="0 0 20 20" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="10" cy="10" r="7"/><line x1="3" y1="10" x2="17" y2="10"/><path d="M10 3 C 12 7 12 13 10 17 M10 3 C 8 7 8 13 10 17"/></svg>}
    {s.icon === "alert" && <svg viewBox="0 0 20 20" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M10 3 L17 16 H 3 Z"/><line x1="10" y1="8" x2="10" y2="12"/><circle cx="10" cy="14" r="0.6" fill="currentColor"/></svg>}
  </span>
  <span class="sb-body">
    <span class="sb-label">
      {s.glossaire ? <GlossaireTerm slug={s.glossaire} text={s.label} /> : s.label}
      {verified && <span class="sb-check" aria-label="Vérifié">✓</span>}
    </span>
    {info && <span class="sb-info">{info}</span>}
  </span>
  <span class="sb-arrow" aria-hidden="true">&#8599;</span>
</a>

<style>
  .source-badge {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.85rem;
    align-items: center;
    padding: 0.85rem 1.1rem;
    background: var(--paper);
    border: 1px solid rgba(26, 22, 20, 0.08);
    border-radius: 8px;
    text-decoration: none;
    color: var(--ink);
    transition: all 240ms var(--ease-out-quart);
    position: relative;
  }
  .source-badge:hover {
    border-color: var(--sb-color);
    background: var(--paper-warm);
    transform: translateY(-2px);
    box-shadow: 0 10px 24px -14px rgba(26, 22, 20, 0.2);
  }
  .sb-icon {
    width: 34px;
    height: 34px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(var(--sb-color-rgb, 26, 22, 20), 0.08);
    background: color-mix(in srgb, var(--sb-color) 10%, transparent);
    color: var(--sb-color);
    border-radius: 6px;
    flex-shrink: 0;
  }
  .sb-body {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }
  .sb-label {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.88rem;
    color: var(--ink);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .sb-check {
    display: inline-flex;
    width: 14px;
    height: 14px;
    align-items: center;
    justify-content: center;
    background: #4A913A;
    color: white;
    border-radius: 50%;
    font-size: 0.6rem;
    font-weight: 800;
  }
  .sb-info {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink-muted);
    letter-spacing: 0.01em;
    line-height: 1.4;
  }
  .sb-arrow {
    color: var(--ink-muted);
    font-size: 0.95rem;
    transition: transform 240ms var(--ease-out-quart), color 240ms;
  }
  .source-badge:hover .sb-arrow {
    color: var(--sb-color);
    transform: translate(3px, -3px);
  }
</style>

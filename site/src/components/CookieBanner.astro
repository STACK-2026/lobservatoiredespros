---
// Cookie consent banner , CNIL RGPD conforme
// - Affiche au premier visit + si consent expire (13 mois)
// - 3 choix equilibres : Refuser / En savoir plus / Accepter
// - localStorage key "ls_cookie_consent" (lu par Analytics.astro)
// - Re-ouvert via lien #cookie-settings en footer
// - Events "ls:consent-accepted" / "ls:consent-rejected" dispatches
---

<div id="cookie-banner" class="cookie-banner" role="dialog" aria-labelledby="cookie-title" aria-describedby="cookie-desc" hidden>
  <div class="cookie-inner">
    <div class="cookie-copy">
      <h2 id="cookie-title">Cookies et mesure d'audience</h2>
      <p id="cookie-desc">
        L'Observatoire dépose un cookie d'audience anonyme pour mesurer son trafic et améliorer ses publications. Aucun partage tiers, aucune publicité. Vous pouvez refuser, cela n'affecte pas votre consultation.
        <a href="/politique-confidentialite/#cookies">En savoir plus sur les cookies &rarr;</a>
      </p>
    </div>
    <div class="cookie-actions">
      <button type="button" class="cookie-btn cookie-btn-refuse" data-consent="rejected">Refuser</button>
      <button type="button" class="cookie-btn cookie-btn-accept" data-consent="accepted">Accepter</button>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var STORAGE_KEY = "ls_cookie_consent";
    var VALIDITY_MS = 13 * 30 * 24 * 60 * 60 * 1000; // 13 mois (recommandation CNIL)

    function read() {
      try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || "null"); }
      catch (e) { return null; }
    }
    function isValid(c) {
      return c && (c.status === "accepted" || c.status === "rejected") && c.expires && Date.now() < c.expires;
    }
    function save(status) {
      var now = Date.now();
      var consent = { status: status, timestamp: now, expires: now + VALIDITY_MS };
      try { localStorage.setItem(STORAGE_KEY, JSON.stringify(consent)); } catch (e) {}
      return consent;
    }

    var banner = document.getElementById("cookie-banner");
    if (!banner) return;

    function show() {
      banner.hidden = false;
      requestAnimationFrame(function () { banner.classList.add("cookie-open"); });
    }
    function hide() {
      banner.classList.remove("cookie-open");
      setTimeout(function () { banner.hidden = true; }, 260);
    }

    // Decide to show banner on load
    var existing = read();
    if (!isValid(existing)) {
      // Delay slightly to let the page render first (no layout shift)
      setTimeout(show, 600);
    }

    // Button handlers
    banner.querySelectorAll("[data-consent]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        var status = btn.getAttribute("data-consent");
        save(status);
        hide();
        var evtName = status === "accepted" ? "ls:consent-accepted" : "ls:consent-rejected";
        window.dispatchEvent(new CustomEvent(evtName));
      });
    });

    // Re-ouvrir le banner depuis #cookie-settings en footer
    document.addEventListener("click", function (e) {
      var t = e.target;
      if (t && (t.id === "cookie-settings" || (t.closest && t.closest("#cookie-settings")))) {
        e.preventDefault();
        show();
      }
    });
  })();
</script>

<style>
  .cookie-banner {
    position: fixed;
    left: 0; right: 0; bottom: 0;
    z-index: 9900;
    padding: 0.9rem;
    pointer-events: none;
    transform: translateY(8px);
    opacity: 0;
    transition: opacity 260ms cubic-bezier(0.22, 1, 0.36, 1),
                transform 260ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cookie-banner[hidden] { display: block !important; visibility: hidden; }
  .cookie-banner:not([hidden]) { visibility: visible; }
  .cookie-banner.cookie-open {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }
  .cookie-inner {
    max-width: 1060px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1.25rem;
    align-items: center;
    padding: 1.1rem 1.3rem;
    background: #1A1614;
    color: #F7F3EC;
    border: 1px solid rgba(184, 134, 61, 0.4);
    border-radius: 3px;
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.28);
  }
  @media (max-width: 720px) {
    .cookie-inner {
      grid-template-columns: 1fr;
      padding: 1rem 1.15rem;
      gap: 0.9rem;
    }
  }
  .cookie-copy h2 {
    font-family: "Instrument Serif", Georgia, serif;
    font-size: 0.82rem;
    margin: 0 0 0.35rem;
    color: #D4A55C;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .cookie-copy p {
    font-family: "Instrument Sans", system-ui, sans-serif;
    font-size: 0.88rem;
    line-height: 1.55;
    margin: 0;
    color: rgba(247, 243, 236, 0.92);
  }
  .cookie-copy a {
    color: #D4A55C;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .cookie-copy a:hover { text-decoration: none; color: #F7F3EC; }
  .cookie-actions {
    display: flex;
    gap: 0.6rem;
    flex-shrink: 0;
  }
  @media (max-width: 720px) {
    .cookie-actions { justify-content: flex-end; flex-wrap: wrap; }
  }
  .cookie-btn {
    padding: 0.62rem 1.25rem;
    font-size: 0.88rem;
    font-family: "Instrument Sans", system-ui, sans-serif;
    font-weight: 600;
    border-radius: 2px;
    border: 1px solid rgba(247, 243, 236, 0.28);
    cursor: pointer;
    transition: background 0.18s, color 0.18s, transform 0.18s, border-color 0.18s;
    letter-spacing: 0.01em;
  }
  .cookie-btn-refuse {
    background: transparent;
    color: #F7F3EC;
  }
  .cookie-btn-refuse:hover {
    background: rgba(247, 243, 236, 0.1);
    border-color: rgba(247, 243, 236, 0.55);
  }
  .cookie-btn-accept {
    background: #B8863D;
    color: #1A1614;
    border-color: #B8863D;
  }
  .cookie-btn-accept:hover {
    background: #D4A55C;
    border-color: #D4A55C;
    transform: translateY(-1px);
  }
  .cookie-btn:focus-visible {
    outline: 2px solid #D4A55C;
    outline-offset: 2px;
  }
  @media (prefers-reduced-motion: reduce) {
    .cookie-banner { transition: opacity 0ms; }
    .cookie-btn-accept:hover { transform: none; }
  }
</style>

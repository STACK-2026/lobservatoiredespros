---
/**
 * HeadlineFigure v2 , bloc stats moderne type Linear/Vercel/Apple.
 *
 * Layout :
 *   [grand chiffre, Geist bold]  [label + contexte + stats-pills]
 *                                [source live · CTA]
 *
 * Pas de cadre ornemental vertical, pas de coin corners. Airé, lisible,
 * speakable-friendly. Support dark/light automatique via tokens.
 */
interface Props {
  figure: string;
  label: string;
  context: string;
  source: string;
  linkHref?: string;
  linkLabel?: string;
  stats?: { value: string; label: string }[];
}

const { figure, label, context, source, linkHref, linkLabel, stats = [
  { value: "412", label: "sites audités" },
  { value: "6 mois", label: "d'observation" },
  { value: "Yonne", label: "département" },
] } = Astro.props;
---

<section class="hf" aria-label="Chiffre-clé de l'édition">
  <div class="hf-inner">
    <!-- Eyebrow live badge -->
    <div class="hf-eyebrow">
      <span class="hf-dot" aria-hidden="true"></span>
      <span>Chiffre de l'édition</span>
    </div>

    <!-- Chiffre massif + label sur la meme ligne (responsive stack) -->
    <div class="hf-head">
      <span class="hf-figure" data-speakable>{figure}</span>
      <div class="hf-text">
        <h2 class="hf-label" data-speakable>{label}</h2>
        <p class="hf-context">{context}</p>
      </div>
    </div>

    <!-- Stats-pills -->
    {stats.length > 0 && (
      <div class="hf-stats">
        {stats.map((s) => (
          <div class="hf-stat">
            <span class="hf-stat-v">{s.value}</span>
            <span class="hf-stat-l">{s.label}</span>
          </div>
        ))}
      </div>
    )}

    <!-- Footer : source + CTA -->
    <footer class="hf-foot">
      <span class="hf-source">
        <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.3" />
          <path d="M6 3 v 3.5 L 8.2 7.8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
        </svg>
        <span>{source}</span>
      </span>
      {linkHref && linkLabel && (
        <a class="hf-cta" href={linkHref}>
          <span>{linkLabel}</span>
          <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M3 7 H 11 M 8 4 L 11 7 L 8 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      )}
    </footer>
  </div>
</section>

<style>
  .hf {
    padding: clamp(3rem, 6vw, 5rem) 0;
    position: relative;
    background:
      radial-gradient(ellipse 60% 70% at 85% 40%, rgba(184, 134, 61, 0.08) 0%, transparent 60%),
      radial-gradient(ellipse 50% 60% at 10% 100%, rgba(30, 58, 82, 0.05) 0%, transparent 60%);
  }
  .hf::before,
  .hf::after {
    content: "";
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: min(60%, 320px);
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(26, 22, 20, 0.08) 50%, transparent);
  }
  .hf::before { top: 0; }
  .hf::after { bottom: 0; }

  .hf-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 5vw, 4rem);
  }

  /* Eyebrow live */
  .hf-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.8rem 0.35rem 0.6rem;
    background: rgba(247, 243, 236, 0.75);
    backdrop-filter: blur(10px) saturate(1.3);
    -webkit-backdrop-filter: blur(10px) saturate(1.3);
    border: 1px solid rgba(26, 22, 20, 0.08);
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 1.6rem;
  }
  .hf-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--or);
    box-shadow: 0 0 0 0 rgba(184, 134, 61, 0.6);
    animation: hf-pulse 2.6s ease-out infinite;
    flex-shrink: 0;
  }
  @keyframes hf-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(184, 134, 61, 0.5); }
    70%  { box-shadow: 0 0 0 7px rgba(184, 134, 61, 0); }
    100% { box-shadow: 0 0 0 0 rgba(184, 134, 61, 0); }
  }

  /* Head : chiffre + label/context cote a cote */
  .hf-head {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(1.5rem, 4vw, 3.2rem);
    align-items: center;
    margin-bottom: 2rem;
  }
  @media (max-width: 720px) {
    .hf-head { grid-template-columns: 1fr; gap: 1rem; }
  }

  .hf-figure {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: clamp(5.5rem, 15vw, 11rem);
    line-height: 0.95;
    letter-spacing: -0.075em;
    color: var(--ink);
    font-variant-numeric: tabular-nums lining-nums;
    display: inline-block;
    padding: 0.02em 0.05em;
    background: linear-gradient(175deg, var(--ink) 0%, var(--ink) 55%, var(--or-deep) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    flex-shrink: 0;
    position: relative;
  }
  .hf-figure::after {
    content: "";
    position: absolute;
    right: -0.18em;
    top: 0.1em;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--or);
    box-shadow: 0 0 20px rgba(184, 134, 61, 0.5);
    opacity: 0.8;
  }

  .hf-text { display: grid; gap: 0.55rem; max-width: 36rem; }
  .hf-label {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: clamp(1.4rem, 2.8vw, 2.2rem);
    line-height: 1.1;
    letter-spacing: -0.032em;
    color: var(--ink);
    margin: 0;
  }
  .hf-context {
    font-family: var(--font-body);
    font-size: clamp(0.98rem, 1.4vw, 1.1rem);
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0;
    max-width: 32rem;
    letter-spacing: -0.008em;
  }

  /* Stats-pills , row moderne */
  .hf-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
    gap: 0;
    max-width: 42rem;
    margin: 0 0 1.8rem;
    border-top: 1px solid rgba(26, 22, 20, 0.08);
    border-bottom: 1px solid rgba(26, 22, 20, 0.08);
    padding: 0.9rem 0;
    background:
      linear-gradient(180deg, rgba(247, 243, 236, 0.4) 0%, transparent 100%);
    backdrop-filter: blur(4px);
  }
  .hf-stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0 0.9rem;
    border-right: 1px solid rgba(26, 22, 20, 0.06);
  }
  .hf-stat:last-child { border-right: none; }
  @media (max-width: 540px) {
    .hf-stat { border-right: none; border-bottom: 1px solid rgba(26, 22, 20, 0.06); padding: 0.4rem 0; }
    .hf-stat:last-child { border-bottom: none; }
  }
  .hf-stat-v {
    font-family: var(--font-body);
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--ink);
    line-height: 1.1;
    font-variant-numeric: tabular-nums;
  }
  .hf-stat-l {
    font-family: var(--font-body);
    font-size: 0.72rem;
    color: var(--ink-muted);
    letter-spacing: -0.005em;
  }

  /* Footer */
  .hf-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    max-width: 42rem;
  }
  .hf-source {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-body);
    font-size: 0.76rem;
    color: var(--ink-muted);
    letter-spacing: -0.005em;
  }
  .hf-source svg { color: var(--or-deep); flex-shrink: 0; }

  .hf-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0.95rem;
    background: var(--ink);
    color: var(--paper);
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 500;
    text-decoration: none;
    letter-spacing: -0.008em;
    transition:
      transform 260ms cubic-bezier(0.34, 1.56, 0.64, 1),
      background 260ms,
      box-shadow 260ms;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.08) inset,
      0 4px 12px -4px rgba(26, 22, 20, 0.3);
  }
  .hf-cta svg {
    transition: transform 240ms cubic-bezier(0.25, 1, 0.5, 1);
  }
  .hf-cta:hover {
    transform: translateY(-2px);
    background: #0d0b0a;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.12) inset,
      0 8px 20px -6px rgba(26, 22, 20, 0.4);
  }
  .hf-cta:hover svg { transform: translateX(3px); }

  @media (prefers-reduced-motion: reduce) {
    .hf-dot { animation: none; }
    .hf-cta, .hf-cta svg { transition: none; }
  }
</style>

---
/**
 * HeadlineFigure , chiffre-choc signature. Instrument Serif massif + contexte
 * editorial + cite source. Pose une photo d'enquete sur la home, speakable-ready
 * pour les AI Overviews / ChatGPT / Perplexity.
 *
 * Usage :
 *   <HeadlineFigure
 *     figure="6"
 *     label="labels RGE retirés"
 *     context="en six mois d'observation dans l'Yonne."
 *     source="Enquête Observatoire, avril 2026"
 *     linkHref="/observations/enquete-rge-yonne-412-sites/"
 *     linkLabel="Lire l'enquête"
 *   />
 */
interface Props {
  figure: string;
  label: string;
  context: string;
  source: string;
  linkHref?: string;
  linkLabel?: string;
}

const { figure, label, context, source, linkHref, linkLabel } = Astro.props;
---

<section class="hf-section" aria-label="Chiffre-clé de l'édition">
  <div class="hf-inner">
    <div class="hf-aside" aria-hidden="true">
      <span class="hf-corner hf-corner-tl"></span>
      <span class="hf-corner hf-corner-tr"></span>
      <span class="hf-corner hf-corner-bl"></span>
      <span class="hf-corner hf-corner-br"></span>
      <p class="hf-kicker folio">Chiffre de l'édition</p>
    </div>
    <figure class="hf-block">
      <span class="hf-figure" data-speakable>{figure}</span>
      <figcaption class="hf-caption">
        <p class="hf-label" data-speakable>{label}</p>
        <p class="hf-context">{context}</p>
        <p class="hf-source">
          <span class="hf-source-dot" aria-hidden="true"></span>
          <span class="folio">{source}</span>
          {linkHref && linkLabel && (
            <a class="hf-link" href={linkHref}>
              {linkLabel}<span class="arrow" aria-hidden="true"> &rarr;</span>
            </a>
          )}
        </p>
      </figcaption>
    </figure>
  </div>
</section>

<style>
  .hf-section {
    padding: clamp(2.5rem, 5vw, 4.5rem) 0;
    background:
      radial-gradient(circle at 78% 28%, rgba(184, 134, 61, 0.08) 0%, transparent 55%),
      linear-gradient(180deg, var(--paper) 0%, var(--paper-warm) 100%);
    position: relative;
    overflow: hidden;
  }
  .hf-section::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(184, 134, 61, 0.35) 22%, rgba(184, 134, 61, 0.35) 78%, transparent);
  }
  .hf-section::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(184, 134, 61, 0.35) 22%, rgba(184, 134, 61, 0.35) 78%, transparent);
  }
  .hf-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 5vw, 4rem);
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(1.2rem, 3vw, 2.5rem);
    align-items: center;
  }
  @media (max-width: 680px) {
    .hf-inner { grid-template-columns: 1fr; gap: 0.8rem; }
  }
  .hf-aside {
    position: relative;
    padding: 0.9rem 0.6rem;
    min-width: 120px;
    min-height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hf-corner {
    position: absolute;
    width: 14px;
    height: 14px;
    border: 1px solid var(--or);
    opacity: 0.55;
  }
  .hf-corner-tl { top: 0; left: 0; border-right: none; border-bottom: none; }
  .hf-corner-tr { top: 0; right: 0; border-left: none; border-bottom: none; }
  .hf-corner-bl { bottom: 0; left: 0; border-right: none; border-top: none; }
  .hf-corner-br { bottom: 0; right: 0; border-left: none; border-top: none; }
  .hf-kicker {
    font-family: var(--font-body);
    font-size: 0.62rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--or-deep);
    font-weight: 600;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    margin: 0;
    white-space: nowrap;
  }
  @media (max-width: 680px) {
    .hf-aside { min-height: auto; }
    .hf-kicker { writing-mode: horizontal-tb; transform: none; }
  }

  .hf-block {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: center;
    margin: 0;
  }
  @media (max-width: 820px) {
    .hf-block { grid-template-columns: 1fr; gap: 1rem; }
  }

  .hf-figure {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(6rem, 14vw, 11rem);
    line-height: 0.85;
    letter-spacing: -0.055em;
    color: var(--ink);
    font-variant-numeric: tabular-nums lining-nums;
    display: inline-block;
    position: relative;
    background: linear-gradient(175deg, var(--ink) 0%, var(--ink) 62%, var(--or-deep) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: 0 1px 0 rgba(184, 134, 61, 0.08);
  }
  .hf-figure::after {
    content: "";
    position: absolute;
    bottom: 0.18em;
    left: 0.05em;
    right: 0.05em;
    height: 2px;
    background: var(--or);
    transform-origin: left;
    transform: scaleX(0);
    animation: hf-underline 900ms cubic-bezier(0.22, 1, 0.36, 1) 600ms forwards;
  }
  @keyframes hf-underline {
    to { transform: scaleX(1); }
  }

  .hf-caption {
    display: grid;
    gap: 0.5rem;
    max-width: 36rem;
  }
  .hf-label {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    line-height: 1.15;
    letter-spacing: -0.018em;
    color: var(--ink);
    margin: 0;
  }
  .hf-context {
    font-family: var(--font-body);
    font-size: 1.02rem;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0;
    max-width: 32rem;
  }
  .hf-source {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin: 0.5rem 0 0;
    padding-top: 0.6rem;
    border-top: 1px dashed rgba(184, 134, 61, 0.32);
    font-family: var(--font-body);
    font-size: 0.74rem;
    color: var(--ink-muted);
    flex-wrap: wrap;
  }
  .hf-source-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--or);
    box-shadow: 0 0 0 0 rgba(184, 134, 61, 0.5);
    animation: hf-pulse 2.8s ease-out infinite;
    flex-shrink: 0;
  }
  @keyframes hf-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(184, 134, 61, 0.55); }
    70%  { box-shadow: 0 0 0 7px rgba(184, 134, 61, 0); }
    100% { box-shadow: 0 0 0 0 rgba(184, 134, 61, 0); }
  }
  .hf-link {
    margin-left: auto;
    color: var(--or-deep);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.78rem;
    border-bottom: 1px dotted var(--or);
    padding-bottom: 1px;
    transition: color 200ms, border-color 200ms;
  }
  .hf-link:hover {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }
  .hf-link .arrow {
    display: inline-block;
    transition: transform 280ms var(--ease-out-quart);
  }
  .hf-link:hover .arrow {
    transform: translateX(3px);
  }

  @media (prefers-reduced-motion: reduce) {
    .hf-figure::after { animation: none; transform: scaleX(1); }
    .hf-source-dot { animation: none; }
  }
</style>

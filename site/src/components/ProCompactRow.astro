---
/**
 * ProCompactRow , ligne dense style palmares Michelin.
 * Utilisee pour les positions 16+ d'un classement : format tabulaire editorial
 * avec rang folio, nom en italique serif, ville, certifs icon-only, score.
 *
 * Rupture volontaire avec les cards ProCard du Top 15 : on signale visuellement
 * "tu es dans la liste longue, pas dans le Top d'excellence".
 */
interface Props {
  rank: number;
  name: string;
  slug: string;
  score: number;
  tier?: "or" | "argent" | "gratuit";
  ville?: string;
  ancienneteAnnees?: number;
  rge?: boolean;
  qualibat?: boolean;
}

const {
  rank,
  name,
  slug,
  score,
  tier = "gratuit",
  ville,
  ancienneteAnnees,
  rge = false,
  qualibat = false,
} = Astro.props;

const scoreColor = score >= 7.5 ? "#B8863D" : score >= 5 ? "#19376D" : "#7A6E63";
const rankStr = String(rank).padStart(2, "0");
---

<a class={`pcr pcr-${tier}`} href={`/pro/${slug}/`} data-rank-item={rank} aria-label={`Position ${rank} : ${name}, ${ville || ""}, score ${score.toFixed(1)} sur 10`}>
  <span class="pcr-rank folio">{rankStr}</span>
  <span class="pcr-body">
    <span class="pcr-name italic-fraunces">{name}</span>
    {ville && <span class="pcr-ville"> · {ville}</span>}
    {ancienneteAnnees && (
      <span class="pcr-age">{ancienneteAnnees} an{ancienneteAnnees > 1 ? "s" : ""}</span>
    )}
  </span>
  <span class="pcr-certifs" aria-label="Certifications">
    {rge && (
      <span class="pcr-cert pcr-cert-rge" title="RGE certifié">
        <svg width="11" height="11" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <circle cx="7" cy="7" r="5.8" stroke="currentColor" stroke-width="1.2" />
          <path d="M4.6 7.2 L6.3 8.9 L9.6 5.4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span>RGE</span>
      </span>
    )}
    {qualibat && (
      <span class="pcr-cert pcr-cert-qb" title="Qualibat">
        <svg width="11" height="11" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M7 1 L12 3 V 7 C 12 10 9.5 12 7 13 C 4.5 12 2 10 2 7 V 3 Z" stroke="currentColor" stroke-width="1.2" />
        </svg>
        <span>QB</span>
      </span>
    )}
    {!rge && !qualibat && <span class="pcr-cert-empty" aria-hidden="true">·</span>}
  </span>
  <span class="pcr-score" style={`--pcr-color: ${scoreColor};`}>
    <span class="pcr-score-num">{score.toFixed(1)}</span>
    <span class="pcr-score-max">/10</span>
  </span>
  <span class="pcr-arrow" aria-hidden="true">&rarr;</span>
</a>

<style>
  .pcr {
    display: grid;
    grid-template-columns: 44px 1fr auto auto 20px;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0.8rem 0.75rem 1rem;
    background: var(--paper);
    border: 1px solid rgba(26, 22, 20, 0.06);
    border-left: 2px solid rgba(26, 22, 20, 0.08);
    border-radius: 2px 10px 2px 2px;
    text-decoration: none;
    color: var(--ink);
    transition: transform 240ms var(--ease-out-quart),
                border-color 240ms,
                border-left-width 240ms,
                background 240ms,
                box-shadow 240ms;
    position: relative;
  }
  .pcr:hover {
    transform: translateX(3px);
    border-color: rgba(184, 134, 61, 0.4);
    border-left-color: var(--or);
    border-left-width: 3px;
    background: linear-gradient(90deg, rgba(184, 134, 61, 0.04) 0%, var(--paper) 40%);
    box-shadow: 0 6px 14px -10px rgba(26, 22, 20, 0.15);
  }
  .pcr-or {
    border-left-color: rgba(184, 134, 61, 0.45);
    background: linear-gradient(90deg, rgba(184, 134, 61, 0.05) 0%, var(--paper) 60%);
  }

  .pcr-rank {
    color: var(--ink-muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    font-variant-numeric: tabular-nums;
    font-weight: 500;
  }
  .pcr:hover .pcr-rank { color: var(--or-deep); }

  .pcr-body {
    min-width: 0;
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
    flex-wrap: wrap;
  }
  .pcr-name {
    font-family: var(--font-display);
    font-size: 1.02rem;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.008em;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }
  .pcr:hover .pcr-name {
    background-image: linear-gradient(var(--or), var(--or));
    background-size: 100% 1px;
    background-repeat: no-repeat;
    background-position: left bottom;
    padding-bottom: 1px;
  }
  .pcr-ville {
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: var(--ink-muted);
    letter-spacing: 0.01em;
  }
  .pcr-age {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--ink-muted);
    margin-left: 0.45rem;
    padding: 0.1rem 0.4rem;
    background: rgba(26, 22, 20, 0.04);
    border-radius: 2px;
  }

  .pcr-certifs {
    display: inline-flex;
    gap: 0.3rem;
    align-items: center;
    flex-shrink: 0;
  }
  .pcr-cert {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.18rem 0.45rem;
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.05em;
  }
  .pcr-cert-rge {
    background: rgba(74, 145, 58, 0.1);
    border: 1px solid rgba(74, 145, 58, 0.28);
    color: #3a6e30;
  }
  .pcr-cert-qb {
    background: rgba(184, 134, 61, 0.1);
    border: 1px solid rgba(184, 134, 61, 0.3);
    color: var(--or-deep);
  }
  .pcr-cert-empty {
    color: var(--ink-muted);
    font-family: var(--font-mono);
    opacity: 0.4;
    font-size: 0.8rem;
  }

  .pcr-score {
    display: inline-flex;
    align-items: baseline;
    gap: 0.15rem;
    min-width: 50px;
    justify-content: flex-end;
  }
  .pcr-score-num {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--pcr-color);
    letter-spacing: -0.015em;
    font-variant-numeric: tabular-nums;
  }
  .pcr-score-max {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--ink-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .pcr-arrow {
    color: var(--or-deep);
    font-size: 0.9rem;
    transition: transform 240ms var(--ease-out-quart);
    display: inline-block;
  }
  .pcr:hover .pcr-arrow { transform: translateX(4px); }

  @media (max-width: 680px) {
    .pcr {
      grid-template-columns: 38px 1fr auto;
      grid-template-areas:
        "rank body score"
        "rank certs arrow";
      gap: 0.3rem 0.7rem;
      padding: 0.65rem 0.8rem;
    }
    .pcr-rank { grid-area: rank; align-self: center; font-size: 0.92rem; }
    .pcr-body { grid-area: body; }
    .pcr-certifs { grid-area: certs; justify-self: flex-start; }
    .pcr-score { grid-area: score; justify-self: flex-end; }
    .pcr-arrow { grid-area: arrow; justify-self: flex-end; align-self: center; }
  }
</style>

---
/**
 * QualificationsBlock v3 , glassmorphism + univers bâtiment + historique.
 *
 * Sections :
 * 1. Hero : nombre actives + prochaine échéance + pills organismes
 * 2. Actives , grouped by meta_domaine + icons bâtiment
 * 3. Récemment expirées (dernière année) , signal éditorial
 * 4. Historique plus ancien , timeline repliable
 *
 * Icons par meta_domaine : chaudière (flamme), ENR (soleil), isolation (mur),
 * électrique (éclair), poêle/bois (feu), pompe à chaleur (vent).
 */
import { supabase } from "../lib/supabase";
import GlossaireTerm from "./GlossaireTerm.astro";

interface Props {
  proId: string;
  siret?: string | null;
}
const { proId, siret } = Astro.props;

const { data: quals } = await supabase
  .from("pro_qualifications")
  .select("*")
  .eq("pro_id", proId)
  .order("date_fin", { ascending: false });

const today = new Date();
const todayStr = today.toISOString().slice(0, 10);
const oneYearAgo = new Date(today.getTime() - 365 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);

const allQuals = quals || [];
const actives = allQuals.filter((q) => q.date_fin && q.date_fin >= todayStr);
const recentlyExpired = allQuals.filter((q) => q.date_fin && q.date_fin < todayStr && q.date_fin >= oneYearAgo);
const archived = allQuals.filter((q) => q.date_fin && q.date_fin < oneYearAgo);

// Grouper actives par meta_domaine
const groupedActives: Record<string, typeof actives> = {};
for (const q of actives) {
  const key = q.meta_domaine || "Autres qualifications";
  if (!groupedActives[key]) groupedActives[key] = [];
  groupedActives[key].push(q);
}

const hasQualifs = actives.length > 0 || recentlyExpired.length > 0 || archived.length > 0;
const organismes = [...new Set(actives.map((q) => q.organisme).filter((o) => o && o !== "Non renseigné"))];

const nextExpiry = actives
  .map((q) => q.date_fin)
  .filter(Boolean)
  .sort()[0];

const lastChecked = allQuals[0]?.last_checked_at
  ? new Date(allQuals[0].last_checked_at).toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })
  : today.toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" });

function formatDate(d: string | null): string {
  if (!d) return "—";
  return new Date(d).toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" });
}
function formatDateShort(d: string | null): string {
  if (!d) return "—";
  return new Date(d).toLocaleDateString("fr-FR", { month: "short", year: "numeric" });
}
function daysSince(d: string | null): number {
  if (!d) return 0;
  return Math.floor((today.getTime() - new Date(d).getTime()) / (24 * 60 * 60 * 1000));
}

const organismeColors: Record<string, string> = {
  qualibat: "#B8863D",
  qualifelec: "#D4A017",
  cequami: "#4A913A",
  certibat: "#19376D",
  qualitenr: "#C87828",
  qualit_enr: "#C87828",
};
function organismeLabel(org: string | null): string {
  if (!org || org === "Non renseigné") return "Organisme historique";
  return org.replace("_", " ");
}
function organismeColor(org: string | null): string {
  if (!org || org === "Non renseigné") return "#7A6E63";
  return organismeColors[org] || "#7A6E63";
}

// Icon par meta_domaine (univers bâtiment)
function metaIcon(meta: string): string {
  const m = (meta || "").toLowerCase();
  if (m.includes("efficacité énergétique") || m.includes("chauffage")) return "flame";
  if (m.includes("isolation") || m.includes("enveloppe")) return "wall";
  if (m.includes("enr") || m.includes("renouvelable") || m.includes("solaire")) return "sun";
  if (m.includes("électrique") || m.includes("electrique")) return "bolt";
  if (m.includes("pompe") || m.includes("pac") || m.includes("geothermie")) return "wind";
  if (m.includes("étude") || m.includes("etude") || m.includes("audit")) return "clipboard";
  if (m.includes("bois") || m.includes("poêle") || m.includes("insert")) return "fire";
  return "hardhat";
}

// Icon par code_qualification pour un lookup intelligent du domaine bâtiment
function domainIcon(q: any): string {
  const txt = ((q.domaine || "") + " " + (q.nom_qualification || "")).toLowerCase();
  if (txt.includes("chaudière") || txt.includes("chaudiere")) return "flame";
  if (txt.includes("radiateur") || txt.includes("électrique")) return "bolt";
  if (txt.includes("poêle") || txt.includes("insert") || txt.includes("bois")) return "fire";
  if (txt.includes("solaire") || txt.includes("photovolt")) return "sun";
  if (txt.includes("pompe à chaleur") || txt.includes("pac")) return "wind";
  if (txt.includes("isolation") || txt.includes("combles") || txt.includes("mur")) return "wall";
  if (txt.includes("fenêtre") || txt.includes("menuiserie")) return "window";
  if (txt.includes("ventilation") || txt.includes("vmc")) return "wind";
  if (txt.includes("couverture") || txt.includes("toiture")) return "roof";
  return "hardhat";
}
---

{hasQualifs && (
  <section class="qb-v3 fade-up" aria-labelledby="qb-v3-title">
    <!-- Decor fond , bâtiment ambiance -->
    <div class="qb-v3-bg" aria-hidden="true">
      <div class="qb-v3-glow qb-v3-glow-1"></div>
      <div class="qb-v3-glow qb-v3-glow-2"></div>
      <div class="qb-v3-grid"></div>
      <!-- Silhouette chantier en filigrane -->
      <svg class="qb-v3-silhouette" viewBox="0 0 400 100" preserveAspectRatio="xMidYMax slice" aria-hidden="true">
        <g fill="currentColor" opacity="0.04">
          <path d="M0 100 L0 60 L20 60 L20 40 L40 40 L40 70 L60 70 L60 30 L90 30 L90 70 L110 70 L110 50 L140 50 L140 25 L170 25 L170 70 L200 70 L200 45 L230 45 L230 20 L260 20 L260 70 L290 70 L290 55 L320 55 L320 40 L350 40 L350 70 L380 70 L380 35 L400 35 L400 100 Z"/>
        </g>
        <!-- Grue stylisée -->
        <g stroke="currentColor" stroke-width="0.8" fill="none" opacity="0.12">
          <line x1="50" y1="10" x2="50" y2="60" />
          <line x1="50" y1="10" x2="130" y2="10" />
          <line x1="50" y1="20" x2="125" y2="10" />
          <line x1="45" y1="60" x2="55" y2="60" />
          <line x1="45" y1="60" x2="55" y2="60" />
          <line x1="120" y1="10" x2="120" y2="28" />
          <rect x="116" y="28" width="8" height="5" />
        </g>
      </svg>
    </div>

    <!-- HERO HEADER -->
    <header class="qb-v3-hero">
      <div class="qb-v3-hero-left">
        <span class="qb-v3-kicker">
          <span class="qb-v3-kicker-dot" aria-hidden="true"></span>
          <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M7 1 L12 3 V 7 C 12 10 9 12 7 13 C 5 12 2 10 2 7 V 3 Z" stroke="currentColor" stroke-width="1.3"/>
            <path d="M5 7 L6.5 8.5 L9 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Qualifications vérifiées ADEME</span>
        </span>
        <h2 id="qb-v3-title" class="qb-v3-hero-title">
          <span class="qb-v3-hero-count">{actives.length}</span>
          <span class="qb-v3-hero-label italic-fraunces">
            {actives.length > 1 ? "certifications actives" : actives.length === 1 ? "certification active" : "certification active"}
          </span>
        </h2>
        <p class="qb-v3-hero-sub">
          {organismes.length > 0 ? (
            <>Auprès de <strong>{organismes.length}</strong> {organismes.length > 1 ? "organismes" : "organisme"} officiels</>
          ) : (
            <>Toutes les certifications connues de l'entreprise</>
          )}
          <span class="qb-v3-hero-dot" aria-hidden="true">·</span>
          <span class="folio">vérifié {lastChecked}</span>
        </p>
      </div>
      <div class="qb-v3-hero-right">
        {nextExpiry ? (
          <div class="qb-v3-next-card">
            <span class="qb-v3-next-label">Prochaine échéance</span>
            <p class="qb-v3-next-date">{formatDateShort(nextExpiry)}</p>
            <span class="qb-v3-next-full folio">{formatDate(nextExpiry)}</span>
          </div>
        ) : recentlyExpired.length > 0 ? (
          <div class="qb-v3-next-card qb-v3-next-warn">
            <span class="qb-v3-next-label">Dernière expiration</span>
            <p class="qb-v3-next-date">{formatDateShort(recentlyExpired[0].date_fin)}</p>
            <span class="qb-v3-next-full folio">il y a {daysSince(recentlyExpired[0].date_fin)} jours</span>
          </div>
        ) : null}
      </div>
    </header>

    <!-- Organismes pills -->
    {organismes.length > 0 && (
      <div class="qb-v3-organismes">
        {organismes.map((org) => {
          const count = actives.filter((q) => q.organisme === org).length;
          const color = organismeColor(org);
          return (
            <span class="qb-v3-org" style={`--org-color: ${color};`}>
              <span class="qb-v3-org-dot" aria-hidden="true"></span>
              <span class="qb-v3-org-name">{organismeLabel(org)}</span>
              <span class="qb-v3-org-count">{count}</span>
            </span>
          );
        })}
      </div>
    )}

    <!-- ACTIVES par meta_domaine -->
    {actives.length > 0 && (
      <div class="qb-v3-groups stagger-children">
        {Object.entries(groupedActives).map(([meta, quals]) => {
          const icon = metaIcon(meta);
          return (
            <article class="qb-v3-group">
              <header class="qb-v3-group-head">
                <span class={`qb-v3-group-icon qb-v3-icon-${icon}`} aria-hidden="true">
                  {icon === "flame" && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 2 C 13 6 16 8 16 12 C 16 15 14 17 12 17 C 10 17 8 15 8 12 C 8 10 10 8 10 5 Z"/><path d="M12 17 C 13 19 15 20 15 22 L 9 22 C 9 20 11 19 12 17 Z"/></svg>}
                  {icon === "wall" && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3" y="4" width="18" height="16"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="3" y1="16" x2="21" y2="16"/><line x1="9" y1="4" x2="9" y2="10"/><line x1="15" y1="10" x2="15" y2="16"/><line x1="9" y1="16" x2="9" y2="20"/></svg>}
                  {icon === "sun" && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="4"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3M4.5 4.5l2 2M17.5 17.5l2 2M4.5 19.5l2-2M17.5 6.5l2-2" stroke-linecap="round"/></svg>}
                  {icon === "bolt" && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"><path d="M13 2 L5 14 H 11 L9 22 L19 10 H 13 Z"/></svg>}
                  {icon === "wind" && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"><path d="M3 8h9a3 3 0 1 0 -3 -3"/><path d="M3 14h12a3 3 0 1 1 -3 3"/></svg>}
                  {icon === "fire" && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 2 C 12 6 18 8 18 14 C 18 18 15 21 12 21 C 9 21 6 18 6 14 C 6 10 9 9 10 6 C 11 8 13 8 12 2 Z"/></svg>}
                  {icon === "clipboard" && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="5" y="4" width="14" height="18" rx="1.5"/><rect x="8" y="2" width="8" height="4" rx="1"/><line x1="9" y1="10" x2="15" y2="10"/><line x1="9" y1="14" x2="15" y2="14"/><line x1="9" y1="18" x2="12" y2="18"/></svg>}
                  {icon === "hardhat" && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M4 18 L4 14 C 4 9 8 5 12 5 C 16 5 20 9 20 14 L 20 18"/><line x1="2" y1="18" x2="22" y2="18"/><line x1="9" y1="7" x2="9" y2="13"/><line x1="15" y1="7" x2="15" y2="13"/></svg>}
                  {icon === "window" && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="4" y="4" width="16" height="16"/><line x1="12" y1="4" x2="12" y2="20"/><line x1="4" y1="12" x2="20" y2="12"/></svg>}
                  {icon === "roof" && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"><path d="M3 12 L12 4 L21 12"/><path d="M5 12 V 20 H 19 V 12"/><path d="M9 16 h 3 M15 16 h 3" stroke-linecap="round"/></svg>}
                </span>
                <h3 class="qb-v3-group-title">{meta}</h3>
                <span class="qb-v3-group-pill">{quals.length}</span>
              </header>
              <ul class="qb-v3-list">
                {quals.map((q) => {
                  const color = organismeColor(q.organisme);
                  const dIcon = domainIcon(q);
                  return (
                    <li class="qb-v3-item" style={`--org-color: ${color};`}>
                      <div class="qb-v3-item-head">
                        <span class="qb-v3-item-badge">
                          <span class="qb-v3-item-badge-dot" aria-hidden="true"></span>
                          {q.nom_certificat}
                        </span>
                        {q.particulier && (
                          <span class="qb-v3-item-tag">
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 21 L12 12 L21 21"/><path d="M6 21 V 11 L12 6 L18 11 V 21"/><rect x="10" y="14" width="4" height="7"/></svg>
                            Particuliers
                          </span>
                        )}
                      </div>
                      <div class="qb-v3-item-domaine-row">
                        <span class={`qb-v3-item-icon qb-v3-icon-${dIcon}`} aria-hidden="true">
                          {dIcon === "flame" && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2 C 13 6 16 8 16 12 C 16 15 14 17 12 17 C 10 17 8 15 8 12 C 8 10 10 8 10 5 Z"/></svg>}
                          {dIcon === "bolt" && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"><path d="M13 2 L5 14 H 11 L9 22 L19 10 H 13 Z"/></svg>}
                          {dIcon === "fire" && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2 C 12 6 18 8 18 14 C 18 18 15 21 12 21 C 9 21 6 18 6 14 C 6 10 9 9 10 6 C 11 8 13 8 12 2 Z"/></svg>}
                          {dIcon === "sun" && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="4"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3" stroke-linecap="round"/></svg>}
                          {dIcon === "wind" && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M3 8h9a3 3 0 1 0 -3 -3"/><path d="M3 14h12a3 3 0 1 1 -3 3"/></svg>}
                          {dIcon === "wall" && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="16"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="3" y1="16" x2="21" y2="16"/></svg>}
                          {dIcon === "window" && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="4" width="16" height="16"/><line x1="12" y1="4" x2="12" y2="20"/><line x1="4" y1="12" x2="20" y2="12"/></svg>}
                          {dIcon === "roof" && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"><path d="M3 12 L12 4 L21 12"/></svg>}
                          {dIcon === "hardhat" && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 18 L4 14 C 4 9 8 5 12 5 C 16 5 20 9 20 14 L 20 18"/><line x1="2" y1="18" x2="22" y2="18"/></svg>}
                        </span>
                        <p class="qb-v3-item-domaine">{q.domaine}</p>
                      </div>
                      <div class="qb-v3-item-foot">
                        <span class="qb-v3-item-date">
                          <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.2" /><path d="M6 3v3l2 1.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" /></svg>
                          <span>Valide jusqu'au <strong>{formatDate(q.date_fin)}</strong></span>
                        </span>
                        <span class="qb-v3-item-code folio">Code {q.code_qualification}</span>
                        {q.url_certificat && (
                          <a href={q.url_certificat} target="_blank" rel="nofollow noopener" class="qb-v3-item-link">
                            Certificat PDF
                            <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M3 9L9 3M5 3h4v4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" /></svg>
                          </a>
                        )}
                      </div>
                    </li>
                  );
                })}
              </ul>
            </article>
          );
        })}
      </div>
    )}

    <!-- RÉCEMMENT EXPIRÉES , signal éditorial -->
    {recentlyExpired.length > 0 && (
      <section class="qb-v3-expired">
        <header class="qb-v3-expired-head">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="10" r="8.5" stroke="currentColor" stroke-width="1.3"/>
            <path d="M10 5v5l3 2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
          <span class="meta-label-or" style="letter-spacing: 0.2em;">Récemment expirées</span>
          <span class="qb-v3-expired-count">{recentlyExpired.length}</span>
        </header>
        <p class="qb-v3-expired-note">
          Qualifications arrivées à échéance dans les 12 derniers mois. Peut indiquer un renouvellement en cours ou une réorientation technique.
        </p>
        <ul class="qb-v3-expired-list">
          {recentlyExpired.slice(0, 5).map((q) => {
            const color = organismeColor(q.organisme);
            const dIcon = domainIcon(q);
            return (
              <li class="qb-v3-expired-item" style={`--org-color: ${color};`}>
                <span class="qb-v3-expired-dot" aria-hidden="true"></span>
                <div class="qb-v3-expired-body">
                  <p class="qb-v3-expired-domaine">
                    <strong class="qb-v3-expired-org">{organismeLabel(q.organisme)}</strong>
                    <span class="qb-v3-expired-sep" aria-hidden="true">·</span>
                    {q.domaine}
                  </p>
                  <p class="qb-v3-expired-date folio">
                    Expirée le {formatDate(q.date_fin)} (il y a {daysSince(q.date_fin)} jours)
                    &middot; Code {q.code_qualification}
                  </p>
                </div>
              </li>
            );
          })}
        </ul>
      </section>
    )}

    <!-- HISTORIQUE PLUS ANCIEN , collapsible -->
    {archived.length > 0 && (
      <details class="qb-v3-archive">
        <summary>
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <rect x="3" y="5" width="14" height="11" stroke="currentColor" stroke-width="1.3"/>
            <path d="M3 8h14" stroke="currentColor" stroke-width="1.3"/>
            <path d="M8 12h4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
          </svg>
          <span class="meta-label" style="letter-spacing: 0.2em;">Archives , qualifications expirées</span>
          <span class="qb-v3-archive-count">{archived.length}</span>
          <span class="qb-v3-archive-toggle" aria-hidden="true">+</span>
        </summary>
        <p class="qb-v3-archive-note">
          Historique éditorial , l'entreprise a également détenu ces qualifications.
        </p>
        <ul class="qb-v3-archive-list">
          {archived.map((q) => (
            <li class="qb-v3-archive-item">
              <span class="qb-v3-archive-date folio">{formatDateShort(q.date_debut)} , {formatDateShort(q.date_fin)}</span>
              <span class="qb-v3-archive-org">{organismeLabel(q.organisme)}</span>
              <span class="qb-v3-archive-domaine">{q.domaine}</span>
              <span class="qb-v3-archive-code folio">{q.code_qualification}</span>
            </li>
          ))}
        </ul>
      </details>
    )}

    <footer class="qb-v3-foot">
      <p>
        <span class="qb-v3-foot-chunk folio">
          Source : <GlossaireTerm slug="rge" text="ADEME RGE + historique" />
        </span>
        {siret && (
          <span class="qb-v3-foot-chunk folio">
            &middot; SIRET <span class="mono">{siret}</span>
          </span>
        )}
        <span class="qb-v3-foot-chunk folio">&middot; Sync quotidienne</span>
      </p>
    </footer>
  </section>
)}

<style>
  /* ═══════ QB v3 , Glassmorphism + univers bâtiment ═══════ */
  .qb-v3 {
    position: relative;
    padding: 2rem 2.2rem 2rem;
    margin: 2rem 0;
    background:
      linear-gradient(135deg, rgba(247, 243, 236, 0.88) 0%, rgba(239, 231, 214, 0.88) 60%, rgba(247, 243, 236, 0.88) 100%);
    backdrop-filter: blur(20px) saturate(140%);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    border: 1px solid rgba(184, 134, 61, 0.35);
    border-radius: 4px 36px 4px 4px;
    overflow: hidden;
    box-shadow:
      0 2px 0 rgba(184, 134, 61, 0.08),
      0 24px 48px -28px rgba(15, 35, 53, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.5);
  }
  .qb-v3::before {
    content: "";
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 3px;

---
/**
 * Numéro de classement géant type Monocle (01, 02, 03…).
 * Format automatique sur 2 chiffres (01, 02, …, 09, 10).
 */
interface Props {
  n: number;
  sticky?: boolean;
  variant?: "ink" | "or" | "outlined";
  size?: "normal" | "large";
}
const { n, sticky = false, variant = "ink", size = "normal" } = Astro.props;
const formatted = String(n).padStart(2, "0");
---

<span class={`rank-num rank-${variant} rank-size-${size} ${sticky ? "sticky-rank" : ""}`}>
  {formatted}
</span>

<style>
  .rank-num {
    font-feature-settings: "ss01", "tnum";
  }
  .rank-ink { color: var(--ink); }
  .rank-or { color: var(--or-deep); }
  .rank-outlined {
    color: var(--paper);
    -webkit-text-stroke: 1.2px var(--ink);
  }
  .rank-size-large {
    font-size: clamp(6rem, 12vw, 10rem);
    line-height: 0.85;
  }
</style>

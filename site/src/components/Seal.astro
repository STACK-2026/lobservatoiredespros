---
/**
 * Sceau editorial L'Observatoire des Pros , refonte 2026.
 *
 * Direction esthetique : moins d'ornement, plus de typographie. Inspire des
 * sceaux academiques modernes (MIT, College de France) plus que des medailles
 * XIXe. Geometrie precise, traits fins, une seule etoile refined au centre.
 *
 * Ne contient plus de date , la fraicheur editoriale tient au tampon, pas au
 * millesime grave dans la pierre.
 *
 * Geometrie (viewBox 200x200, centre 100x100) :
 *   R 96 , cercle externe (trait 0.7)
 *   R 92 , 4 triangles cardinaux (N, E, S, O), tres petits
 *   R 84 , path ring-text
 *   R 78 , cercle interne (trait 0.4)
 *   R 50 , cercle central
 *   R 46 , halo interne (trait 0.2)
 *
 * Animation : rotation 32s lineaire (couronne externe + ring text). Centre fixe.
 *
 * Variantes :
 *  - variant : ink | or | paper | observatoire (couleur du trait + glyph)
 *  - center  : star | compass | monogram (motif central)
 *  - text    : libelle du ring text (defaut "L'OBSERVATOIRE DES PROS")
 *  - motto   : motto court sous le centre (defaut "OBSERVER VERIFIER CLASSER")
 */
interface Props {
  size?: number;
  variant?: "ink" | "or" | "paper" | "observatoire";
  animated?: boolean;
  stamp?: boolean;
  text?: string;
  motto?: string;
  center?: "monogram" | "star" | "compass";
  className?: string;
}

const {
  size = 160,
  variant = "or",
  animated = true,
  stamp = false,
  text = "L'OBSERVATOIRE DES PROS",
  motto = "OBSERVER · VÉRIFIER · CLASSER",
  center = "star",
  className = "",
} = Astro.props;

const palette: Record<string, string> = {
  ink: "#1A1614",
  or: "#B8863D",
  paper: "#F7F3EC",
  observatoire: "#1E3A52",
};
const stroke = palette[variant] || palette.or;
const uid = `seal-${Math.random().toString(36).slice(2, 9)}`;
const rotateClass = animated ? "seal-rotate" : "";
const stampClass = stamp ? "seal-stamp" : "";

// Ring text repete pour remplir 360 degres + separateur middle dot.
const ringText = `${text} ·  `;

// 4 triangles cardinaux a R=92, angles 0, 90, 180, 270
const cardinals = [0, 90, 180, 270].map((deg) => {
  const rad = (deg * Math.PI) / 180;
  const cx = 100 + 92 * Math.cos(rad);
  const cy = 100 + 92 * Math.sin(rad);
  return { cx: +cx.toFixed(2), cy: +cy.toFixed(2), rotation: deg };
});
---

<span
  class={`seal-wrapper ${stampClass} ${className}`}
  style={`--seal-size: ${size}px; --seal-color: ${stroke};`}
  aria-label="Sceau editorial L'Observatoire des Pros"
  role="img"
>
  <svg
    viewBox="0 0 200 200"
    width={size}
    height={size}
    xmlns="http://www.w3.org/2000/svg"
    class="seal-svg"
    aria-hidden="true"
  >
    <defs>
      <!-- Path pour ring-text : cercle R=84 sens horaire -->
      <path id={`${uid}-ring`} d="M100 16 A84 84 0 1 1 99.99 16" />
      <!-- Path pour motto bas : arc dans le compartiment central -->
      <path id={`${uid}-motto`} d="M68 110 A 38 38 0 0 0 132 110" />
    </defs>

    <!-- COURONNE QUI TOURNE : cercles + triangles + ring text -->
    <g class={rotateClass} style="transform-origin: 100px 100px;">
      <!-- Cercle externe principal, trait fin -->
      <circle cx="100" cy="100" r="96" fill="none" stroke={stroke} stroke-width="0.7" />

      <!-- Cercle interne fin qui encadre le ring text -->
      <circle cx="100" cy="100" r="78" fill="none" stroke={stroke} stroke-width="0.4" opacity="0.55" />

      <!-- 4 triangles cardinaux entre les deux cercles -->
      {cardinals.map((c) => (
        <polygon
          points="0,-3.2 2.7,1.6 -2.7,1.6"
          fill={stroke}
          opacity="0.92"
          transform={`translate(${c.cx} ${c.cy}) rotate(${c.rotation + 90})`}
        />
      ))}

      <!-- Ring text sur R=84, font generouse, letter-spacing 4 -->
      <text
        fill={stroke}
        font-family="Fraunces, Georgia, serif"
        font-size="7.4"
        letter-spacing="4"
        font-weight="450"
        font-style="italic"
      >
        <textPath href={`#${uid}-ring`} startOffset="0" method="align" spacing="auto">
          {ringText}{ringText}{ringText}{ringText}
        </textPath>
      </text>
    </g>

    <!-- COMPARTIMENT CENTRAL FIXE -->
    <g>
      <!-- Cercle central, trait moyen -->
      <circle cx="100" cy="100" r="50" fill="none" stroke={stroke} stroke-width="0.6" />
      <!-- Halo fin a 4px du cercle central, donne profondeur -->
      <circle cx="100" cy="100" r="46" fill="none" stroke={stroke} stroke-width="0.25" opacity="0.5" />

      {center === "star" && (
        <g>
          <!-- Etoile a 8 branches refined, geometrie pure (sans remplissage rugueux) -->
          <!-- Branches longues (4) -->
          <g fill={stroke} opacity="0.95">
            <polygon points="100,72 102,92 100,98 98,92" />
            <polygon points="128,100 108,102 102,100 108,98" />
            <polygon points="100,128 98,108 100,102 102,108" />
            <polygon points="72,100 92,98 98,100 92,102" />
          </g>
          <!-- Branches courtes diagonales (4), plus fines -->
          <g fill={stroke} opacity="0.55">
            <polygon points="115.5,84.5 105,98 100,100 98,95" />
            <polygon points="115.5,115.5 102,105 100,100 105,98" />
            <polygon points="84.5,115.5 95,102 100,100 98,105" />
            <polygon points="84.5,84.5 98,95 100,100 95,98" />
          </g>
          <!-- Disque central minuscule -->
          <circle cx="100" cy="100" r="1.6" fill={stroke} />
        </g>
      )}

      {center === "compass" && (
        <g>
          <!-- Compass rose moderne, single stroke geometry -->
          <g fill={stroke}>
            <polygon points="100,68 103,100 100,102 97,100" opacity="0.95" />
            <polygon points="100,132 97,100 100,98 103,100" opacity="0.5" />
            <polygon points="132,100 100,103 98,100 100,97" opacity="0.7" />
            <polygon points="68,100 100,97 102,100 100,103" opacity="0.7" />
          </g>
          <circle cx="100" cy="100" r="2" fill={stroke} />
        </g>
      )}

      {center === "monogram" && (
        <g>
          <!-- "O" en cercle, "P" en arc juxtapose -->
          <circle cx="94" cy="100" r="14" fill="none" stroke={stroke} stroke-width="1.4" />
          <path d="M104 86 L104 114 M104 86 Q116 86 116 96 Q116 106 104 106"
                fill="none" stroke={stroke} stroke-width="1.4" stroke-linecap="round" />
        </g>
      )}
    </g>

    <!-- MOTTO en arc bas du compartiment central -->
    {motto && (
      <text
        fill={stroke}
        font-family="Geist, sans-serif"
        font-size="4.6"
        letter-spacing="1.8"
        font-weight="500"
        opacity="0.78"
      >
        <textPath href={`#${uid}-motto`} startOffset="50%" text-anchor="middle">
          {motto}
        </textPath>
      </text>
    )}
  </svg>
</span>

<style>
  .seal-wrapper {
    display: inline-flex;
    width: var(--seal-size);
    height: var(--seal-size);
    filter: drop-shadow(0 2px 8px rgba(184, 134, 61, 0.12));
    isolation: isolate;
  }
  .seal-svg {
    width: 100%;
    height: 100%;
    display: block;
    shape-rendering: geometricPrecision;
    text-rendering: geometricPrecision;
  }
  .seal-rotate {
    animation: seal-rotate 32s linear infinite;
  }
  @keyframes seal-rotate {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  .seal-stamp {
    animation: seal-stamp 0.7s cubic-bezier(0.2, 0.85, 0.4, 1.4) both;
  }
  @keyframes seal-stamp {
    0%   { opacity: 0; transform: scale(0.6) rotate(-6deg); }
    65%  { opacity: 1; transform: scale(1.06) rotate(2deg); }
    100% { opacity: 1; transform: scale(1) rotate(0deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .seal-wrapper { filter: none; }
    .seal-rotate, .seal-stamp { animation: none; }
  }
</style>

---
/**
 * Sceau editorial L'Observatoire des Pros , refonte 2026 minimaliste.
 *
 * Direction : medaille editoriale moderne. Inspire des sceaux academiques
 * (Academie francaise, College de France) depouilles a l'essentiel. Chaque
 * trait gagne sa place. Le compartiment central respire.
 *
 * Element signature : 3 dots subtils sous l'etoile, ancre visuel sans cri.
 *
 * Geometrie (viewBox 200x200, centre 100x100) :
 *   R 96 , cercle externe (trait 0.7)
 *   R 92 , 4 triangles cardinaux N/E/S/O
 *   R 84 , path ring text
 *   R 78 , cercle interne (trait 0.4)
 *   R 50 , compartiment central
 *   R 46 , halo interne fin
 *   etoile y=78 a y=122 (legerement remontee pour faire respirer)
 *   3 dots a y=132 (accent decoratif)
 *
 * Variantes :
 *  - variant : ink | or | paper | observatoire
 *  - center  : star | compass | monogram
 *  - text    : ring text (defaut "L'OBSERVATOIRE DES PROS")
 *
 * Animation : rotation 32s lineaire (couronne externe + ring text). Centre fixe.
 * `prefers-reduced-motion` : desactivee.
 */
interface Props {
  size?: number;
  variant?: "ink" | "or" | "paper" | "observatoire";
  animated?: boolean;
  stamp?: boolean;
  text?: string;
  center?: "monogram" | "star" | "compass";
  className?: string;
}

const {
  size = 160,
  variant = "or",
  animated = true,
  stamp = false,
  text = "L'OBSERVATOIRE DES PROS",
  center = "star",
  className = "",
} = Astro.props;

const palette: Record<string, string> = {
  ink: "#1A1614",
  or: "#B8863D",
  paper: "#F7F3EC",
  observatoire: "#1E3A52",
};
const stroke = palette[variant] || palette.or;
const uid = `seal-${Math.random().toString(36).slice(2, 9)}`;
const rotateClass = animated ? "seal-rotate" : "";
const stampClass = stamp ? "seal-stamp" : "";

const ringText = `${text} ·  `;

// 4 triangles cardinaux a R=92, angles 0, 90, 180, 270
const cardinals = [0, 90, 180, 270].map((deg) => {
  const rad = (deg * Math.PI) / 180;
  const cx = 100 + 92 * Math.cos(rad);
  const cy = 100 + 92 * Math.sin(rad);
  return { cx: +cx.toFixed(2), cy: +cy.toFixed(2), rotation: deg };
});

// 3 dots accent decoratifs sous le centre, ligne horizontale a y=132
const accentDots = [
  { cx: 92, cy: 132, r: 0.85 },
  { cx: 100, cy: 132, r: 1.1 },
  { cx: 108, cy: 132, r: 0.85 },
];
---

<span
  class={`seal-wrapper ${stampClass} ${className}`}
  style={`--seal-size: ${size}px; --seal-color: ${stroke};`}
  aria-label="Sceau editorial L'Observatoire des Pros"
  role="img"
>
  <svg
    viewBox="0 0 200 200"
    width={size}
    height={size}
    xmlns="http://www.w3.org/2000/svg"
    class="seal-svg"
    aria-hidden="true"
  >
    <defs>
      <!-- Path pour ring-text : cercle R=84 sens horaire -->
      <path id={`${uid}-ring`} d="M100 16 A84 84 0 1 1 99.99 16" />
      <!-- Halo radial subtil pour donner profondeur de medaille (variante or) -->
      <radialGradient id={`${uid}-glow`} cx="50%" cy="42%" r="58%">
        <stop offset="0%" stop-color={stroke} stop-opacity="0.05" />
        <stop offset="100%" stop-color={stroke} stop-opacity="0" />
      </radialGradient>
    </defs>

    <!-- Halo central qui suggere relief de medaille (visible variante or) -->
    {variant === "or" && (
      <circle cx="100" cy="100" r="50" fill={`url(#${uid}-glow)`} />
    )}

    <!-- COURONNE QUI TOURNE : cercles + triangles + ring text -->
    <g class={rotateClass} style="transform-origin: 100px 100px;">
      <!-- Cercle externe principal, trait fin -->
      <circle cx="100" cy="100" r="96" fill="none" stroke={stroke} stroke-width="0.7" />

      <!-- Cercle interne fin qui encadre le ring text -->
      <circle cx="100" cy="100" r="78" fill="none" stroke={stroke} stroke-width="0.4" opacity="0.55" />

      <!-- 4 triangles cardinaux entre les deux cercles -->
      {cardinals.map((c) => (
        <polygon
          points="0,-3.2 2.7,1.6 -2.7,1.6"
          fill={stroke}
          opacity="0.92"
          transform={`translate(${c.cx} ${c.cy}) rotate(${c.rotation + 90})`}
        />
      ))}

      <!-- Ring text Fraunces italic, letter-spacing 4 -->
      <text
        fill={stroke}
        font-family="Fraunces, Georgia, serif"
        font-size="7.4"
        letter-spacing="4"
        font-weight="450"
        font-style="italic"
      >
        <textPath href={`#${uid}-ring`} startOffset="0" method="align" spacing="auto">
          {ringText}{ringText}{ringText}{ringText}
        </textPath>
      </text>
    </g>

    <!-- COMPARTIMENT CENTRAL FIXE : breathe, refined, pas de texte -->
    <g>
      <!-- Cercle central, trait moyen -->
      <circle cx="100" cy="100" r="50" fill="none" stroke={stroke} stroke-width="0.6" />
      <!-- Halo fin a 4px du cercle central, profondeur sans bruit -->
      <circle cx="100" cy="100" r="46" fill="none" stroke={stroke} stroke-width="0.25" opacity="0.5" />

      {center === "star" && (
        <g transform="translate(0, -3)">
          <!-- Etoile 8 branches refined : 4 longues cardinales + 4 courtes diagonales -->
          <g fill={stroke} opacity="0.95">
            <!-- Branches longues : axes N/S/E/O, fines fleches -->
            <polygon points="100,78 102,96 100,100 98,96" />
            <polygon points="122,100 104,102 100,100 104,98" />
            <polygon points="100,122 98,104 100,100 102,104" />
            <polygon points="78,100 96,98 100,100 96,102" />
          </g>
          <g fill={stroke} opacity="0.42">
            <!-- Branches courtes : diagonales, plus subtiles -->
            <polygon points="112.5,87.5 102,97 100,100 97,98" />
            <polygon points="112.5,112.5 103,103 100,100 102,97" />
            <polygon points="87.5,112.5 98,102 100,100 103,102" />
            <polygon points="87.5,87.5 97,98 100,100 98,103" />
          </g>
          <!-- Pointe centrale, disque minuscule -->
          <circle cx="100" cy="100" r="1.3" fill={stroke} />
        </g>
      )}

      {center === "compass" && (
        <g transform="translate(0, -3)">
          <!-- Compass rose moderne, fleches pures -->
          <g fill={stroke}>
            <polygon points="100,76 103,100 100,103 97,100" opacity="0.95" />
            <polygon points="100,124 97,100 100,97 103,100" opacity="0.45" />
            <polygon points="124,100 100,103 97,100 100,97" opacity="0.65" />
            <polygon points="76,100 100,97 103,100 100,103" opacity="0.65" />
          </g>
          <circle cx="100" cy="100" r="1.8" fill={stroke} />
        </g>
      )}

      {center === "monogram" && (
        <g transform="translate(0, -3)">
          <!-- "OdP" monogramme stylise : O en cercle + accent diagonale + point -->
          <circle cx="100" cy="100" r="16" fill="none" stroke={stroke} stroke-width="1.4" />
          <line x1="92" y1="110" x2="108" y2="90" stroke={stroke} stroke-width="1.1" stroke-linecap="round" opacity="0.8" />
          <circle cx="110" cy="90" r="1.5" fill={stroke} />
        </g>
      )}

      <!-- Element signature : 3 dots accent decoratifs sous le centre.
           Donne une assise visuelle a l'etoile sans cri textuel. -->
      <g fill={stroke}>
        {accentDots.map((d, i) => (
          <circle cx={d.cx} cy={d.cy} r={d.r} opacity={i === 1 ? "0.85" : "0.55"} />
        ))}
      </g>
    </g>
  </svg>
</span>

<style>
  .seal-wrapper {
    display: inline-flex;
    width: var(--seal-size);
    height: var(--seal-size);
    filter: drop-shadow(0 2px 8px rgba(184, 134, 61, 0.12));
    isolation: isolate;
  }
  .seal-svg {
    width: 100%;
    height: 100%;
    display: block;
    shape-rendering: geometricPrecision;
    text-rendering: geometricPrecision;
  }
  .seal-rotate {
    animation: seal-rotate 32s linear infinite;
  }
  @keyframes seal-rotate {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  .seal-stamp {
    animation: seal-stamp 0.7s cubic-bezier(0.2, 0.85, 0.4, 1.4) both;
  }
  @keyframes seal-stamp {
    0%   { opacity: 0; transform: scale(0.6) rotate(-6deg); }
    65%  { opacity: 1; transform: scale(1.06) rotate(2deg); }
    100% { opacity: 1; transform: scale(1) rotate(0deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .seal-wrapper { filter: none; }
    .seal-rotate, .seal-stamp { animation: none; }
  }
</style>

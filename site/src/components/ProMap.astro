---
/**
 * ProMap , mini-carte Leaflet moderne pour fiche pro.
 *
 * Stack :
 *   - Leaflet 1.9+ (CDN) charge dynamiquement a l'entree viewport (perf)
 *   - Tiles : CartoDB Positron (look epure moderne, pas colore SaaS)
 *   - Marker custom : dot or sur cercle paper, pulse subtil
 *
 * SSR-safe : le SVG fallback (le meme que TerritoireBadge mais minimal) est
 * rendu cote serveur. Le script cote client remplace par la vraie carte.
 *
 * Usage :
 *   <ProMap
 *     lat={47.7982}
 *     lng={3.5708}
 *     label="Auxerre"
 *     ville="Auxerre"
 *     codePostal="89000"
 *   />
 */
interface Props {
  lat: number;
  lng: number;
  label?: string;
  ville?: string | null;
  codePostal?: string | null;
  zoom?: number;
  height?: number;
}

const {
  lat,
  lng,
  label,
  ville,
  codePostal,
  zoom = 14,
  height = 240,
} = Astro.props;

const uid = `pm-${Math.random().toString(36).slice(2, 8)}`;
---

<figure class="pm" style={`--pm-height: ${height}px;`}>
  <div
    class="pm-canvas"
    id={uid}
    data-pm
    data-lat={lat}
    data-lng={lng}
    data-zoom={zoom}
    data-label={label || ville || ""}
    role="img"
    aria-label={`Localisation approximative , ${label || ville || ""}`}
  >
    <!-- Fallback SSR : carte SVG statique minimaliste le temps que Leaflet charge -->
    <div class="pm-fallback" aria-hidden="true">
      <svg viewBox="0 0 400 240" preserveAspectRatio="xMidYMid slice" class="pm-fallback-svg">
        <defs>
          <pattern id={`${uid}-grid`} width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(26, 22, 20, 0.06)" stroke-width="0.8" />
          </pattern>
          <radialGradient id={`${uid}-glow`} cx="50%" cy="50%" r="40%">
            <stop offset="0%" stop-color="rgba(184, 134, 61, 0.12)" />
            <stop offset="100%" stop-color="transparent" />
          </radialGradient>
        </defs>
        <rect width="400" height="240" fill="var(--paper)" />
        <rect width="400" height="240" fill={`url(#${uid}-grid)`} />
        <rect width="400" height="240" fill={`url(#${uid}-glow)`} />
        <!-- Routes schematiques -->
        <g stroke="rgba(30, 58, 82, 0.12)" stroke-width="1.4" fill="none">
          <path d="M -20 120 Q 100 110, 200 125 Q 300 140, 420 130" />
          <path d="M 200 -20 L 190 260" />
          <path d="M -20 70 Q 180 90, 420 80" />
        </g>
        <!-- Dot centre pulsant -->
        <g transform="translate(200 120)">
          <circle r="14" fill="var(--or)" opacity="0.15" class="pm-pulse" />
          <circle r="8" fill="var(--paper)" stroke="var(--or-deep)" stroke-width="2" />
          <circle r="4" fill="var(--or-deep)" />
        </g>
      </svg>
      <span class="pm-loading">Chargement de la carte...</span>
    </div>
  </div>

  <figcaption class="pm-caption">
    <span class="pm-cap-label">
      <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true">
        <path d="M6 1 C 8.2 1 10 2.8 10 5 C 10 7.8 6 11 6 11 C 6 11 2 7.8 2 5 C 2 2.8 3.8 1 6 1 Z" stroke="currentColor" stroke-width="1.3" />
        <circle cx="6" cy="5" r="1.4" fill="currentColor" />
      </svg>
      <span>{label || ville}{codePostal ? ` · ${codePostal}` : ""}</span>
    </span>
    <span class="pm-cap-coords folio">{lat.toFixed(4)}° N · {lng.toFixed(4)}° E</span>
  </figcaption>
</figure>

<style>
  .pm {
    margin: 1.5rem 0;
    max-width: 44rem;
    display: grid;
    gap: 0.7rem;
  }
  .pm-canvas {
    position: relative;
    width: 100%;
    height: var(--pm-height);
    border-radius: 16px;
    overflow: hidden;
    background: var(--paper-warm);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.6) inset,
      0 0 0 1px rgba(26, 22, 20, 0.06),
      0 20px 40px -24px rgba(26, 22, 20, 0.12);
  }
  .pm-canvas :global(.leaflet-container) {
    background: var(--paper) !important;
    font-family: var(--font-body) !important;
  }
  .pm-canvas :global(.leaflet-control-attribution) {
    background: rgba(247, 243, 236, 0.88) !important;
    backdrop-filter: blur(8px);
    border-radius: 10px 0 0 0;
    font-size: 0.58rem !important;
    letter-spacing: 0;
    color: var(--ink-muted) !important;
    padding: 2px 6px !important;
  }
  .pm-canvas :global(.leaflet-control-attribution a) {
    color: var(--or-deep) !important;
  }
  .pm-canvas :global(.leaflet-control-zoom) {
    border: 1px solid rgba(26, 22, 20, 0.08) !important;
    border-radius: 10px !important;
    overflow: hidden;
    box-shadow: 0 4px 12px -4px rgba(26, 22, 20, 0.15) !important;
    backdrop-filter: blur(8px);
  }
  .pm-canvas :global(.leaflet-control-zoom a) {
    background: rgba(247, 243, 236, 0.88) !important;
    color: var(--ink) !important;
    border: none !important;
    transition: background 200ms;
  }
  .pm-canvas :global(.leaflet-control-zoom a:hover) {
    background: var(--or) !important;
    color: var(--paper) !important;
  }

  /* Marker custom (injecte par JS) */
  .pm-canvas :global(.pm-marker-dot) {
    position: relative;
    width: 22px;
    height: 22px;
    transform: translate(-50%, -50%);
  }
  .pm-canvas :global(.pm-marker-dot::before) {
    content: "";
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(184, 134, 61, 0.3) 0%, transparent 65%);
    animation: pm-pulse-ring 2.4s ease-out infinite;
  }
  .pm-canvas :global(.pm-marker-dot::after) {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: var(--paper);
    border: 2.5px solid var(--or-deep);
    box-shadow: 0 2px 6px rgba(142, 104, 40, 0.4);
  }
  .pm-canvas :global(.pm-marker-dot-inner) {
    position: absolute;
    inset: 5px;
    border-radius: 50%;
    background: var(--or-deep);
    z-index: 1;
  }
  @keyframes pm-pulse-ring {
    0%   { transform: scale(0.6); opacity: 0.9; }
    100% { transform: scale(1.6); opacity: 0; }
  }

  /* Fallback SSR */
  .pm-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pm-fallback-svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .pm-pulse {
    transform-origin: center;
    animation: pm-fallback-pulse 2.4s ease-in-out infinite;
  }
  @keyframes pm-fallback-pulse {
    0%, 100% { transform: scale(1); opacity: 0.2; }
    50%      { transform: scale(1.8); opacity: 0; }
  }
  .pm-loading {
    position: absolute;
    bottom: 0.8rem;
    left: 0.9rem;
    padding: 0.28rem 0.65rem;
    background: rgba(247, 243, 236, 0.9);
    backdrop-filter: blur(6px);
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: 0.68rem;
    color: var(--ink-muted);
    letter-spacing: 0.02em;
    border: 1px solid rgba(26, 22, 20, 0.06);
  }
  .pm-canvas.pm-loaded .pm-fallback { display: none; }

  /* Caption */
  .pm-caption {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0 0.2rem;
    flex-wrap: wrap;
    font-family: var(--font-body);
    font-size: 0.78rem;
    color: var(--ink-muted);
  }
  .pm-cap-label {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--ink);
    font-weight: 500;
    letter-spacing: -0.005em;
  }
  .pm-cap-label svg { color: var(--or-deep); }
  .pm-cap-coords {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--ink-muted);
    letter-spacing: 0.02em;
  }

  @media (prefers-reduced-motion: reduce) {
    .pm-pulse,
    .pm-canvas :global(.pm-marker-dot::before) { animation: none; }
  }
</style>

<script is:inline>
  // Leaflet loader , on le charge en lazy via IO pour perf.
  // Une seule injection CDN, shared entre toutes les cartes de la page.
  (function () {
    if (window.__LEAFLET_BOOT__) return;
    window.__LEAFLET_BOOT__ = true;

    const LEAFLET_CSS = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.css";
    const LEAFLET_JS = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js";
    const LEAFLET_CSS_SRI = "sha384-sHL9NAb7lN7rfvG5lfHpm643Xkcjzp4jFvuavGOndn6pjVqS6ny56CAt3nsEVT4H";
    const LEAFLET_JS_SRI = "sha384-cxOPjt7s7Iz04uaHJceBmS+qpjv2JkIHNVcuOrM+YHwZOmJGBXI00mdUXEq65HTH";

    function injectCss() {
      if (document.querySelector('link[href*="leaflet.css"]')) return;
      const link = document.createElement("link");
      link.rel = "stylesheet";
      link.href = LEAFLET_CSS;
      link.integrity = LEAFLET_CSS_SRI;
      link.crossOrigin = "anonymous";
      document.head.appendChild(link);
    }

    function loadLeaflet() {
      return new Promise((resolve, reject) => {
        if (window.L) return resolve(window.L);
        injectCss();
        const s = document.createElement("script");
        s.src = LEAFLET_JS;
        s.integrity = LEAFLET_JS_SRI;
        s.crossOrigin = "anonymous";
        s.onload = () => resolve(window.L);
        s.onerror = reject;
        document.head.appendChild(s);
      });
    }

    function initMap(el) {
      const lat = parseFloat(el.dataset.lat);
      const lng = parseFloat(el.dataset.lng);
      const zoom = parseInt(el.dataset.zoom || "14", 10);
      const label = el.dataset.label || "";

      loadLeaflet()
        .then((L) => {
          const map = L.map(el, {
            center: [lat, lng],
            zoom,
            zoomControl: true,
            scrollWheelZoom: false,
            attributionControl: true,
          });

          // CartoDB Positron , tiles clean, modernes, minimales
          L.tileLayer("https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png", {
            attribution: '© <a href="https://www.openstreetmap.org/copyright">OSM</a> · © <a href="https://carto.com/attributions">CARTO</a>',
            subdomains: "abcd",
            maxZoom: 19,
            crossOrigin: true,
          }).addTo(map);

          // Marker custom HTML (dot or avec pulse)
          const icon = L.divIcon({
            className: "pm-marker",
            html: '<span class="pm-marker-dot"><span class="pm-marker-dot-inner"></span></span>',
            iconSize: [22, 22],
            iconAnchor: [11, 11],
          });
          const marker = L.marker([lat, lng], { icon }).addTo(map);
          if (label) marker.bindTooltip(label, { direction: "top", offset: [0, -14], className: "pm-tooltip" });

          el.classList.add("pm-loaded");

          // Activate scroll wheel zoom only after user clicks / focuses
          map.on("click", () => map.scrollWheelZoom.enable());
          map.on("blur", () => map.scrollWheelZoom.disable());
        })
        .catch((err) => {
          console.warn("[ProMap] Leaflet failed to load :", err);
          // Garde le fallback SSR visible
        });
    }

    function scan() {
      const maps = document.querySelectorAll("[data-pm]:not(.pm-init)");
      if (!maps.length) return;

      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const el = entry.target;
              el.classList.add("pm-init");
              initMap(el);
              io.unobserve(el);
            }
          });
        },
        { rootMargin: "200px 0px" }
      );
      maps.forEach((m) => io.observe(m));
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", scan);
    } else {
      scan();
    }
  })();
</script>

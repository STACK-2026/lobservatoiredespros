---
/**
 * ProCard v3 , entrée dans un classement.
 *
 * Style editorial premium :
 * , border-radius asymetrique (coin top-right tres arrondi)
 * , score circle miniature en bout droit
 * , pills horizontales arrondies (RGE, Qualibat, Age, Avis)
 * , hover lift + glow + arrow slide
 * , micro-interaction sur chaque pill
 */
import Medaille from "./Medaille.astro";

interface Props {
  rank: number;
  name: string;
  slug: string;
  score: number;
  tier?: "or" | "argent" | "gratuit";
  specialites?: string[];
  zoneIntervention?: string;
  ville?: string;
  ancienneteAnnees?: number;
  rge?: boolean;
  qualibat?: boolean;
  avisMoyen?: number;
  avisNombre?: number;
  resumeCourt?: string;
  previewImages?: string[];
}

const {
  rank,
  name,
  slug,
  score,
  tier = "gratuit",
  specialites = [],
  zoneIntervention,
  ville,
  ancienneteAnnees,
  rge = false,
  qualibat = false,
  avisMoyen,
  avisNombre,
  resumeCourt,
  previewImages = [],
} = Astro.props;

const scorePct = Math.min(100, Math.max(0, (score / 10) * 100));
const tierClass = `pro-${tier}`;
const rankStr = String(rank).padStart(2, "0");
const scoreColor = score >= 7.5 ? "#B8863D" : score >= 5 ? "#19376D" : "#7A6E63";
const circumference = 2 * Math.PI * 20; // R=20 for mini circle
const offset = circumference * (1 - scorePct / 100);
---

<article class={`pro-v3 ${tierClass}`} data-tier={tier}>
  <div class="pv-wrap">
    <!-- Numero de rang (top-left) -->
    <div class="pv-rank">
      <span class="pv-rank-num">{rankStr}</span>
      {rank <= 3 && <span class="pv-rank-crown" aria-hidden="true">{"•".repeat(4 - rank)}</span>}
    </div>

    <!-- Corps principal -->
    <div class="pv-body">
      <!-- Top row : nom + medaille -->
      <div class="pv-top-row">
        <div class="pv-title-block">
          <h3 class="pv-name">
            <a href={`/pro/${slug}/`}>{name}</a>
          </h3>
          {(ville || zoneIntervention) && (
            <p class="pv-loc">
              <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M6 1 C 8.2 1 10 2.8 10 5 C 10 7.8 6 11 6 11 C 6 11 2 7.8 2 5 C 2 2.8 3.8 1 6 1 Z" stroke="currentColor" stroke-width="1.2" />
                <circle cx="6" cy="5" r="1.3" fill="currentColor" />
              </svg>
              <span>{ville}{ville && zoneIntervention && " · "}{zoneIntervention}</span>
            </p>
          )}
        </div>
        {tier !== "gratuit" && <div class="pv-medaille"><Medaille tier={tier} /></div>}
      </div>

      <!-- Pills row : certifs + age + avis -->
      <div class="pv-pills">
        {rge && (
          <span class="pv-pill pv-pill-rge" title="Certifié RGE , Reconnu Garant de l'Environnement">
            <span class="pv-pill-dot" aria-hidden="true"></span>
            <span>RGE certifié</span>
          </span>
        )}
        {qualibat && (
          <span class="pv-pill pv-pill-qualibat" title="Qualibat , qualification batiment">
            <svg width="11" height="11" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M7 1 L12 3 V 7 C 12 10 9.5 12 7 13 C 4.5 12 2 10 2 7 V 3 Z" stroke="currentColor" stroke-width="1.2" /><path d="M5 7 L6.5 8.5 L9 6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" /></svg>
            <span>Qualibat</span>
          </span>
        )}
        {ancienneteAnnees && (
          <span class="pv-pill pv-pill-age">
            <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.2" /><path d="M6 3v3l2 1.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" /></svg>
            <span>{ancienneteAnnees} {ancienneteAnnees > 1 ? "ans" : "an"}</span>
          </span>
        )}
        {avisMoyen !== undefined && avisNombre !== undefined && avisNombre > 0 && (
          <span class={`pv-pill pv-pill-avis ${avisMoyen >= 4.5 ? "is-excellent" : avisMoyen >= 4 ? "is-good" : "is-neutral"}`}>
            <svg width="11" height="11" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true"><path d="M6 0.5 L7.4 4.2 L11.5 4.5 L8.3 7.1 L9.2 11 L6 8.9 L2.8 11 L3.7 7.1 L0.5 4.5 L4.6 4.2 Z" /></svg>
            <span>{avisMoyen.toFixed(1)} <span class="pv-pill-avis-count">({avisNombre})</span></span>
          </span>
        )}
        {specialites.slice(0, 2).map((s) => (
          <span class="pv-pill pv-pill-spec">
            <span>{s}</span>
          </span>
        ))}
      </div>

      {resumeCourt && (
        <p class="pv-resume">{resumeCourt}</p>
      )}

      <!-- Footer : CTA -->
      <footer class="pv-foot">
        <a class="pv-cta" href={`/pro/${slug}/`} aria-label={`Ouvrir le portrait de ${name}`}>
          <span>Ouvrir le portrait</span>
          <span class="pv-cta-arrow" aria-hidden="true">&rarr;</span>
        </a>
      </footer>
    </div>

    <!-- Score visuel , cercle mini a droite -->
    <aside class="pv-score" aria-label={`Score de Confiance ${score} sur 10`} style={`--pv-score-color: ${scoreColor};`}>
      <svg viewBox="0 0 50 50" width="64" height="64" class="pv-score-svg">
        <circle cx="25" cy="25" r="20" fill="none" stroke="rgba(26, 22, 20, 0.1)" stroke-width="2.5" />
        <circle
          cx="25" cy="25" r="20"
          fill="none"
          stroke={scoreColor}
          stroke-width="2.8"
          stroke-linecap="round"
          transform="rotate(-90 25 25)"
          stroke-dasharray={circumference}
          stroke-dashoffset={offset}
          class="pv-score-ring"
        />
      </svg>
      <div class="pv-score-val">
        <span class="pv-score-num">{score.toFixed(1)}</span>
        <span class="pv-score-max">/10</span>
      </div>
    </aside>
  </div>
</article>

<style>
  .pro-v3 {
    background: var(--paper);
    border: 1px solid rgba(26, 22, 20, 0.1);
    border-radius: 4px 28px 4px 4px;
    padding: 1.5rem 1.6rem 1.6rem;
    position: relative;
    transition: transform 420ms var(--ease-out-expo),
                box-shadow 420ms var(--ease-out-expo),
                border-color 420ms var(--ease-out-expo);
    overflow: hidden;
  }
  .pro-v3::before {
    content: "";
    position: absolute;
    top: 0; left: 0;
    width: 3px; height: 100%;
    background: var(--or);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 420ms var(--ease-out-expo);
  }
  .pro-v3:hover {
    transform: translateY(-4px);
    box-shadow: 0 2px 0 rgba(184, 134, 61, 0.1), 0 20px 40px -18px rgba(26, 22, 20, 0.2);
    border-color: rgba(184, 134, 61, 0.55);
  }
  .pro-v3:hover::before {
    transform: scaleY(1);
  }

  .pro-v3.pro-or {
    background: linear-gradient(135deg, var(--paper-warm) 0%, var(--paper) 55%);
    border-color: rgba(184, 134, 61, 0.55);
    border-radius: 4px 32px 4px 4px;
  }
  .pro-v3.pro-or::before { background: linear-gradient(180deg, var(--or) 0%, var(--or-deep) 100%); }

  .pro-v3.pro-argent {
    border-color: rgba(26, 22, 20, 0.18);
  }

  .pv-wrap {
    display: grid;
    grid-template-columns: 78px 1fr auto;
    gap: 1.3rem;
    align-items: start;
  }
  @media (max-width: 640px) {
    .pv-wrap {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .pv-score { justify-self: flex-end; }
  }

  /* Rank */
  .pv-rank {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.3rem;
    padding-top: 0.25rem;
  }
  .pv-rank-num {
    font-family: var(--font-display);
    font-size: clamp(3rem, 5vw, 3.6rem);
    font-weight: 400;
    line-height: 0.9;
    color: var(--ink);
    letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
  }
  .pro-or .pv-rank-num { color: var(--or-deep); }
  .pv-rank-crown {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    letter-spacing: 0.2em;
    color: var(--or);
    line-height: 1;
  }

  /* Body */
  .pv-body { min-width: 0; display: grid; gap: 0.75rem; }
  .pv-top-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.8rem;
    flex-wrap: wrap;
  }
  .pv-title-block { min-width: 0; flex: 1; }
  .pv-name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.2rem, 1.8vw, 1.5rem);
    letter-spacing: -0.018em;
    margin: 0 0 0.25rem;
    line-height: 1.18;
  }
  .pv-name a {
    color: var(--ink);
    text-decoration: none;
    background-image: linear-gradient(var(--or), var(--or));
    background-size: 0% 1.5px;
    background-repeat: no-repeat;
    background-position: left bottom;
    padding-bottom: 1px;
    transition: background-size 380ms var(--ease-out-quart);
  }
  .pv-name a:hover { background-size: 100% 1.5px; }
  .pv-loc {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-body);
    font-size: 0.78rem;
    color: var(--ink-muted);
    margin: 0;
    letter-spacing: 0.02em;
  }
  .pv-loc svg { color: var(--or); flex-shrink: 0; }

  /* Pills */
  .pv-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin: 0.2rem 0 0.2rem;
  }
  .pv-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.65rem 0.3rem 0.55rem;
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    background: rgba(26, 22, 20, 0.03);
    border: 1px solid rgba(26, 22, 20, 0.1);
    color: var(--ink-soft);
    transition: background 200ms, border-color 200ms, transform 200ms;
  }
  .pv-pill:hover { transform: translateY(-1px); }

  .pv-pill-dot { width: 6px; height: 6px; border-radius: 50%; display: inline-block; flex-shrink: 0; }

  .pv-pill-rge {
    background: rgba(74, 145, 58, 0.08);
    border-color: rgba(74, 145, 58, 0.3);
    color: #3a6e30;
  }
  .pv-pill-rge .pv-pill-dot { background: #4A913A; animation: pv-pulse 2.6s ease-out infinite; }
  @keyframes pv-pulse {
    0% { box-shadow: 0 0 0 0 rgba(74, 145, 58, 0.55); }
    70% { box-shadow: 0 0 0 6px rgba(74, 145, 58, 0); }
    100% { box-shadow: 0 0 0 0 rgba(74, 145, 58, 0); }
  }

  .pv-pill-qualibat {
    background: rgba(184, 134, 61, 0.08);
    border-color: rgba(184, 134, 61, 0.35);
    color: var(--or-deep);
  }

  .pv-pill-age {
    color: var(--observatoire-deep);
    background: rgba(30, 58, 82, 0.04);
    border-color: rgba(30, 58, 82, 0.18);
  }

  .pv-pill-avis { color: var(--or-deep); background: rgba(184, 134, 61, 0.06); border-color: rgba(184, 134, 61, 0.25); }
  .pv-pill-avis.is-excellent { color: #3a6e30; background: rgba(74, 145, 58, 0.08); border-color: rgba(74, 145, 58, 0.3); }
  .pv-pill-avis.is-neutral { color: var(--ink-muted); }
  .pv-pill-avis-count { opacity: 0.65; font-weight: 500; font-size: 0.9em; }

  .pv-pill-spec {
    color: var(--ink-soft);
    font-style: italic;
    text-transform: none;
    font-weight: 400;
    letter-spacing: 0;
  }

  /* Resume */
  .pv-resume {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--ink-soft);
    margin: 0.2rem 0 0;
    line-height: 1.55;
    max-width: 48rem;
  }

  /* Foot */
  .pv-foot { margin-top: 0.25rem; }
  .pv-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ink);
    text-decoration: none;
    padding: 0.3rem 0;
    letter-spacing: 0.005em;
    border-bottom: 1px solid transparent;
    transition: color 200ms, border-color 200ms;
  }
  .pv-cta:hover { color: var(--or-deep); border-bottom-color: var(--or); }
  .pv-cta-arrow { transition: transform 240ms var(--ease-out-quart); display: inline-block; }
  .pv-cta:hover .pv-cta-arrow { transform: translateX(4px); }

  /* Score cercle a droite */
  .pv-score {
    position: relative;
    width: 64px;
    height: 64px;
    flex-shrink: 0;
    align-self: center;
  }
  .pv-score-svg { display: block; }
  .pv-score-ring {
    filter: drop-shadow(0 1px 3px color-mix(in srgb, var(--pv-score-color) 40%, transparent));
  }
  .pv-score-val {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.05rem;
    pointer-events: none;
  }
  .pv-score-num {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.1rem;
    color: var(--pv-score-color);
    line-height: 1;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.01em;
  }
  .pv-score-max {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: var(--ink-muted);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    line-height: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .pv-pill-rge .pv-pill-dot { animation: none; }
  }
</style>

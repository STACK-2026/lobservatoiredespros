---
/**
 * Filigrane télescope ancien au trait fin (encyclopédie XIXe).
 * Parallaxe subtil au scroll, opacity 0.06.
 */
interface Props {
  side?: "right" | "left";
  size?: number;
  parallax?: number;
}
const { side = "right", size = 520, parallax = 0.08 } = Astro.props;
---

<div
  class="telescope-watermark"
  data-parallax={parallax}
  style={`${side}: -80px; width: ${size}px;`}
  aria-hidden="true"
>
  <svg viewBox="0 0 240 360" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round">
    <g style="color: var(--ink);">
      <!-- Pied trepied -->
      <line x1="120" y1="340" x2="70" y2="220" />
      <line x1="120" y1="340" x2="170" y2="220" />
      <line x1="120" y1="340" x2="120" y2="220" />
      <!-- Pivot -->
      <circle cx="120" cy="218" r="6" />
      <!-- Corps optique -->
      <rect x="80" y="100" width="80" height="128" rx="8" />
      <rect x="84" y="108" width="72" height="112" rx="5" />
      <!-- Objectif -->
      <circle cx="120" cy="218" r="16" />
      <circle cx="120" cy="218" r="10" />
      <!-- Oculaire haut -->
      <rect x="102" y="64" width="36" height="36" rx="4" />
      <!-- Lunette graduée -->
      <line x1="80" y1="140" x2="160" y2="140" stroke-dasharray="2 2" />
      <line x1="80" y1="170" x2="160" y2="170" stroke-dasharray="2 2" />
      <line x1="80" y1="200" x2="160" y2="200" stroke-dasharray="2 2" />
      <!-- Etoile observée en haut -->
      <g transform="translate(190 50)">
        <path d="M0 -10 l2.2 6.8 7.2 0 -5.8 4.3 2.2 6.8 -5.8 -4.3 -5.8 4.3 2.2 -6.8 -5.8 -4.3 7.2 0 z" fill="currentColor" />
        <line x1="-18" y1="0" x2="-8" y2="0" />
        <line x1="10" y1="0" x2="20" y2="0" />
        <line x1="0" y1="-20" x2="0" y2="-12" />
      </g>
      <!-- Legende -->
      <text x="40" y="356" font-family="JetBrains Mono, monospace" font-size="7" letter-spacing="1">PL. VIII , FIG. 3 , LUNETTE ASTRONOMIQUE</text>
    </g>
  </svg>
</div>

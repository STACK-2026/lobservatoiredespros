---
/**
 * EditorialTicker , fil presse live style Bloomberg/Mediapart.
 *
 * Marquee horizontal qui defile en haut de page. Genere 12-20 events a partir
 * des pros Supabase avec format :
 *   [HH:MM] [Action] n°XXX · [Nom entreprise] · [Ville] · Score XX → YY
 *
 * Animation : ticker-scroll 60s linear infinite. Pause au hover.
 * Prefers-reduced-motion : animation desactivee mais texte reste visible (scroll manuel).
 * Accessibility : aria-live="off" (trop bruyant pour lecteurs d'ecran).
 */
import { supabase } from "../lib/supabase";

interface TickerEvent {
  time: string;
  type: "observation" | "score" | "certification" | "dossier";
  label: string;
  detail: string;
  slug?: string; // lien vers la fiche pro
}

// Fetch top pros (par score) pour generer des events credibles
const { data: pros } = await supabase
  .from("pros")
  .select("nom_entreprise, ville, code_postal, score_confiance, siret, rge, date_creation_entreprise, slug")
  .eq("active", true)
  .order("score_confiance", { ascending: false })
  .limit(18);

// Generer des events "live" deterministes basés sur les vrais pros
const events: TickerEvent[] = [];
const now = new Date();
if (pros && pros.length > 0) {
  pros.forEach((p: any, i: number) => {
    const minutesAgo = (i * 7) + Math.floor((p.siret || "0").slice(-2).charCodeAt(0) % 15);
    const d = new Date(now.getTime() - minutesAgo * 60_000);
    const hh = String(d.getHours()).padStart(2, "0");
    const mm = String(d.getMinutes()).padStart(2, "0");
    const score = p.score_confiance || 4.5;
    const prev = Math.max(0, score - 0.3).toFixed(1);
    const nxt = score.toFixed(1);
    const ville = p.ville ? p.ville.replace(/-/g, " ") : "";
    const cp = p.code_postal ? p.code_postal.slice(0, 2) : "";

    // Alterner les types d'events
    const kind = i % 4;
    const slug = p.slug || undefined;
    if (kind === 0) {
      events.push({
        time: `${hh}:${mm}`,
        type: "observation",
        label: `Observation n°${(i + 1) * 1372 + 47382}`,
        detail: `${p.nom_entreprise} · ${ville} (${cp}) · Score ${nxt}/10`,
        slug,
      });
    } else if (kind === 1) {
      events.push({
        time: `${hh}:${mm}`,
        type: "score",
        label: `Score recalculé`,
        detail: `${p.nom_entreprise} · ${prev} → ${nxt}`,
        slug,
      });
    } else if (kind === 2 && p.rge) {
      events.push({
        time: `${hh}:${mm}`,
        type: "certification",
        label: `Certification RGE confirmée`,
        detail: `${p.nom_entreprise} · ${ville}`,
        slug,
      });
    } else if (kind === 2) {
      events.push({
        time: `${hh}:${mm}`,
        type: "dossier",
        label: `Dossier ouvert`,
        detail: `${p.nom_entreprise} · examen en cours`,
        slug,
      });
    } else {
      events.push({
        time: `${hh}:${mm}`,
        type: "observation",
        label: `SIRET vérifié`,
        detail: `${p.nom_entreprise} · ${ville} · actif INSEE`,
        slug,
      });
    }
  });
}

// Fallback si aucun pros en DB , avec liens vers pages de classement
if (events.length === 0) {
  const seed: Array<Omit<TickerEvent, "time"> & { href?: string }> = [
    { type: "observation", label: "Édition N°1 publiée", detail: "290 plombiers · Yonne (89)" },
    { type: "observation", label: "Nouvelle observation", detail: "SARL DUBOIS & Fils · Auxerre · Score 4.5/10" },
    { type: "certification", label: "RGE confirmé", detail: "Plomberie HE · Auxerre" },
    { type: "dossier", label: "Dossier ouvert", detail: "Certification RGE perdue à Sens" },
  ];
  seed.forEach((s, i) => {
    const d = new Date(now.getTime() - i * 13 * 60_000);
    events.push({
      time: `${String(d.getHours()).padStart(2, "0")}:${String(d.getMinutes()).padStart(2, "0")}`,
      ...s,
    });
  });
}

// Dupliquer pour boucle infinie visuelle sans trou
const loop = [...events, ...events];
---

<div class="editorial-ticker" role="complementary" aria-label="Fil d'actualité de la rédaction" aria-live="off">
  <div class="et-label">
    <span class="et-live-dot" aria-hidden="true"></span>
    <span class="et-label-text">En direct</span>
    <span class="et-label-sep" aria-hidden="true"></span>
    <span class="et-edition folio">Édition N°1</span>
  </div>
  <div class="et-track-wrapper">
    <div class="et-track">
      {loop.map((e) => {
        const href = e.slug ? `/pro/${e.slug}/` : "/selection/";
        const ariaLabel = `${e.label} , ${e.detail}`;
        return (
          <a class={`et-item et-item-${e.type}`} href={href} aria-label={ariaLabel}>
            <span class="et-time">{e.time}</span>
            <span class="et-type-dot" aria-hidden="true"></span>
            <span class="et-item-label">{e.label}</span>
            <span class="et-item-sep" aria-hidden="true">·</span>
            <span class="et-item-detail">{e.detail}</span>
            <span class="et-item-arrow" aria-hidden="true">&rarr;</span>
          </a>
        );
      })}
    </div>
  </div>
</div>

<style>
  .editorial-ticker {
    background: var(--ink);
    color: var(--paper);
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    border-bottom: 1px solid rgba(184, 134, 61, 0.35);
    font-family: var(--font-body);
    font-size: 0.78rem;
    position: relative;
    z-index: 40;
    overflow: hidden;
  }

  .et-label {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.6rem 1rem 0.55rem 1.1rem;
    background: linear-gradient(90deg, var(--ink) 70%, rgba(26, 22, 20, 0) 100%);
    position: relative;
    z-index: 2;
    white-space: nowrap;
  }
  .et-live-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #E53935;
    box-shadow: 0 0 0 0 rgba(229, 57, 53, 0.6);
    animation: et-live-pulse 1.6s ease-out infinite;
    flex-shrink: 0;
  }
  @keyframes et-live-pulse {
    0% { box-shadow: 0 0 0 0 rgba(229, 57, 53, 0.7); }
    70% { box-shadow: 0 0 0 7px rgba(229, 57, 53, 0); }
    100% { box-shadow: 0 0 0 0 rgba(229, 57, 53, 0); }
  }
  .et-label-text {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.68rem;
    color: var(--or-soft);
  }
  .et-label-sep {
    display: inline-block;
    width: 1px;
    height: 12px;
    background: rgba(247, 243, 236, 0.2);
  }
  .et-edition {
    color: rgba(247, 243, 236, 0.55);
    font-size: 0.7rem;
  }

  .et-track-wrapper {
    overflow: hidden;
    mask-image: linear-gradient(90deg, transparent 0, black 40px, black calc(100% - 60px), transparent 100%);
    -webkit-mask-image: linear-gradient(90deg, transparent 0, black 40px, black calc(100% - 60px), transparent 100%);
  }
  .et-track {
    display: inline-flex;
    align-items: center;
    gap: 2.5rem;
    white-space: nowrap;
    animation: ticker-scroll 75s linear infinite;
    padding-left: 1.5rem;
    will-change: transform;
  }
  .editorial-ticker:hover .et-track { animation-play-state: paused; }
  @keyframes ticker-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .et-item {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.76rem;
    letter-spacing: 0.008em;
    flex-shrink: 0;
    text-decoration: none;
    color: inherit;
    padding: 0.25rem 0.55rem;
    border-radius: 4px;
    transition: background 220ms, transform 220ms;
    cursor: pointer;
  }
  .et-item:hover {
    background: rgba(184, 134, 61, 0.14);
    transform: translateY(-1px);
  }
  .et-item:focus-visible {
    outline: 2px solid var(--or);
    outline-offset: 2px;
  }
  .et-item-arrow {
    display: inline-block;
    color: var(--or-soft);
    opacity: 0;
    margin-left: -0.4rem;
    transform: translateX(-3px);
    transition: opacity 220ms, transform 220ms, margin-left 220ms;
  }
  .et-item:hover .et-item-arrow {
    opacity: 1;
    margin-left: 0.1rem;
    transform: translateX(0);
  }
  .et-time {
    font-family: var(--font-mono);
    color: rgba(247, 243, 236, 0.55);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
  }
  .et-type-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .et-item-observation .et-type-dot { background: var(--or); }
  .et-item-score .et-type-dot { background: var(--observatoire); box-shadow: 0 0 8px rgba(30, 58, 82, 0.6); }
  .et-item-certification .et-type-dot { background: #4A913A; }
  .et-item-dossier .et-type-dot { background: var(--cachet); }

  .et-item-label {
    color: var(--paper);
    font-weight: 600;
    letter-spacing: 0.01em;
  }
  .et-item-observation .et-item-label { color: var(--or-soft); }
  .et-item-certification .et-item-label { color: #A4D595; }
  .et-item-dossier .et-item-label { color: #E8A09A; }

  .et-item-sep {
    color: rgba(247, 243, 236, 0.3);
    margin: 0 -0.1rem;
  }
  .et-item-detail {
    color: rgba(247, 243, 236, 0.8);
  }

  @media (max-width: 720px) {
    .et-label { padding: 0.55rem 0.8rem 0.5rem 0.9rem; }
    .et-edition { display: none; }
    .et-label-sep { display: none; }
    .et-track { gap: 1.8rem; }
    .et-item { font-size: 0.72rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .et-track { animation: none; overflow-x: auto; }
    .et-live-dot { animation: none; box-shadow: none; }
  }
</style>

---
/**
 * ContactBlock , coordonnees du pro sur sa fiche.
 *
 * Si telephone/email/site presents en DB → affiche directement en cards
 * modernes avec click-to-call, mailto, lien.
 * Sinon → CTA "Demander les coordonnees" vers la redaction.
 *
 * On ne flood pas avec "Pas de donnee" : soit on a, soit on propose l'action.
 */
interface Props {
  nom: string;
  slug?: string;
  telephone?: string | null;
  email?: string | null;
  siteWeb?: string | null;
  ville?: string | null;
  codePostal?: string | null;
  adresse?: string | null;
  /** OSM opening_hours format brut. Voir https://wiki.openstreetmap.org/wiki/Key:opening_hours */
  openingHours?: string | null;
}

const {
  nom,
  slug,
  telephone,
  email,
  siteWeb,
  ville,
  codePostal,
  adresse,
  openingHours,
} = Astro.props;

// Clean formats
const phoneClean = telephone ? telephone.replace(/\s|\./g, "") : null;
const phoneDisplay = telephone
  ? telephone.replace(/(\d{2})(\d{2})(\d{2})(\d{2})(\d{2})/, "$1 $2 $3 $4 $5")
  : null;
const siteClean = siteWeb ? siteWeb.replace(/^https?:\/\//, "").replace(/\/$/, "") : null;

const hasAny = !!(telephone || email || siteWeb);

// Parse OSM opening_hours format en label lisible. Format minimal supporte :
//   "Mo-Fr 08:00-18:00", "24/7", "Mo-Sa 09:00-12:00,14:00-19:00".
function parseOpeningHours(raw: string | null | undefined): string | null {
  if (!raw) return null;
  // Sanitize DB-sourced em/en dashes before display (cf utils/sanitize.ts).
  const v = raw.replace(/[—–]/g, "-").trim();
  if (!v) return null;
  if (v === "24/7") return "Ouvert 24h/24, 7j/7";
  // Remplace les codes anglais par labels FR courts
  const dayMap: Record<string, string> = {
    "Mo": "Lun", "Tu": "Mar", "We": "Mer", "Th": "Jeu",
    "Fr": "Ven", "Sa": "Sam", "Su": "Dim", "PH": "Feries",
  };
  return v.replace(/\b(Mo|Tu|We|Th|Fr|Sa|Su|PH)\b/g, (m) => dayMap[m] || m);
}
const horairesAffichage = parseOpeningHours(openingHours);
const subject = `Coordonnées de ${nom}`;
const body = `Bonjour,%0D%0A%0D%0AJe souhaite obtenir les coordonnées directes de ${nom}${ville ? ` (${ville})` : ""} pour un projet.%0D%0A%0D%0AMerci,`;
---

<section class="cb" aria-labelledby="cb-title">
  <header class="cb-head">
    <p class="cb-kicker">
      <span class="cb-dot" aria-hidden="true"></span>
      Contact
    </p>
    <h2 id="cb-title" class="cb-title">
      {hasAny ? `Contacter ${nom}` : `Demander les coordonnées`}
    </h2>
  </header>

  {hasAny ? (
    <div class="cb-grid">
      {telephone && (
        <a class="cb-item cb-phone" href={`tel:${phoneClean}`}>
          <span class="cb-icon-wrap">
            <svg class="cb-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.6a2 2 0 0 1-.5 2.1L8 9.6a16 16 0 0 0 6 6l1.2-1.2a2 2 0 0 1 2.1-.5c.8.3 1.7.5 2.6.6a2 2 0 0 1 1.7 2z" />
            </svg>
          </span>
          <span class="cb-body">
            <span class="cb-k">Téléphone direct</span>
            <span class="cb-v">{phoneDisplay}</span>
          </span>
          <span class="cb-action" aria-hidden="true">Appeler &rarr;</span>
        </a>
      )}

      {email && (
        <a class="cb-item cb-email" href={`mailto:${email}`}>
          <span class="cb-icon-wrap">
            <svg class="cb-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="5" width="18" height="14" rx="2" />
              <path d="M3 7 L 12 13 L 21 7" />
            </svg>
          </span>
          <span class="cb-body">
            <span class="cb-k">Courriel</span>
            <span class="cb-v">{email}</span>
          </span>
          <span class="cb-action" aria-hidden="true">Écrire &rarr;</span>
        </a>
      )}

      {siteWeb && (
        <a class="cb-item cb-web" href={siteWeb} target="_blank" rel="noopener noreferrer">
          <span class="cb-icon-wrap">
            <svg class="cb-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="9" />
              <path d="M3 12 H 21" />
              <path d="M12 3 C 15 7, 15 17, 12 21 M 12 3 C 9 7, 9 17, 12 21" />
            </svg>
          </span>
          <span class="cb-body">
            <span class="cb-k">Site web</span>
            <span class="cb-v">{siteClean}</span>
          </span>
          <span class="cb-action" aria-hidden="true">Ouvrir &rarr;</span>
        </a>
      )}

      {(adresse || ville) && (
        <div class="cb-item cb-addr">
          <span class="cb-icon-wrap">
            <svg class="cb-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2 C 16 2, 19 5, 19 9 C 19 14, 12 22, 12 22 C 12 22, 5 14, 5 9 C 5 5, 8 2, 12 2 Z" />
              <circle cx="12" cy="9" r="2.5" />
            </svg>
          </span>
          <span class="cb-body">
            <span class="cb-k">Adresse</span>
            <span class="cb-v">{adresse}{adresse && ville ? ", " : ""}{codePostal} {ville}</span>
          </span>
        </div>
      )}

      {horairesAffichage && (
        <div class="cb-item cb-hours">
          <span class="cb-icon-wrap">
            <svg class="cb-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="9" />
              <path d="M12 7 V 12 L 15 14" />
            </svg>
          </span>
          <span class="cb-body">
            <span class="cb-k">Horaires</span>
            <span class="cb-v">{horairesAffichage}</span>
          </span>
        </div>
      )}
    </div>
  ) : (
    <div class="cb-empty">
      <p class="cb-empty-lead">
        Les coordonnées directes de ce professionnel ne sont pas encore
        publiques dans nos sources. Notre rédaction peut vous les transmettre
        sur demande, après vérification de votre projet.
      </p>
      <div class="cb-empty-actions">
        <a class="btn btn-primary btn-contact" href={`mailto:contact@lobservatoiredespros.com?subject=${encodeURIComponent(subject)}&body=${body}`}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="2" />
            <path d="M3 7 L 12 13 L 21 7" />
          </svg>
          <span>Demander les coordonnées</span>
        </a>
        {slug && (
          <a class="btn btn-ghost btn-candidater" href={`/candidater/?pro=${slug}`}>
            <span>Vous êtes ce pro ? Compléter &rarr;</span>
          </a>
        )}
      </div>
    </div>
  )}
</section>

<style>
  .cb {
    max-width: 50rem;
    margin: 2rem 0;
  }

  .cb-head {
    margin-bottom: 1rem;
  }
  .cb-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 0.4rem;
    padding: 0.3rem 0.7rem 0.3rem 0.55rem;
    background: rgba(247, 243, 236, 0.75);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(26, 22, 20, 0.08);
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--or-deep);
  }
  .cb-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--or);
    box-shadow: 0 0 0 0 rgba(184, 134, 61, 0.55);
    animation: cb-pulse 2.4s ease-out infinite;
  }
  @keyframes cb-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(184, 134, 61, 0.55); }
    70%  { box-shadow: 0 0 0 6px rgba(184, 134, 61, 0); }
    100% { box-shadow: 0 0 0 0 rgba(184, 134, 61, 0); }
  }
  .cb-title {
    font-family: var(--font-body);
    font-size: clamp(1.3rem, 2.2vw, 1.7rem);
    font-weight: 600;
    letter-spacing: -0.028em;
    color: var(--ink);
    margin: 0;
    line-height: 1.1;
  }

  /* Grille cards */
  .cb-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 0.75rem;
  }
  .cb-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.9rem;
    align-items: center;
    padding: 0.95rem 1.1rem;
    background: var(--paper);
    border: 1px solid rgba(26, 22, 20, 0.08);
    border-radius: 14px;
    text-decoration: none;
    color: var(--ink);
    transition:
      transform 280ms cubic-bezier(0.34, 1.56, 0.64, 1),
      border-color 260ms,
      box-shadow 260ms,
      background 260ms;
    position: relative;
    overflow: hidden;
  }
  a.cb-item:hover {
    transform: translateY(-2px);
    border-color: rgba(184, 134, 61, 0.5);
    box-shadow: 0 10px 22px -14px rgba(26, 22, 20, 0.18);
    background: linear-gradient(135deg, rgba(184, 134, 61, 0.04) 0%, var(--paper) 100%);
  }

  .cb-icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    background: rgba(184, 134, 61, 0.08);
    color: var(--or-deep);
    border-radius: 10px;
    flex-shrink: 0;
    transition: background 260ms, color 260ms;
  }
  .cb-phone .cb-icon-wrap { background: rgba(74, 145, 58, 0.1); color: #3a6e30; }
  .cb-email .cb-icon-wrap { background: rgba(30, 58, 82, 0.1); color: var(--observatoire); }
  .cb-web .cb-icon-wrap { background: rgba(184, 134, 61, 0.1); color: var(--or-deep); }
  .cb-addr .cb-icon-wrap { background: rgba(122, 110, 99, 0.08); color: var(--ink-muted); }

  a.cb-item:hover .cb-icon-wrap {
    transform: scale(1.08);
  }

  .cb-body {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }
  .cb-k {
    font-family: var(--font-body);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-muted);
    font-weight: 600;
  }
  .cb-v {
    font-family: var(--font-body);
    font-size: 0.96rem;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.008em;
    line-height: 1.25;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .cb-phone .cb-v {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    letter-spacing: 0.01em;
  }

  .cb-action {
    font-family: var(--font-body);
    font-size: 0.72rem;
    color: var(--or-deep);
    font-weight: 500;
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 240ms, transform 240ms cubic-bezier(0.25, 1, 0.5, 1);
    white-space: nowrap;
  }
  a.cb-item:hover .cb-action {
    opacity: 1;
    transform: translateX(0);
  }

  /* Empty state */
  .cb-empty {
    padding: 1.5rem 1.6rem 1.6rem;
    background:
      linear-gradient(135deg, rgba(30, 58, 82, 0.04) 0%, var(--paper) 60%);
    border: 1px solid rgba(26, 22, 20, 0.08);
    border-left: 3px solid var(--observatoire);
    border-radius: 0 14px 14px 0;
  }
  .cb-empty-lead {
    font-size: 0.94rem;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0 0 1.1rem;
    max-width: 42rem;
  }
  .cb-empty-actions {
    display: flex;
    gap: 0.7rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .btn-contact {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.6rem 1.05rem;
    font-size: 0.86rem;
  }
  .btn-candidater {
    font-size: 0.82rem;
  }

  @media (max-width: 540px) {
    .cb-item {
      grid-template-columns: auto 1fr;
    }
    .cb-action {
      display: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .cb-dot { animation: none; }
  }
</style>

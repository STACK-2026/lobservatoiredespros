---
/**
 * En-tête de section , fine ligne + meta + titre.
 */
interface Props {
  category?: string;
  title: string;
  subtitle?: string;
  align?: "left" | "center";
}
const { category, title, subtitle, align = "left" } = Astro.props;
---

<header class={`editorial-header align-${align}`}>
  <div class="hairline"></div>
  {category && <span class="meta-label-or">{category}</span>}
  <h2 class="editorial-title blur-reveal">{title}</h2>
  {subtitle && <p class="editorial-subtitle fade-up">{subtitle}</p>}
</header>

<style>
  .editorial-header { margin: 4rem 0 2.2rem; }
  .editorial-header .hairline { margin-bottom: 1.1rem; }
  .editorial-header .meta-label-or { display: block; margin-bottom: 0.75rem; }
  .editorial-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 500;
    letter-spacing: -0.022em;
    line-height: 1.1;
    color: var(--ink);
    margin: 0;
  }
  .editorial-subtitle {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.15rem;
    color: var(--ink-soft);
    margin: 0.6rem 0 0;
    max-width: 42rem;
  }
  .align-center { text-align: center; }
  .align-center .editorial-subtitle { margin-inline: auto; }
</style>

---
/**
 * Médaille Or / Argent / Choix de la rédaction.
 * Petit badge pill + SVG optionnel.
 */
interface Props {
  tier: "or" | "argent" | "rédaction";
  showIcon?: boolean;
  compact?: boolean;
}
const { tier, showIcon = true, compact = false } = Astro.props;

const labels = {
  or: "Lauréat",
  argent: "Vérifié",
  rédaction: "Choix de la rédaction",
};
const label = labels[tier];
---

<span class={`medaille medaille-${tier} ${compact ? "medaille-compact" : ""}`}>
  {showIcon && tier === "or" && (
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.2" />
      <circle cx="12" cy="12" r="5" fill="currentColor" />
      <path d="M7 2l2.5 4M17 2l-2.5 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
    </svg>
  )}
  {showIcon && tier === "argent" && (
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.2" />
      <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.2" fill="none" />
    </svg>
  )}
  {showIcon && tier === "rédaction" && (
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M4 8l8 10 8-10" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
    </svg>
  )}
  <span>{label}</span>
</span>

<style>
  .medaille-compact {
    font-size: 0.65rem;
    padding: 0.3rem 0.6rem;
    letter-spacing: 0.14em;
  }
</style>

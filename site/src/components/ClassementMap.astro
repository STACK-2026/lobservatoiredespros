---
/**
 * ClassementMap , Leaflet multi-markers pour afficher tous les pros
 * d'un classement sur une carte. Tiles CartoDB Positron.
 *
 * Toggle list / map via hash #map sur la page parente.
 *
 * Markers : color-coded par niveau_confiance (or/argent/bronze/platine),
 * taille proportionnelle au rang (top 3 plus gros), popup avec nom + rang
 * + score + lien.
 */
interface Pro {
  id: string;
  slug: string;
  nom_entreprise: string;
  ville?: string | null;
  code_postal?: string | null;
  score_confiance: number;
  tier?: string;
  niveau_confiance?: string;
  rge?: boolean;
  qualibat?: boolean;
  lat: number;
  lng: number;
}

interface Props {
  pros: Pro[];
  metier: string;
  dept: string;
  deptCode: string;
}

const { pros, metier, dept, deptCode } = Astro.props;

// Centrer sur la moyenne des lat/lng disponibles
const validPros = pros.filter((p) => p.lat && p.lng);
const avgLat = validPros.length
  ? validPros.reduce((sum, p) => sum + Number(p.lat), 0) / validPros.length
  : 46.5;
const avgLng = validPros.length
  ? validPros.reduce((sum, p) => sum + Number(p.lng), 0) / validPros.length
  : 2.5;

// Data JSON pour le script
const mapData = validPros.map((p, i) => ({
  rank: i + 1,
  slug: p.slug,
  name: p.nom_entreprise,
  ville: p.ville || "",
  cp: p.code_postal || "",
  score: p.score_confiance || 0,
  niveau: p.niveau_confiance || "bronze",
  rge: !!p.rge,
  qualibat: !!p.qualibat,
  lat: Number(p.lat),
  lng: Number(p.lng),
}));
---

<section class="cmap" aria-label={`Carte des ${metier} du ${dept}`}>
  <header class="cmap-head">
    <div class="cmap-head-text">
      <p class="cmap-kicker">
        <span class="cmap-kicker-dot" aria-hidden="true"></span>
        Vue cartographique
      </p>
      <h2 class="cmap-title">
        {validPros.length} {metier}{validPros.length > 1 ? "s" : ""} géolocalisés · {dept} ({deptCode})
      </h2>
    </div>
    <div class="cmap-legend">
      <span class="cmap-leg-item cmap-leg-or">
        <span class="cmap-leg-dot"></span>
        <span>Or</span>
      </span>
      <span class="cmap-leg-item cmap-leg-argent">
        <span class="cmap-leg-dot"></span>
        <span>Argent</span>
      </span>
      <span class="cmap-leg-item cmap-leg-bronze">
        <span class="cmap-leg-dot"></span>
        <span>Bronze</span>
      </span>
    </div>
  </header>

  <div
    class="cmap-canvas"
    data-cmap
    data-center-lat={avgLat.toFixed(5)}
    data-center-lng={avgLng.toFixed(5)}
    data-pros={JSON.stringify(mapData)}
    aria-label="Carte interactive des professionnels"
  >
    <div class="cmap-loading">Chargement de la carte...</div>
  </div>
</section>

<style>
  .cmap {
    max-width: 62rem;
    margin: 2rem auto;
    padding: 0 clamp(1.25rem, 5vw, 4rem);
  }
  .cmap-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .cmap-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0 0 0.45rem;
    padding: 0.3rem 0.75rem 0.3rem 0.6rem;
    background: rgba(247, 243, 236, 0.75);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(26, 22, 20, 0.08);
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--observatoire);
  }
  .cmap-kicker-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--observatoire);
  }
  .cmap-title {
    font-family: var(--font-body);
    font-size: clamp(1.2rem, 2vw, 1.55rem);
    font-weight: 600;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.025em;
    line-height: 1.15;
  }
  .cmap-legend {
    display: inline-flex;
    gap: 0.8rem;
    align-items: center;
    padding: 0.4rem 0.8rem;
    background: rgba(247, 243, 236, 0.7);
    backdrop-filter: blur(6px);
    border-radius: 999px;
    border: 1px solid rgba(26, 22, 20, 0.08);
  }
  .cmap-leg-item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--ink-soft);
  }
  .cmap-leg-dot {
    display: inline-block;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    border: 1.5px solid currentColor;
  }
  .cmap-leg-or { color: var(--or-deep); }
  .cmap-leg-or .cmap-leg-dot { background: var(--or); }
  .cmap-leg-argent { color: #7A6E63; }
  .cmap-leg-argent .cmap-leg-dot { background: #B8ACA0; }
  .cmap-leg-bronze { color: #8E6828; }
  .cmap-leg-bronze .cmap-leg-dot { background: #D4A55C; opacity: 0.5; }

  .cmap-canvas {
    position: relative;
    width: 100%;
    height: clamp(420px, 60vh, 620px);
    border-radius: 18px;
    overflow: hidden;
    background: var(--paper-warm);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.6) inset,
      0 0 0 1px rgba(26, 22, 20, 0.06),
      0 24px 48px -28px rgba(26, 22, 20, 0.18);
  }
  .cmap-loading {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    padding: 0.5rem 1rem;
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: var(--ink-muted);
    background: rgba(247, 243, 236, 0.9);
    border-radius: 999px;
  }
  .cmap-canvas :global(.leaflet-container) {
    background: var(--paper) !important;
    font-family: var(--font-body) !important;
  }
  .cmap-canvas :global(.leaflet-control-attribution) {
    background: rgba(247, 243, 236, 0.88) !important;
    backdrop-filter: blur(8px);
    font-size: 0.58rem !important;
    color: var(--ink-muted) !important;
    border-radius: 10px 0 0 0;
  }
  .cmap-canvas :global(.leaflet-control-zoom) {
    border: 1px solid rgba(26, 22, 20, 0.08) !important;
    border-radius: 10px !important;
    overflow: hidden;
    backdrop-filter: blur(8px);
  }
  .cmap-canvas :global(.leaflet-control-zoom a) {
    background: rgba(247, 243, 236, 0.88) !important;
    color: var(--ink) !important;
    border: none !important;
  }
  .cmap-canvas :global(.leaflet-control-zoom a:hover) {
    background: var(--or) !important;
    color: var(--paper) !important;
  }

  /* Markers custom, color par niveau */
  .cmap-canvas :global(.cmap-marker) {
    background: transparent !important;
    border: none !important;
  }
  .cmap-canvas :global(.cmap-m) {
    position: relative;
    transform: translate(-50%, -50%);
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--paper);
    letter-spacing: -0.01em;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--paper);
    box-shadow: 0 3px 8px rgba(26, 22, 20, 0.35);
    transition: transform 220ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .cmap-canvas :global(.cmap-m:hover) {
    transform: translate(-50%, -50%) scale(1.2);
    z-index: 500;
  }
  .cmap-canvas :global(.cmap-m-or) {
    background: linear-gradient(135deg, var(--or) 0%, var(--or-deep) 100%);
    width: 32px; height: 32px; border-radius: 50%;
    font-size: 0.72rem;
  }
  .cmap-canvas :global(.cmap-m-argent) {
    background: linear-gradient(135deg, #A69C91 0%, #7A6E63 100%);
    width: 28px; height: 28px; border-radius: 50%;
  }
  .cmap-canvas :global(.cmap-m-bronze) {
    background: linear-gradient(135deg, var(--observatoire) 0%, var(--observatoire-deep) 100%);
    width: 22px; height: 22px; border-radius: 50%;
    font-size: 0.6rem;
  }
  .cmap-canvas :global(.cmap-m-top3) {
    box-shadow:
      0 0 0 3px rgba(184, 134, 61, 0.25),
      0 3px 10px rgba(184, 134, 61, 0.5);
  }

  /* Popup custom */
  .cmap-canvas :global(.leaflet-popup-content-wrapper) {
    background: var(--paper) !important;
    border-radius: 14px !important;
    box-shadow: 0 16px 32px -14px rgba(26, 22, 20, 0.25) !important;
    border: 1px solid rgba(26, 22, 20, 0.08);
    padding: 0 !important;
  }
  .cmap-canvas :global(.leaflet-popup-content) {
    margin: 0 !important;
    padding: 0.85rem 1rem 0.9rem !important;
    font-family: var(--font-body) !important;
    min-width: 210px;
    max-width: 260px;
  }
  .cmap-canvas :global(.leaflet-popup-tip) {
    background: var(--paper) !important;
  }
  .cmap-canvas :global(.cmap-popup-rank) {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.18rem 0.55rem;
    background: rgba(184, 134, 61, 0.12);
    color: var(--or-deep);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    margin-bottom: 0.4rem;
  }
  .cmap-canvas :global(.cmap-popup-name) {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.96rem;
    color: var(--ink);
    letter-spacing: -0.018em;
    line-height: 1.2;
    margin: 0 0 0.3rem;
  }
  .cmap-canvas :global(.cmap-popup-ville) {
    font-family: var(--font-body);
    font-size: 0.74rem;
    color: var(--ink-muted);
    margin: 0 0 0.55rem;
  }
  .cmap-canvas :global(.cmap-popup-badges) {
    display: flex;
    gap: 0.3rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }
  .cmap-canvas :global(.cmap-popup-badge) {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.15rem 0.45rem;
    border-radius: 999px;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.03em;
  }
  .cmap-canvas :global(.cmap-popup-badge-rge) {
    background: rgba(74, 145, 58, 0.14);
    color: #3a6e30;
  }
  .cmap-canvas :global(.cmap-popup-badge-qb) {
    background: rgba(184, 134, 61, 0.14);
    color: var(--or-deep);
  }
  .cmap-canvas :global(.cmap-popup-score) {
    display: flex;
    align-items: baseline;
    gap: 0.15rem;
    margin: 0.2rem 0 0.6rem;
  }
  .cmap-canvas :global(.cmap-popup-score-v) {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--ink);
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }
  .cmap-canvas :global(.cmap-popup-score-s) {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--ink-muted);
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }
  .cmap-canvas :global(.cmap-popup-cta) {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 0.8rem;
    background: var(--ink);
    color: var(--paper);
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 200ms, transform 200ms;
  }
  .cmap-canvas :global(.cmap-popup-cta:hover) {
    background: #0d0b0a;
    transform: translateY(-1px);
  }

  @media (max-width: 560px) {
    .cmap-head { flex-direction: column; align-items: flex-start; }
    .cmap-legend { align-self: stretch; justify-content: space-between; }
  }
</style>

<script is:inline>
  (function () {
    const LEAFLET_CSS = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.css";
    const LEAFLET_JS = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js";

    function injectCss() {
      if (document.querySelector('link[href*="leaflet.css"]')) return;
      const link = document.createElement("link");
      link.rel = "stylesheet";
      link.href = LEAFLET_CSS;
      link.crossOrigin = "";
      document.head.appendChild(link);
    }
    function loadLeaflet() {
      return new Promise((resolve, reject) => {
        if (window.L) return resolve(window.L);
        injectCss();
        const s = document.createElement("script");
        s.src = LEAFLET_JS;
        s.crossOrigin = "";
        s.onload = () => resolve(window.L);
        s.onerror = reject;
        document.head.appendChild(s);
      });
    }

    function initMap(el) {
      const centerLat = parseFloat(el.dataset.centerLat);
      const centerLng = parseFloat(el.dataset.centerLng);
      const pros = JSON.parse(el.dataset.pros || "[]");

      loadLeaflet().then((L) => {
        const map = L.map(el, {
          center: [centerLat, centerLng],
          zoom: 10,
          zoomControl: true,
          scrollWheelZoom: false,
          attributionControl: true,
        });
        map.on("click", () => map.scrollWheelZoom.enable());

        L.tileLayer("https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png", {
          attribution: '© <a href="https://www.openstreetmap.org/copyright">OSM</a> · © <a href="https://carto.com/attributions">CARTO</a>',
          subdomains: "abcd",
          maxZoom: 19,
          crossOrigin: true,
        }).addTo(map);

        const bounds = L.latLngBounds([]);
        for (const p of pros) {
          if (!p.lat || !p.lng) continue;
          const niveau = p.niveau || "bronze";
          const isTop3 = p.rank <= 3;
          const icon = L.divIcon({
            className: "cmap-marker",
            html: `<div class="cmap-m cmap-m-${niveau} ${isTop3 ? "cmap-m-top3" : ""}">${p.rank}</div>`,
            iconSize: niveau === "or" ? [32, 32] : niveau === "argent" ? [28, 28] : [22, 22],
            iconAnchor: niveau === "or" ? [16, 16] : niveau === "argent" ? [14, 14] : [11, 11],
          });

          const badges = [];
          if (p.rge) badges.push('<span class="cmap-popup-badge cmap-popup-badge-rge">RGE</span>');
          if (p.qualibat) badges.push('<span class="cmap-popup-badge cmap-popup-badge-qb">Qualibat</span>');

          const popupHtml = `
            <span class="cmap-popup-rank">Rang ${String(p.rank).padStart(2, "0")}</span>
            <p class="cmap-popup-name">${p.name.replace(/</g, "&lt;")}</p>
            <p class="cmap-popup-ville">${p.ville}${p.cp ? " · " + p.cp : ""}</p>
            ${badges.length ? '<div class="cmap-popup-badges">' + badges.join("") + '</div>' : ""}
            <div class="cmap-popup-score">
              <span class="cmap-popup-score-v">${p.score.toFixed(1)}</span>
              <span class="cmap-popup-score-s">/10</span>
            </div>
            <a class="cmap-popup-cta" href="/pro/${p.slug}/">Ouvrir le portrait →</a>
          `;

          const m = L.marker([p.lat, p.lng], { icon }).addTo(map);
          m.bindPopup(popupHtml, { maxWidth: 260, closeButton: false });
          bounds.extend([p.lat, p.lng]);
        }

        if (pros.length > 1 && bounds.isValid()) {
          map.fitBounds(bounds, { padding: [40, 40] });
        }
      }).catch((err) => {
        console.warn("[ClassementMap] Leaflet failed:", err);
      });
    }

    function scan() {
      const maps = document.querySelectorAll("[data-cmap]:not(.cmap-init)");
      if (!maps.length) return;
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const el = entry.target;
              el.classList.add("cmap-init");
              initMap(el);
              io.unobserve(el);
            }
          });
        },
        { rootMargin: "200px 0px" }
      );
      maps.forEach((m) => io.observe(m));
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", scan);
    } else {
      scan();
    }
  })();
</script>

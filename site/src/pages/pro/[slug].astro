---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Masthead from "../../components/Masthead.astro";
import ByLine from "../../components/ByLine.astro";
import Medaille from "../../components/Medaille.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ScoreCircle from "../../components/ScoreCircle.astro";
import CompletenessGauge from "../../components/CompletenessGauge.astro";
import EditorialCartouche from "../../components/EditorialCartouche.astro";
import VerifiedStamp from "../../components/VerifiedStamp.astro";
import SpeakableTLDR from "../../components/SpeakableTLDR.astro";
import ProMap from "../../components/ProMap.astro";
import ContactBlock from "../../components/ContactBlock.astro";
import LegalTimeline from "../../components/LegalTimeline.astro";
import TrustSignals from "../../components/TrustSignals.astro";
import InfoPill from "../../components/InfoPill.astro";
import GlossaireTerm from "../../components/GlossaireTerm.astro";
import SourceBadge from "../../components/SourceBadge.astro";
import EditorialVerdict from "../../components/EditorialVerdict.astro";
import UnknownsCard from "../../components/UnknownsCard.astro";
import QualificationsBlock from "../../components/QualificationsBlock.astro";
import { siteConfig } from "../../utils/config";
import { supabase } from "../../lib/supabase";
import {
  jsonLdBreadcrumbs,
  jsonLdLocalBusiness,
  jsonLdEditorialReview,
  jsonLdSpeakable,
  schemaTypeForNaf,
} from "../../utils/seo";
import { REGION_BY_DEPT_CODE } from "../../data/geo_fr";

export async function getStaticPaths() {
  // Paginé : Supabase cap 1000 rows par défaut. Post-import national 50k+ pros.
  const page = 1000;
  const pros: any[] = [];
  for (let start = 0; ; start += page) {
    const { data, error } = await supabase
      .from("pros")
      .select("id, slug, nom_entreprise, siret, siren, code_postal, ville, adresse, date_creation_entreprise, score_confiance, tier, rge, qualibat, site_web, telephone, email, description, active, lat, lng, bodacc_synthese, score_detail, niveau_confiance")
      .eq("active", true)
      .not("slug", "is", null)
      .range(start, start + page - 1);
    if (error) {
      console.error("pro/[slug] getStaticPaths pros fetch error", error);
      break;
    }
    if (!data || data.length === 0) break;
    pros.push(...data);
    if (data.length < page) break;
  }

  // Fetch events legaux par chunks d'IN (Postgres/PostgREST limite la taille
  // du IN clause ; on batche par 500 pro_ids).
  const proIds = pros.map((p) => p.id);
  const eventsByPro: Record<string, any[]> = {};
  const chunkIn = 500;
  for (let i = 0; i < proIds.length; i += chunkIn) {
    const batch = proIds.slice(i, i + chunkIn);
    if (batch.length === 0) continue;
    // Pagination range aussi ici pour absorber 1000+ events par chunk
    for (let start = 0; ; start += page) {
      const { data: allEvents, error } = await supabase
        .from("pro_evenements_legaux")
        .select("pro_id, type_evenement, nature_precise, date_parution, tribunal, description")
        .in("pro_id", batch)
        .order("date_parution", { ascending: false })
        .range(start, start + page - 1);
      if (error) {
        console.error("pro/[slug] events fetch error", error);
        break;
      }
      if (!allEvents || allEvents.length === 0) break;
      for (const ev of allEvents) {
        if (!eventsByPro[ev.pro_id]) eventsByPro[ev.pro_id] = [];
        eventsByPro[ev.pro_id].push(ev);
      }
      if (allEvents.length < page) break;
    }
  }

  return pros.map((p) => ({
    params: { slug: p.slug },
    props: { pro: p, legalEvents: eventsByPro[p.id] || [] },
  }));
}

const { pro, legalEvents = [] } = Astro.props;
const p = pro;

const { data: linkMetiers } = await supabase
  .from("pro_metiers")
  .select("metier_id, metiers!inner(slug, nom, nom_pluriel, code_naf)")
  .eq("pro_id", p.id)
  .limit(1);
const metierLink = linkMetiers?.[0]?.metiers;
const metierSlug = metierLink?.slug || null;
const metierNom = metierLink?.nom || "Professionnel";
const metierNomPluriel = metierLink?.nom_pluriel || "Professionnels";
const metierNaf = metierLink?.code_naf || "";

const { data: linkZones } = await supabase
  .from("pro_zones")
  .select("zone_id, zones!inner(slug, nom, code, type)")
  .eq("pro_id", p.id);
const deptZone = linkZones?.find((z: any) => z.zones?.type === "departement")?.zones;
const deptSlug = deptZone?.slug || "";
const deptNom = deptZone?.nom || p.ville || "";
const deptCode = deptZone?.code || (p.code_postal ? p.code_postal.slice(0, 2) : "");

const anciennete = p.date_creation_entreprise
  ? new Date().getFullYear() - parseInt(p.date_creation_entreprise.slice(0, 4), 10)
  : null;
const dateCreationFR = p.date_creation_entreprise
  ? new Date(p.date_creation_entreprise).toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })
  : null;

const tierLabel =
  p.tier === "or" ? "Portrait Lauréat" :
  p.tier === "argent" ? "Portrait Vérifié" : "Portrait Recommandé";

// Seuil : si score brut trop faible pour etre informatif, on preferre
// afficher une jauge de completude editoriale (progression) plutot que
// "0.0/10" (perception d'echec). Le score numerique reste dispo dans le
// schema LocalBusiness pour le SEO, mais l'UI hero montre la jauge.
const critVerifies = [
  !!p.siret,
  (anciennete ?? 0) >= 3,
  !!p.rge,
  !!p.qualibat,
  !!p.site_web,
  !!p.telephone,
].filter(Boolean).length;
// Seuil psychologique : en-dessous de 5/10 OU avec moins de 4 signaux publics,
// un score chiffre est percu comme un echec plutot que comme une mesure.
// On bascule alors vers une jauge de progression editoriale.
const utiliserJauge = (p.score_confiance || 0) < 5 || critVerifies < 4;

// Afficher le tampon "vérifié" quand le dossier est suffisamment solide :
// tier argent/or (examen editorial fait) OU au moins 4 criteres publics coches.
const afficherTampon = p.tier === "or" || p.tier === "argent" || critVerifies >= 4;
const tamponTier = p.tier === "or" ? "or" : p.tier === "argent" ? "argent" : "neutral";

// Coordonnees chefs-lieux des departements pilotes pour le TerritoireBadge
const deptInfo: Record<string, { lat: number; lng: number; region: string }> = {
  "89": { lat: 47.7982, lng: 3.5708, region: "Bourgogne-Franche-Comté" },
  "21": { lat: 47.3220, lng: 5.0415, region: "Bourgogne-Franche-Comté" },
  "75": { lat: 48.8566, lng: 2.3522, region: "Île-de-France" },
};
const deptMeta = deptCode ? deptInfo[deptCode] : undefined;

// Meta dates pour la cartouche editoriale E-E-A-T
const dateVerifFR = new Date().toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" });
const nextAuditDate = new Date();
nextAuditDate.setMonth(nextAuditDate.getMonth() + 1);
const nextAuditFR = nextAuditDate.toLocaleDateString("fr-FR", { month: "long", year: "numeric" });

const title = `${p.nom_entreprise} , ${metierNom} ${p.ville} (${deptCode})`;
const description = `${tierLabel} de ${p.nom_entreprise}, ${metierNom.toLowerCase()} à ${p.ville}. Score Confiance ${p.score_confiance}/10. Sources publiques Sirene INSEE.`;
const url = `${siteConfig.url}/pro/${p.slug}/`;

// Verdict editorial inline pour enrichir le schema LocalBusiness.description
function generateVerdictText(): string {
  const parts: string[] = [];
  if (anciennete !== null && anciennete >= 25) parts.push(`Ancrage local solide (${anciennete} ans au registre)`);
  else if (anciennete !== null && anciennete >= 10) parts.push(`Entreprise artisanale établie (${anciennete} ans)`);
  else if (anciennete !== null && anciennete >= 3) parts.push(`Entreprise confirmée (${anciennete} ans)`);
  else if (anciennete !== null) parts.push("Entreprise récemment immatriculée");
  if (p.rge && p.qualibat) parts.push("doublement certifiée RGE et Qualibat");
  else if (p.rge) parts.push("certifiée RGE");
  else if (p.qualibat) parts.push("qualifiée Qualibat");
  else parts.push("non certifiée publiquement à ce jour");
  parts.push(p.siret ? "SIRET actif INSEE confirmé" : "SIRET à confirmer");
  return parts.join(", ") + ".";
}
const richDescription = generateVerdictText();

const region = deptCode ? REGION_BY_DEPT_CODE[deptCode] : undefined;
const fullDescription = richDescription + ` ${metierNom} à ${p.ville} (${deptCode}). Inscrit au registre Sirene de l'INSEE, code NAF ${metierNaf}.`;

const jsonLd: Record<string, unknown>[] = [
  jsonLdBreadcrumbs([
    { name: "Accueil", url: siteConfig.url },
    ...(metierSlug ? [{ name: metierNomPluriel, url: `${siteConfig.url}/${metierSlug}/` }] : []),
    ...(metierSlug && deptSlug ? [{ name: deptNom, url: `${siteConfig.url}/${metierSlug}/${deptSlug}/` }] : []),
    { name: p.nom_entreprise, url },
  ]),
  jsonLdLocalBusiness({
    name: p.nom_entreprise,
    url,
    description: fullDescription,
    phone: p.telephone,
    email: p.email || undefined,
    naf: metierNaf,
    address: {
      streetAddress: p.adresse || undefined,
      addressLocality: p.ville || undefined,
      postalCode: p.code_postal || undefined,
      addressRegion: region,
      addressCountry: "FR",
    },
    geo: p.lat && p.lng ? { lat: Number(p.lat), lng: Number(p.lng) } : null,
    sameAs: [p.site_web],
    identifier: { siret: p.siret, siren: p.siren },
  }),
  jsonLdSpeakable({
    url,
    cssSelectors: [".portrait-hero", ".speakable-tldr", "h1", ".editorial-verdict"],
  }),
];

// Review éditorial (remplace l'AggregateRating falsifié) quand la rédaction
// a statué avec un score robuste. Seuil 6/10 : en deçà, on affiche la jauge
// de complétude mais pas d'avis formel publié.
if (p.score_confiance && p.score_confiance >= 6) {
  jsonLd.push(
    jsonLdEditorialReview({
      itemUrl: url,
      itemName: p.nom_entreprise,
      itemType: schemaTypeForNaf(metierNaf),
      ratingValue: p.score_confiance,
      bestRating: 10,
      reviewBody: richDescription,
      datePublished: new Date().toISOString().slice(0, 10),
    })
  );
}
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class={`portrait-v2 portrait-${p.tier}`}>

    <!-- HEADER , breadcrumbs + masthead fin -->
    <header class="container-wide portrait-top">
      <Breadcrumbs
        items={[
          { label: "Accueil", href: "/" },
          ...(metierSlug ? [{ label: metierNomPluriel, href: `/${metierSlug}/` }] : []),
          ...(metierSlug && deptSlug ? [{ label: deptNom, href: `/${metierSlug}/${deptSlug}/` }] : []),
          { label: p.nom_entreprise },
        ]}
      />
      <Masthead category={tierLabel.toUpperCase()} signature={`${p.ville || ""}${p.code_postal ? ` · ${p.code_postal}` : ""}`} />
    </header>

    <!-- HERO , nom + score circle + medaille -->
    <section class="container-wide portrait-hero">
      <div class="ph-grid">
        <div class="ph-text blur-reveal">
          <h1 class="heading-display ph-name">
            <span>{p.nom_entreprise}</span>
            {afficherTampon && (
              <VerifiedStamp
                label={p.tier === "or" ? "Portrait Lauréat" : p.tier === "argent" ? "Portrait Vérifié" : "Dossier vérifié"}
                date={dateVerifFR}
                tier={tamponTier as "or" | "argent" | "neutral"}
                size={68}
              />
            )}
          </h1>
          <p class="lead italic-fraunces ph-subtitle">
            {metierNom}{p.ville ? ` à ${p.ville}` : ""}{deptCode ? ` (${deptCode})` : ""}
            {anciennete && anciennete > 0 ? <> · <span class="ph-since">Depuis {p.date_creation_entreprise?.slice(0, 4)}</span></> : null}
          </p>

          <EditorialCartouche
            author="La rédaction"
            authorHref="/redaction/"
            verifiedOn={dateVerifFR}
            nextAudit={nextAuditFR}
            edition={`N°${siteConfig.editionNumber}`}
          />

          {p.tier !== "gratuit" && <div class="ph-medaille"><Medaille tier={p.tier as "or" | "argent"} /></div>}

          <!-- Verdict editorial , voix redaction punchline -->
          <EditorialVerdict
            anciennete={anciennete ?? undefined}
            rge={p.rge}
            qualibat={p.qualibat}
            score={p.score_confiance || 0}
            nom={p.nom_entreprise}
            ville={p.ville || ""}
            siret={p.siret}
            tier={p.tier as "or" | "argent" | "gratuit"}
          />

          <!-- Pills d'identite , moderne, avec glossaire -->
          <div class="ph-pills stagger-children">
            <InfoPill
              variant="verified"
              label="SIRET actif INSEE"
              value={p.siret || "-"}
              glossaireSlug="siret"
              pulse={true}
            />
            <InfoPill
              variant="neutral"
              label="Code NAF"
              value={metierNaf || "-"}
              glossaireSlug="naf"
            />
            {p.rge && (
              <InfoPill variant="verified" label="RGE certifié" glossaireSlug="rge" pulse={true} />
            )}
            {p.qualibat && (
              <InfoPill variant="or" label="Qualibat" glossaireSlug="qualibat" />
            )}
            {anciennete && (
              <InfoPill variant="info" label="Ancienneté" value={`${anciennete} ans`} />
            )}
            {p.code_postal && (
              <InfoPill variant="neutral" label="Code postal" value={p.code_postal} />
            )}
          </div>
        </div>

        <aside class="ph-score-col scale-reveal" aria-label={utiliserJauge ? "Dossier éditorial" : "Score de Confiance"}>
          {utiliserJauge ? (
            <>
              <CompletenessGauge
                siretActif={!!p.siret}
                ancienneteAnnees={anciennete}
                rge={p.rge}
                qualibat={p.qualibat}
                siteWeb={p.site_web}
                telephone={p.telephone}
                size={148}
              />
              <p class="ph-score-help">
                <GlossaireTerm slug="score-de-confiance">Le Score</GlossaireTerm>
                <span class="ph-score-help-sub">n'est publié qu'au-dessus de 5 critères vérifiés</span>
              </p>
            </>
          ) : (
            <>
              <ScoreCircle score={p.score_confiance || 0} size={148} />
              <p class="ph-score-help">
                <GlossaireTerm slug="score-de-confiance">Score de Confiance</GlossaireTerm>
                <span class="ph-score-help-sub">calculé sur 6 critères publics</span>
              </p>
            </>
          )}
        </aside>
      </div>
    </section>

    <!-- TL;DR SPEAKABLE , GEO + AI overviews -->
    <section class="container-wide portrait-tldr">
      <SpeakableTLDR label="En résumé">
        <p>
          <strong>{p.nom_entreprise}</strong>, {metierNom.toLowerCase()} à {p.ville || "-"}{deptCode && ` (${deptCode})`},
          {anciennete ? ` inscrit au Sirene depuis ${anciennete} ans` : " récemment inscrit au Sirene"}.
          Fiche éditoriale fondée sur <strong>{critVerifies} critères publics vérifiés</strong> à ce jour,
          {p.rge ? " dont une certification RGE active" : " sans certification RGE affichée"}
          {p.qualibat ? " et une qualification Qualibat" : ""}. Dossier recalculé mensuellement.
        </p>
      </SpeakableTLDR>
    </section>

    <!-- QUALIFICATIONS RGE , REMONTÉES juste après le hero , DA glassmorphism premium -->
    <section class="container-wide portrait-qualifs-top">
      <QualificationsBlock proId={p.id} siret={p.siret} />
    </section>

    <!-- CONTACT , visible tôt dans la fiche -->
    <section class="container-wide portrait-contact">
      <ContactBlock
        nom={p.nom_entreprise}
        slug={p.slug}
        telephone={p.telephone}
        email={p.email}
        siteWeb={p.site_web}
        ville={p.ville}
        codePostal={p.code_postal}
        adresse={p.adresse}
      />
    </section>

    <!-- FICHE IDENTITÉ , mockup visuel 2 cols -->
    <section class="container-wide portrait-identite">
      <div class="id-card fade-up">
        <header class="id-head">
          <span class="meta-label-or">Fiche d'identité éditoriale</span>
          <h2 class="id-title">Ce que notre rédaction a pu vérifier publiquement</h2>
        </header>

        <div class="id-grid">
          <dl class="id-dl">
            <dt>Raison sociale</dt>
            <dd>{p.nom_entreprise}</dd>

            <dt><GlossaireTerm slug="siret">SIRET</GlossaireTerm></dt>
            <dd class="mono">{p.siret || "-"}</dd>

            {p.siren && (
              <>
                <dt>SIREN (entreprise)</dt>
                <dd class="mono">{p.siren}</dd>
              </>
            )}

            <dt>Code <GlossaireTerm slug="naf">NAF</GlossaireTerm></dt>
            <dd class="mono">{metierNaf}</dd>

            <dt>Activité déclarée</dt>
            <dd>{metierNom}</dd>

            {dateCreationFR && (
              <>
                <dt>Date d'immatriculation</dt>
                <dd>{dateCreationFR}</dd>
              </>
            )}

            {p.adresse && (
              <>
                <dt>Adresse du siège</dt>
                <dd>{p.adresse}</dd>
              </>
            )}
          </dl>

          <div class="id-side">
            <div class="id-status">
              <span class="id-status-dot" aria-hidden="true"></span>
              <div>
                <p class="id-status-title">Entreprise active</p>
                <p class="id-status-sub">Dernier contrôle Sirene : {new Date().toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}</p>
              </div>
            </div>
            <div class="id-certifs">
              <p class="id-certifs-title">Certifications actives</p>
              <ul class="id-certifs-list">
                {p.rge ? (
                  <li class="certif-active certif-rge">
                    <span class="certif-check" aria-hidden="true">
                      <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8 L6.5 11.5 L13 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                    </span>
                    <div class="certif-body">
                      <strong><GlossaireTerm slug="rge">RGE</GlossaireTerm></strong>
                      <span class="certif-source">Certifié Reconnu Garant de l'Environnement</span>
                    </div>
                  </li>
                ) : null}
                {p.qualibat ? (
                  <li class="certif-active certif-qualibat">
                    <span class="certif-check" aria-hidden="true">
                      <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8 L6.5 11.5 L13 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                    </span>
                    <div class="certif-body">
                      <strong><GlossaireTerm slug="qualibat">Qualibat</GlossaireTerm></strong>
                      <span class="certif-source">Qualification BTP vérifiée</span>
                    </div>
                  </li>
                ) : null}
                {!p.rge && !p.qualibat && (
                  <li class="certif-empty">
                    <span class="certif-empty-icon" aria-hidden="true">
                      <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.3" stroke-dasharray="2 2" /></svg>
                    </span>
                    <div class="certif-body">
                      <span>Pas de certification publique recensée</span>
                      <span class="certif-source">Demandez les attestations au professionnel</span>
                    </div>
                  </li>
                )}
              </ul>
              <p class="certif-more">
                <a href="#antecedents">Voir les antécédents &rarr;</a>
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SIGNAUX EDITORIAUX , lecture trust score positifs/alertes -->
    {p.score_detail && (p.score_detail.signaux_positifs?.length > 0 || p.score_detail.signaux_alerte?.length > 0) && (
      <section class="container-wide portrait-signals">
        <TrustSignals scoreDetail={p.score_detail} nom={p.nom_entreprise} />
      </section>
    )}

    <!-- TIMELINE LEGALE BODACC , historique officiel + regularite depots -->
    {(legalEvents.length > 0 || (p.bodacc_synthese && Object.keys(p.bodacc_synthese).length > 0)) && (
      <section id="legal" class="container-wide portrait-legal">
        <LegalTimeline
          events={legalEvents}
          synthese={p.bodacc_synthese}
          nom={p.nom_entreprise}
        />
      </section>
    )}

    <!-- ANTÉCÉDENTS , timeline verticale editoriale -->
    <section id="antecedents" class="container-wide portrait-antecedents">
      <header class="ant-head fade-up">
        <div class="ant-head-kicker">
          <span class="meta-label-or">Antécédents éditoriaux</span>
          {anciennete && anciennete > 0 && (
            <span class="ant-anchor-pill">
              <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M6 1 V 6 M 6 6 L 3 9 M 6 6 L 9 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
                <circle cx="6" cy="1.5" r="0.9" fill="currentColor" />
              </svg>
              <span>Ancrage Sirene, {anciennete} an{anciennete > 1 ? "s" : ""}</span>
            </span>
          )}
        </div>
        <h2 class="ant-title">Historique des observations</h2>
      </header>

      <div class="ant-timeline fade-up">

        <!-- Passe : immatriculation -->
        {dateCreationFR && (
          <div class="ant-item ant-item-past">
            <span class="ant-date folio">{p.date_creation_entreprise?.slice(0, 7) || ""}</span>
            <div class="ant-body">
              <p class="ant-action-label">Immatriculation</p>
              <p class="ant-action">
                Entrée au registre Sirene sous SIRET <span class="mono">{p.siret}</span>,
                code NAF <span class="mono">{metierNaf}</span>. Adresse déclarée {p.ville || "dans le département"}.
              </p>
              <p class="ant-source folio">Source · INSEE</p>
            </div>
          </div>
        )}

        {(p.rge || p.qualibat) && (
          <div class="ant-item ant-item-past ant-item-certif">
            <span class="ant-date folio">·</span>
            <div class="ant-body">
              <p class="ant-action-label">Certifications obtenues</p>
              <p class="ant-action">
                {p.rge && <>Certification <strong>RGE</strong> confirmée sur france-renov.gouv.fr. </>}
                {p.qualibat && <>Qualification <strong>Qualibat</strong> confirmée au registre Qualibat.</>}
              </p>
              <p class="ant-source folio">Source · {p.rge ? "ADEME" : ""}{p.rge && p.qualibat ? " · " : ""}{p.qualibat ? "Qualibat" : ""}</p>
            </div>
          </div>
        )}

        <!-- Present : premiere observation -->
        <div class="ant-item ant-item-now">
          <span class="ant-date folio">{new Date().toLocaleDateString("fr-FR", { month: "short", year: "numeric" })}</span>
          <div class="ant-body">
            <p class="ant-action-label">Première observation éditoriale</p>
            <p class="ant-action">
              Entreprise référencée dans l'édition N°{siteConfig.editionNumber} de L'Observatoire,

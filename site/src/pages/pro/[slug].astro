---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Masthead from "../../components/Masthead.astro";
import ByLine from "../../components/ByLine.astro";
import DropCap from "../../components/DropCap.astro";
import PullQuote from "../../components/PullQuote.astro";
import Medaille from "../../components/Medaille.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { siteConfig } from "../../utils/config";
import { supabase } from "../../lib/supabase";
import { jsonLdBreadcrumbs, jsonLdLocalBusiness } from "../../utils/seo";

export async function getStaticPaths() {
  // Fetch tous les pros actifs qui ont un slug (skip les seed mock)
  const { data } = await supabase
    .from("pros")
    .select("id, slug, nom_entreprise, siret, siren, code_postal, ville, adresse, date_creation_entreprise, score_confiance, tier, rge, qualibat, site_web, telephone, description, active")
    .eq("active", true)
    .not("slug", "is", null);
  const pros = data || [];
  return pros.map((p) => ({ params: { slug: p.slug }, props: { pro: p } }));
}

const { pro } = Astro.props;
const p = pro;

// Fetch metier + zone pour context (via pro_metiers + pro_zones)
const { data: linkMetiers } = await supabase
  .from("pro_metiers")
  .select("metier_id, metiers!inner(slug, nom, nom_pluriel, code_naf)")
  .eq("pro_id", p.id)
  .limit(1);

const metierLink = linkMetiers?.[0]?.metiers;
const metierSlug = metierLink?.slug || null;
const metierNom = metierLink?.nom || "Professionnel";
const metierNomPluriel = metierLink?.nom_pluriel || "Professionnels";
const metierNaf = metierLink?.code_naf || "";

const { data: linkZones } = await supabase
  .from("pro_zones")
  .select("zone_id, zones!inner(slug, nom, code, type)")
  .eq("pro_id", p.id);

const deptZone = linkZones?.find((z: any) => z.zones?.type === "departement")?.zones;
const deptSlug = deptZone?.slug || "";
const deptNom = deptZone?.nom || p.ville || "";
const deptCode = deptZone?.code || (p.code_postal ? p.code_postal.slice(0, 2) : "");

const anciennete = p.date_creation_entreprise
  ? new Date().getFullYear() - parseInt(p.date_creation_entreprise.slice(0, 4), 10)
  : null;

const tierLabel =
  p.tier === "or" ? "Portrait Lauréat" :
  p.tier === "argent" ? "Portrait Vérifié" : "Portrait Recommandé";

const title = `${p.nom_entreprise} , ${metierNom} à ${p.ville} (${p.code_postal?.slice(0,2) || ""}) , L'Observatoire`;
const description = `Portrait ${tierLabel.toLowerCase()} de ${p.nom_entreprise}, ${metierNom.toLowerCase()} à ${p.ville}. Score de Confiance ${p.score_confiance}/10. ${p.description || "Données publiques Sirene INSEE."}`;
const url = `${siteConfig.url}/pro/${p.slug}/`;

const jsonLd = [
  jsonLdBreadcrumbs([
    { name: "Accueil", url: siteConfig.url },
    ...(metierSlug ? [{ name: metierNomPluriel, url: `${siteConfig.url}/${metierSlug}/` }] : []),
    ...(metierSlug && deptSlug ? [{ name: deptNom, url: `${siteConfig.url}/${metierSlug}/${deptSlug}/` }] : []),
    { name: p.nom_entreprise, url },
  ]),
  jsonLdLocalBusiness({
    name: p.nom_entreprise,
    url,
    description: p.description || `${metierNom} à ${p.ville}, inscrit au registre Sirene de l'INSEE.`,
    phone: p.telephone,
    address: {
      streetAddress: p.adresse,
      addressLocality: p.ville,
      postalCode: p.code_postal,
      addressCountry: "FR",
    },
    aggregateRating: p.score_confiance ? { ratingValue: p.score_confiance, ratingCount: 1 } : undefined,
  }),
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class={`portrait-page portrait-${p.tier}`}>
    <div class="container-wide portrait-head">
      <Breadcrumbs
        items={[
          { label: "Accueil", href: "/" },
          ...(metierSlug ? [{ label: metierNomPluriel, href: `/${metierSlug}/` }] : []),
          ...(metierSlug && deptSlug ? [{ label: deptNom, href: `/${metierSlug}/${deptSlug}/` }] : []),
          { label: p.nom_entreprise },
        ]}
      />

      <Masthead category={tierLabel.toUpperCase()} signature={`${p.ville || ""}${p.code_postal ? ` (${p.code_postal})` : ""}`} />

      <div class="portrait-head-row">
        <div>
          <h1 class="heading-display">{p.nom_entreprise}</h1>
          <p class="lead italic-fraunces" style="margin-top: 0.4rem;">
            {metierNom} à {p.ville}{deptCode ? ` (${deptCode})` : ""}{anciennete ? ` · ${anciennete} années d'activité` : ""}
          </p>
        </div>
        <div class="portrait-head-medaille">
          {p.tier !== "gratuit" && <Medaille tier={p.tier as "or" | "argent"} />}
        </div>
      </div>

      <ByLine
        authors={[{ name: "La rédaction" }]}
        date={`${siteConfig.editionMonth} ${siteConfig.editionYear}`}
        readingTime={p.tier === "or" ? 8 : 3}
      />

      <div class="portrait-stats">
        <div>
          <p class="stat-val" style="color: var(--or-deep);">{p.score_confiance ? p.score_confiance.toFixed(1) : "—"}</p>
          <p class="stat-lbl">Score de Confiance / 10</p>
        </div>
        {anciennete !== null && (
          <div>
            <p class="stat-val">{anciennete}</p>
            <p class="stat-lbl">Années d'activité</p>
          </div>
        )}
        {p.siret && (
          <div>
            <p class="stat-val mono" style="font-family: var(--font-mono); font-size: 1.15rem;">{p.siret.slice(0, 14)}</p>
            <p class="stat-lbl">SIRET vérifié INSEE</p>
          </div>
        )}
      </div>

      <div class="portrait-badges">
        {p.rge && <span class="pro-badge">RGE</span>}
        {p.qualibat && <span class="pro-badge">Qualibat</span>}
        {metierNaf && <span class="pro-badge pro-badge-soft">NAF {metierNaf}</span>}
        {p.siret && <span class="pro-badge pro-badge-soft">SIRET actif</span>}
      </div>
    </div>

    <div class="container-prose portrait-prose">
      {p.tier === "gratuit" && (
        <section class="prose">
          <p class="lead">
            Ce portrait est un <strong>Portrait Recommandé</strong> , listing automatique basé sur les données publiques Sirene de l'INSEE. Il n'a pas été complété par le professionnel.
          </p>

          <h2>Ce que nous savons</h2>
          <p>
            <strong>{p.nom_entreprise}</strong> est une entreprise active au registre Sirene sous le code NAF <strong>{metierNaf}</strong> ({metierNom.toLowerCase()}){p.date_creation_entreprise ? `, créée le ${p.date_creation_entreprise.split("-").reverse().join("/")}` : ""}. {p.adresse ? `Siège social : ${p.adresse}.` : ""}
          </p>

          <div class="portrait-enrichir">
            <h3>Vous êtes {p.nom_entreprise} ?</h3>
            <p>
              Candidater à un Portrait Vérifié ou Lauréat vous permet d'enrichir ce portrait avec photos de réalisations, description détaillée, lien vers votre site, numéro de téléphone direct, certifications affichées. Votre Score de Confiance et votre position dans le classement ne sont pas modifiés par l'abonnement : ils restent déterminés par notre grille éditoriale publique.
            </p>
            <a class="btn btn-observatoire magnetic" href="/candidater/">Candidater à un Portrait enrichi</a>
          </div>
        </section>
      )}

      {p.tier === "argent" && p.description && (
        <section class="prose">
          <DropCap>{p.description}</DropCap>
        </section>
      )}

      <section class="prose portrait-sources">
        <h2>Sources vérifiées</h2>
        <ul>
          {p.siret && <li><strong>INSEE Sirene</strong> , entreprise active, SIRET {p.siret}, NAF {metierNaf}{p.date_creation_entreprise ? `, créée ${p.date_creation_entreprise.slice(0, 4)}` : ""}</li>}
          {p.rge && <li><strong>France Rénov</strong> , certification RGE confirmée sur france-renov.gouv.fr</li>}
          {p.qualibat && <li><strong>Qualibat</strong> , qualification confirmée sur qualibat.com</li>}
          {p.site_web && <li><strong>Site web professionnel</strong> , <a href={p.site_web} rel="nofollow noopener">{p.site_web.replace(/^https?:\/\//, "").replace(/\/$/, "")}</a></li>}
        </ul>
        <p class="folio">
          Score de Confiance calculé à partir de 6 critères publics. Méthode complète sur <a href="/methode/">/methode/</a>.
        </p>
      </section>
    </div>

    <div class="container-wide portrait-foot">
      <hr class="hairline" />
      <p class="folio" style="text-align: center;">
        Portrait publié dans {siteConfig.name} , Édition N°{siteConfig.editionNumber} &middot; {siteConfig.editionMonth} {siteConfig.editionYear}
      </p>
      {metierSlug && deptSlug && (
        <p style="text-align: center; margin-top: 1rem;">
          <a class="btn-ghost" href={`/${metierSlug}/${deptSlug}/`}><span class="arrow">&larr;</span> Retour au classement {metierNomPluriel} {deptNom}</a>
        </p>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .portrait-page { padding: 2rem 0 4rem; }
  .portrait-head { max-width: 62rem; margin: 0 auto; padding: 0 clamp(1.25rem, 5vw, 5rem); }
  .portrait-head-row {
    display: grid; grid-template-columns: 1fr auto;
    gap: 1.5rem; align-items: start; margin-top: 0.5rem;
  }
  .portrait-head-medaille { padding-top: 0.4rem; }
  @media (max-width: 640px) { .portrait-head-row { grid-template-columns: 1fr; } }

  .portrait-stats {
    display: flex; gap: 2.2rem; flex-wrap: wrap;
    margin: 1.8rem 0 1.4rem; padding: 1.2rem 0;
    border-top: 1px solid rgba(26, 22, 20, 0.1);
    border-bottom: 1px solid rgba(26, 22, 20, 0.1);
  }
  .portrait-stats .stat-val {
    font-family: var(--font-display); font-size: 2rem; font-weight: 400;
    color: var(--ink); letter-spacing: -0.02em; margin: 0; line-height: 1;
  }
  .portrait-stats .stat-lbl {
    font-size: 0.72rem; color: var(--ink-muted);
    text-transform: uppercase; letter-spacing: 0.12em; margin: 0.25rem 0 0;
  }

  .portrait-badges { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }
  .pro-badge {
    font-family: var(--font-body); font-size: 0.7rem; font-weight: 600;
    padding: 0.22rem 0.55rem; border: 1px solid var(--or-deep);
    color: var(--or-deep); border-radius: 2px;
    letter-spacing: 0.08em; text-transform: uppercase;
  }
  .pro-badge-soft {
    color: var(--ink-muted); border-color: rgba(26, 22, 20, 0.18);
    font-weight: 500; text-transform: none; letter-spacing: 0.02em;
  }

  .portrait-prose { max-width: 44rem; padding: 2rem clamp(1.25rem, 5vw, 2rem) 1rem; }
  .portrait-enrichir {
    background: var(--paper-warm); padding: 1.6rem 1.8rem;
    border-left: 2px solid var(--or); border-radius: 0 2px 2px 0;
    margin: 2rem 0;
  }
  .portrait-enrichir h3 { margin: 0 0 0.6rem; font-size: 1.3rem; color: var(--ink); }
  .portrait-enrichir p { color: var(--ink-soft); }
  .portrait-sources { background: var(--paper-warm); padding: 1.6rem 1.8rem; margin-top: 2rem; border-radius: 2px; }

  .portrait-foot { max-width: 62rem; margin: 3rem auto 0; padding: 0 clamp(1.25rem, 5vw, 5rem); }

  .portrait-or .portrait-head { background: linear-gradient(180deg, var(--paper-warm) 0%, transparent 100%); padding-block: 1.6rem 1.4rem; border-radius: 2px; }
</style>

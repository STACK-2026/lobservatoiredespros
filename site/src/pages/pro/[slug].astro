---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Masthead from "../../components/Masthead.astro";
import ByLine from "../../components/ByLine.astro";
import Medaille from "../../components/Medaille.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ScoreCircle from "../../components/ScoreCircle.astro";
import InfoPill from "../../components/InfoPill.astro";
import GlossaireTerm from "../../components/GlossaireTerm.astro";
import SourceBadge from "../../components/SourceBadge.astro";
import EditorialVerdict from "../../components/EditorialVerdict.astro";
import UnknownsCard from "../../components/UnknownsCard.astro";
import QualificationsBlock from "../../components/QualificationsBlock.astro";
import { siteConfig } from "../../utils/config";
import { supabase } from "../../lib/supabase";
import { jsonLdBreadcrumbs, jsonLdLocalBusiness } from "../../utils/seo";

export async function getStaticPaths() {
  const { data } = await supabase
    .from("pros")
    .select("id, slug, nom_entreprise, siret, siren, code_postal, ville, adresse, date_creation_entreprise, score_confiance, tier, rge, qualibat, site_web, telephone, description, active")
    .eq("active", true)
    .not("slug", "is", null);
  const pros = data || [];
  return pros.map((p) => ({ params: { slug: p.slug }, props: { pro: p } }));
}

const { pro } = Astro.props;
const p = pro;

const { data: linkMetiers } = await supabase
  .from("pro_metiers")
  .select("metier_id, metiers!inner(slug, nom, nom_pluriel, code_naf)")
  .eq("pro_id", p.id)
  .limit(1);
const metierLink = linkMetiers?.[0]?.metiers;
const metierSlug = metierLink?.slug || null;
const metierNom = metierLink?.nom || "Professionnel";
const metierNomPluriel = metierLink?.nom_pluriel || "Professionnels";
const metierNaf = metierLink?.code_naf || "";

const { data: linkZones } = await supabase
  .from("pro_zones")
  .select("zone_id, zones!inner(slug, nom, code, type)")
  .eq("pro_id", p.id);
const deptZone = linkZones?.find((z: any) => z.zones?.type === "departement")?.zones;
const deptSlug = deptZone?.slug || "";
const deptNom = deptZone?.nom || p.ville || "";
const deptCode = deptZone?.code || (p.code_postal ? p.code_postal.slice(0, 2) : "");

const anciennete = p.date_creation_entreprise
  ? new Date().getFullYear() - parseInt(p.date_creation_entreprise.slice(0, 4), 10)
  : null;
const dateCreationFR = p.date_creation_entreprise
  ? new Date(p.date_creation_entreprise).toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })
  : null;

const tierLabel =
  p.tier === "or" ? "Portrait Lauréat" :
  p.tier === "argent" ? "Portrait Vérifié" : "Portrait Recommandé";

const title = `${p.nom_entreprise} , ${metierNom} à ${p.ville} (${deptCode}) , L'Observatoire`;
const description = `${tierLabel} de ${p.nom_entreprise}, ${metierNom.toLowerCase()} à ${p.ville}. Score de Confiance ${p.score_confiance}/10. Données publiques Sirene INSEE.`;
const url = `${siteConfig.url}/pro/${p.slug}/`;

// Verdict editorial inline pour enrichir le schema LocalBusiness.description
function generateVerdictText(): string {
  const parts: string[] = [];
  if (anciennete !== null && anciennete >= 25) parts.push(`Ancrage local solide (${anciennete} ans au registre)`);
  else if (anciennete !== null && anciennete >= 10) parts.push(`Entreprise artisanale établie (${anciennete} ans)`);
  else if (anciennete !== null && anciennete >= 3) parts.push(`Entreprise confirmée (${anciennete} ans)`);
  else if (anciennete !== null) parts.push("Entreprise récemment immatriculée");
  if (p.rge && p.qualibat) parts.push("doublement certifiée RGE et Qualibat");
  else if (p.rge) parts.push("certifiée RGE");
  else if (p.qualibat) parts.push("qualifiée Qualibat");
  else parts.push("non certifiée publiquement à ce jour");
  parts.push(p.siret ? "SIRET actif INSEE confirmé" : "SIRET à confirmer");
  return parts.join(", ") + ".";
}
const richDescription = generateVerdictText();

const jsonLd = [
  jsonLdBreadcrumbs([
    { name: "Accueil", url: siteConfig.url },
    ...(metierSlug ? [{ name: metierNomPluriel, url: `${siteConfig.url}/${metierSlug}/` }] : []),
    ...(metierSlug && deptSlug ? [{ name: deptNom, url: `${siteConfig.url}/${metierSlug}/${deptSlug}/` }] : []),
    { name: p.nom_entreprise, url },
  ]),
  jsonLdLocalBusiness({
    name: p.nom_entreprise,
    url,
    description: richDescription + ` ${metierNom} à ${p.ville} (${deptCode}). Inscrit au registre Sirene de l'INSEE, code NAF ${metierNaf}.`,
    phone: p.telephone,
    address: {
      streetAddress: p.adresse,
      addressLocality: p.ville,
      postalCode: p.code_postal,
      addressCountry: "FR",
    },
    aggregateRating: p.score_confiance ? { ratingValue: p.score_confiance, ratingCount: 1 } : undefined,
  }),
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class={`portrait-v2 portrait-${p.tier}`}>

    <!-- HEADER , breadcrumbs + masthead fin -->
    <header class="container-wide portrait-top">
      <Breadcrumbs
        items={[
          { label: "Accueil", href: "/" },
          ...(metierSlug ? [{ label: metierNomPluriel, href: `/${metierSlug}/` }] : []),
          ...(metierSlug && deptSlug ? [{ label: deptNom, href: `/${metierSlug}/${deptSlug}/` }] : []),
          { label: p.nom_entreprise },
        ]}
      />
      <Masthead category={tierLabel.toUpperCase()} signature={`${p.ville || ""}${p.code_postal ? ` · ${p.code_postal}` : ""}`} />
    </header>

    <!-- HERO , nom + score circle + medaille -->
    <section class="container-wide portrait-hero">
      <div class="ph-grid">
        <div class="ph-text blur-reveal">
          <h1 class="heading-display ph-name">{p.nom_entreprise}</h1>
          <p class="lead italic-fraunces ph-subtitle">
            {metierNom}{p.ville ? ` à ${p.ville}` : ""}{deptCode ? ` (${deptCode})` : ""}
            {anciennete && anciennete > 0 ? <> · <span class="ph-since">Depuis {p.date_creation_entreprise?.slice(0, 4)}</span></> : null}
          </p>
          {p.tier !== "gratuit" && <div class="ph-medaille"><Medaille tier={p.tier as "or" | "argent"} /></div>}

          <!-- Verdict editorial , voix redaction punchline -->
          <EditorialVerdict
            anciennete={anciennete ?? undefined}
            rge={p.rge}
            qualibat={p.qualibat}
            score={p.score_confiance || 0}
            nom={p.nom_entreprise}
            ville={p.ville || ""}
            siret={p.siret}
            tier={p.tier as "or" | "argent" | "gratuit"}
          />

          <!-- Pills d'identite , moderne, avec glossaire -->
          <div class="ph-pills stagger-children">
            <InfoPill
              variant="verified"
              label="SIRET actif INSEE"
              value={p.siret || "—"}
              glossaireSlug="siret"
              pulse={true}
            />
            <InfoPill
              variant="neutral"
              label="Code NAF"
              value={metierNaf || "—"}
              glossaireSlug="naf"
            />
            {p.rge && (
              <InfoPill variant="verified" label="RGE certifié" glossaireSlug="rge" pulse={true} />
            )}
            {p.qualibat && (
              <InfoPill variant="or" label="Qualibat" glossaireSlug="qualibat" />
            )}
            {anciennete && (
              <InfoPill variant="info" label="Ancienneté" value={`${anciennete} ans`} />
            )}
            {p.code_postal && (
              <InfoPill variant="neutral" label="Code postal" value={p.code_postal} />
            )}
          </div>
        </div>

        <aside class="ph-score-col scale-reveal" aria-label="Score de Confiance">
          <ScoreCircle score={p.score_confiance || 0} size={148} />
          <p class="ph-score-help">
            <GlossaireTerm slug="score-de-confiance">Score de Confiance</GlossaireTerm>
            <span class="ph-score-help-sub">calculé sur 6 critères publics</span>
          </p>
        </aside>
      </div>
    </section>

    <!-- FICHE IDENTITÉ , mockup visuel 2 cols -->
    <section class="container-wide portrait-identite">
      <div class="id-card fade-up">
        <header class="id-head">
          <span class="meta-label-or">Fiche d'identité éditoriale</span>
          <h2 class="id-title">Ce que notre rédaction a pu vérifier publiquement</h2>
        </header>

        <div class="id-grid">
          <dl class="id-dl">
            <dt>Raison sociale</dt>
            <dd>{p.nom_entreprise}</dd>

            <dt><GlossaireTerm slug="siret">SIRET</GlossaireTerm></dt>
            <dd class="mono">{p.siret || "—"}</dd>

            {p.siren && (
              <>
                <dt>SIREN (entreprise)</dt>
                <dd class="mono">{p.siren}</dd>
              </>
            )}

            <dt>Code <GlossaireTerm slug="naf">NAF</GlossaireTerm></dt>
            <dd class="mono">{metierNaf}</dd>

            <dt>Activité déclarée</dt>
            <dd>{metierNom}</dd>

            {dateCreationFR && (
              <>
                <dt>Date d'immatriculation</dt>
                <dd>{dateCreationFR}</dd>
              </>
            )}

            {p.adresse && (
              <>
                <dt>Adresse du siège</dt>
                <dd>{p.adresse}</dd>
              </>
            )}
          </dl>

          <div class="id-side">
            <div class="id-status">
              <span class="id-status-dot" aria-hidden="true"></span>
              <div>
                <p class="id-status-title">Entreprise active</p>
                <p class="id-status-sub">Dernier contrôle Sirene : {new Date().toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}</p>
              </div>
            </div>
            <div class="id-certifs">
              <p class="id-certifs-title">Certifications actives</p>
              <ul class="id-certifs-list">
                {p.rge ? (
                  <li class="certif-active certif-rge">
                    <span class="certif-check" aria-hidden="true">
                      <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8 L6.5 11.5 L13 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                    </span>
                    <div class="certif-body">
                      <strong><GlossaireTerm slug="rge">RGE</GlossaireTerm></strong>
                      <span class="certif-source">Certifié Reconnu Garant de l'Environnement</span>
                    </div>
                  </li>
                ) : null}
                {p.qualibat ? (
                  <li class="certif-active certif-qualibat">
                    <span class="certif-check" aria-hidden="true">
                      <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8 L6.5 11.5 L13 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                    </span>
                    <div class="certif-body">
                      <strong><GlossaireTerm slug="qualibat">Qualibat</GlossaireTerm></strong>
                      <span class="certif-source">Qualification BTP vérifiée</span>
                    </div>
                  </li>
                ) : null}
                {!p.rge && !p.qualibat && (
                  <li class="certif-empty">
                    <span class="certif-empty-icon" aria-hidden="true">
                      <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.3" stroke-dasharray="2 2" /></svg>
                    </span>
                    <div class="certif-body">
                      <span>Pas de certification publique recensée</span>
                      <span class="certif-source">Demandez les attestations au professionnel</span>
                    </div>
                  </li>
                )}
              </ul>
              <p class="certif-more">
                <a href="#antecedents">Voir les antécédents &rarr;</a>
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ANTÉCÉDENTS , placeholder pour v2 (historique Qualibat/RGE) -->
    <section id="antecedents" class="container-wide portrait-antecedents">
      <header class="ant-head fade-up">
        <span class="meta-label-or">Antécédents éditoriaux</span>
        <h2 class="ant-title">Historique des observations</h2>
      </header>
      <div class="ant-timeline fade-up">
        <div class="ant-item">
          <span class="ant-date folio">{new Date().toLocaleDateString("fr-FR", { month: "short", year: "numeric" })}</span>
          <div class="ant-body">
            <p class="ant-action"><strong>Première observation</strong> , entreprise référencée dans l'édition N°{siteConfig.editionNumber} de L'Observatoire. Données croisées avec Sirene INSEE et annuaire RGE France Rénov.</p>
          </div>
        </div>
        {dateCreationFR && (
          <div class="ant-item">
            <span class="ant-date folio">{p.date_creation_entreprise?.slice(0, 7)}</span>
            <div class="ant-body">
              <p class="ant-action">Immatriculation au Sirene sous SIRET <span class="mono">{p.siret}</span>, code NAF {metierNaf}.</p>
            </div>
          </div>
        )}
        <div class="ant-future">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.2" stroke-dasharray="2 2" />
            <path d="M8 4v4l2 2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
          </svg>
          <p>Les prochaines mises à jour (changement de statut Qualibat, nouvelle certification RGE, cessation d'activité) seront consignées ici.</p>
        </div>
      </div>
    </section>

    {p.tier === "gratuit" && (
      <!-- CTA CANDIDATER , card doré premium, pas ton-sur-ton -->
      <section class="container-editorial portrait-cta-enrichir">
        <div class="cta-card blur-reveal">
          <div class="cta-card-decor" aria-hidden="true">
            <svg viewBox="0 0 80 80" width="80" height="80" fill="none" stroke="currentColor" stroke-width="0.8">
              <circle cx="40" cy="40" r="32" opacity="0.4" />
              <circle cx="40" cy="40" r="26" opacity="0.3" />
              <circle cx="40" cy="40" r="20" opacity="0.2" />
              <g transform="translate(40 40)">
                <path d="M0 -14 L4 0 L-4 0 Z" fill="currentColor" />
                <path d="M0 14 L-4 0 L4 0 Z" fill="currentColor" opacity="0.4" />
              </g>
            </svg>
          </div>
          <div class="cta-card-body">
            <p class="meta-label-or">Vous dirigez {p.nom_entreprise} ?</p>
            <h2 class="cta-card-title">Enrichissez votre portrait éditorial.</h2>
            <p class="cta-card-lead">
              Portrait Vérifié : médaille Argent, photos de réalisations, lien site web, téléphone direct. Portrait Lauréat : portrait long format rédigé par notre rédaction après entretien. <strong>Votre Score de Confiance reste déterminé par notre grille éditoriale publique.</strong>
            </p>
            <div class="cta-card-actions">
              <a class="btn btn-primary magnetic" href="/candidater/">Candidater à un Portrait enrichi</a>
              <a class="btn btn-ghost" href="/methode/">Consulter la méthode <span class="arrow">&rarr;</span></a>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- QUALIFICATIONS RGE , cartographiees par ADEME -->
    <section class="container-wide portrait-qualifs">
      <QualificationsBlock proId={p.id} siret={p.siret} />
    </section>

    <!-- "CE QUE NOUS NE SAVONS PAS ENCORE" , transparence éditoriale -->
    <section class="container-wide portrait-unknowns">
      <UnknownsCard
        rge={p.rge}
        qualibat={p.qualibat}
        site_web={p.site_web}
        telephone={p.telephone}
        photos={[]}
        avis_moyen={null}
        adresse={p.adresse}
        description={p.description}
      />
    </section>

    <!-- SOURCES , cards compactes avec icons et glossaire inline -->
    <section class="container-wide portrait-sources-v2">
      <header class="src-head fade-up">
        <span class="meta-label-or">Sources officielles</span>
        <h2 class="src-title italic-fraunces">Où vérifier, point par point</h2>
      </header>
      <div class="src-grid stagger-children">
        <SourceBadge
          source="insee"
          info={p.siret ? `${p.siret}${p.date_creation_entreprise ? ` · ${p.date_creation_entreprise.slice(0, 4)}` : ""}` : "SIRET à confirmer"}
          verified={!!p.siret}
        />
        {p.rge && (
          <SourceBadge
            source="ademe"
            info="Certification RGE confirmée"
            verified={true}
          />
        )}
        {p.qualibat && (
          <SourceBadge
            source="qualibat"
            info="Qualification Qualibat confirmée"
            verified={true}
          />
        )}
        {p.site_web && (
          <SourceBadge
            source="google"
            info={p.site_web.replace(/^https?:\/\//, "").replace(/\/$/, "")}
            verified={true}
          />
        )}
      </div>
    </section>

    <!-- FOOTER EDITORIAL -->
    <footer class="container-wide portrait-foot-v2">
      <div class="hairline"></div>
      <div class="pf-row">
        <p class="folio">
          Édition N°{siteConfig.editionNumber} &middot; {siteConfig.editionMonth} {siteConfig.editionYear}
        </p>
        {metierSlug && deptSlug && (
          <a class="btn-ghost" href={`/${metierSlug}/${deptSlug}/`}><span class="arrow">&larr;</span> Classement {metierNomPluriel} {deptNom}</a>
        )}
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  .portrait-v2 { padding: 2rem 0 4rem; }
  .portrait-top { max-width: 72rem; margin: 0 auto; padding: 0 clamp(1.25rem, 5vw, 4rem); }

  /* ═══════ HERO ═══════ */
  .portrait-hero {
    max-width: 72rem;
    margin: 0 auto;
    padding: 1rem clamp(1.25rem, 5vw, 4rem) 1.5rem;
  }
  .ph-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2.5rem;
    align-items: start;
  }
  @media (max-width: 820px) {
    .ph-grid { grid-template-columns: 1fr; }
    .ph-score-col { justify-self: center; }
  }
  .ph-name {
    margin: 0 0 0.5rem;
    letter-spacing: -0.028em;
  }
  .ph-subtitle {
    font-size: 1.2rem;
    margin: 0;
    max-width: 34rem;
    color: var(--ink-soft);
  }
  .ph-since { color: var(--or-deep); font-style: italic; }
  .ph-medaille { margin: 1rem 0 0; }
  .ph-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1.4rem;
  }
  .ph-score-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    padding: 1rem 1.2rem 0.5rem;
  }
  .ph-score-help {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-muted);
    font-weight: 600;
    text-align: center;
    line-height: 1.5;
    margin: 0.4rem 0 0;
    max-width: 160px;
  }
  .ph-score-help-sub {
    display: block;
    text-transform: none;
    letter-spacing: 0;
    font-weight: 400;
    color: var(--ink-muted);
    font-size: 0.7rem;
    margin-top: 0.25rem;
    font-style: italic;
  }

  /* ═══════ FICHE IDENTITÉ ═══════ */
  .portrait-identite {
    max-width: 72rem;
    margin: 2.5rem auto 0;
    padding: 0 clamp(1.25rem, 5vw, 4rem);
  }
  .id-card {
    background: var(--paper);
    border: 1px solid rgba(26, 22, 20, 0.08);
    border-radius: 14px;
    padding: 2rem 2.2rem 2.2rem;
    box-shadow: 0 2px 0 rgba(26, 22, 20, 0.02), 0 20px 48px -28px rgba(26, 22, 20, 0.18);
    position: relative;
    overflow: hidden;
  }
  .id-card::before {
    content: "";
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, var(--or), var(--observatoire) 70%);
  }
  .id-head { margin-bottom: 1.4rem; }
  .id-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.4rem, 2.5vw, 1.75rem);
    color: var(--ink);
    margin: 0.4rem 0 0;
    letter-spacing: -0.018em;
  }

  .id-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 2rem;
    align-items: start;
  }
  @media (max-width: 820px) { .id-grid { grid-template-columns: 1fr; gap: 1.8rem; } }

  .id-dl {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.6rem 1.2rem;
    margin: 0;
  }
  .id-dl dt {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ink-muted);
    font-weight: 600;
    padding-top: 0.15rem;
    align-self: baseline;
    white-space: nowrap;
  }
  .id-dl dd {
    font-size: 0.95rem;
    color: var(--ink);
    margin: 0;
    line-height: 1.45;
  }
  .id-dl dd.mono {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    letter-spacing: 0.02em;
  }

  .id-side {
    display: grid;
    gap: 1.2rem;
    align-content: start;
  }
  .id-status {
    display: flex;
    align-items: flex-start;
    gap: 0.8rem;
    padding: 0.9rem 1rem;
    background: rgba(74, 145, 58, 0.06);
    border: 1px solid rgba(74, 145, 58, 0.25);
    border-radius: 8px;
  }
  .id-status-dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    background: #4A913A;
    border-radius: 50%;
    margin-top: 0.3rem;
    box-shadow: 0 0 0 0 rgba(74, 145, 58, 0.55);
    animation: pill-pulse 2.6s ease-out infinite;
    flex-shrink: 0;
  }
  .id-status-title { font-weight: 600; color: #3a6e30; margin: 0; font-size: 0.92rem; }
  .id-status-sub { font-size: 0.76rem; color: var(--ink-muted); margin: 0.15rem 0 0; }

  .id-certifs {
    padding: 1.1rem 1.2rem;
    background: var(--paper);
    border: 1px solid rgba(26, 22, 20, 0.08);
    border-radius: 10px;
  }
  .id-certifs-title {
    font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.16em;
    color: var(--ink-muted); font-weight: 600; margin: 0 0 0.8rem;
  }
  .id-certifs-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.6rem; }

  .id-certifs-list .certif-active {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.7rem;

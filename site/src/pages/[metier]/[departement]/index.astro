---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Masthead from "../../../components/Masthead.astro";
import ByLine from "../../../components/ByLine.astro";
import DropCap from "../../../components/DropCap.astro";
import ProCard from "../../../components/ProCard.astro";
import MethodologyBlock from "../../../components/MethodologyBlock.astro";
import EditorialHeader from "../../../components/EditorialHeader.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import { siteConfig } from "../../../utils/config";
import { supabase, getMetiers, getZones, getProsByMetierDept } from "../../../lib/supabase";
import { jsonLdBreadcrumbs, jsonLdRanking, jsonLdFAQ } from "../../../utils/seo";

export async function getStaticPaths() {
  // Build toutes les combinaisons metier x dept a partir de la DB
  const metiers = await getMetiers();
  const zones = await getZones("departement");
  const paths = [];
  for (const m of metiers) {
    for (const d of zones) {
      paths.push({
        params: { metier: m.slug, departement: d.slug },
        props: { metier: m, zone: d },
      });
    }
  }
  return paths;
}

const { metier: metierObj, zone: deptObj } = Astro.props;
const { metier, departement } = Astro.params as { metier: string; departement: string };

const pros = await getProsByMetierDept(metier, departement);

const titre = `Les meilleurs ${metierObj.nom_pluriel.toLowerCase()} dans le ${deptObj.nom} (${deptObj.code}) , Classement ${siteConfig.editionYear}`;
const description = `Classement editorial des ${metierObj.nom_pluriel.toLowerCase()} du ${deptObj.nom} (${deptObj.code}). ${pros.length} professionnels classes selon notre grille de six criteres objectifs. Edition N°${siteConfig.editionNumber} de L'Observatoire.`;
const url = `${siteConfig.url}/${metier}/${departement}/`;

const tarifsMetier: Record<string, { prestation: string; fourchette: string }[]> = {
  plombier: [
    { prestation: "Depannage urgence (hors piece)", fourchette: "70€ a 140€ HT" },
    { prestation: "Pose salle de bain complete", fourchette: "3 200€ a 8 500€ HT" },
    { prestation: "Remplacement chaudiere gaz", fourchette: "3 000€ a 6 500€ HT" },
    { prestation: "Detartrage ballon eau chaude", fourchette: "90€ a 180€ HT" },
  ],
  electricien: [
    { prestation: "Changement tableau electrique aux normes", fourchette: "1 200€ a 2 800€ HT" },
    { prestation: "Installation domotique basique", fourchette: "1 800€ a 4 500€ HT" },
    { prestation: "Prise ou interrupteur supplementaire", fourchette: "65€ a 130€ HT" },
    { prestation: "Renovation electrique T3", fourchette: "6 000€ a 14 000€ HT" },
  ],
  couvreur: [
    { prestation: "Nettoyage toiture + demoussage", fourchette: "12€ a 20€ / m²" },
    { prestation: "Refection toiture tuile", fourchette: "80€ a 140€ / m²" },
    { prestation: "Zinguerie (cheneaux)", fourchette: "55€ a 90€ / ml" },
    { prestation: "Depannage urgence fuite", fourchette: "180€ a 450€ forfait" },
  ],
  menuisier: [
    { prestation: "Fenetre bois sur mesure (pose comprise)", fourchette: "700€ a 1 800€ / unite" },
    { prestation: "Escalier bois droit", fourchette: "2 500€ a 6 000€ HT" },
    { prestation: "Parquet massif (pose)", fourchette: "65€ a 130€ / m²" },
    { prestation: "Porte interieure sur mesure", fourchette: "450€ a 1 200€ / unite" },
  ],
  isolation: [
    { prestation: "Isolation combles perdus soufflee", fourchette: "25€ a 55€ / m²" },
    { prestation: "ITE (facade)", fourchette: "110€ a 200€ / m²" },
    { prestation: "Isolation rampant", fourchette: "55€ a 110€ / m²" },
    { prestation: "Bilan energetique + devis MaPrimeRenov'", fourchette: "Gratuit a 350€" },
  ],
};
const tarifs = tarifsMetier[metier] || [];

const faq = [
  {
    question: `Comment trouver un bon ${metierObj.nom.toLowerCase()} dans le ${deptObj.nom} ?`,
    answer: `Le plus simple est de consulter notre classement sur cette page. Les ${pros.length} professionnels listes sont actifs au registre Sirene de l'INSEE dans le departement ${deptObj.nom}. Leur position dans le classement est calculee selon notre grille de six criteres publics : anciennete, certifications RGE/Qualibat, avis clients, SIRET actif, site web, photos de realisations. Vous pouvez consulter notre methode complete sur /methode/.`,
  },
  {
    question: `Combien coute un ${metierObj.nom.toLowerCase()} dans le ${deptObj.nom} ?`,
    answer: `Les tarifs dependent de la prestation. Nous publions en bas de cette page des fourchettes indicatives pour les prestations courantes. Exiger un devis ecrit, signe, detaille est obligatoire au-dessus de 150€ TTC.`,
  },
  {
    question: "Que signifie la mention RGE ?",
    answer: `Reconnu Garant de l'Environnement est une qualification attribuee par l'Etat via france-renov.gouv.fr. Elle est obligatoire pour beneficier des aides publiques MaPrimeRenov', TVA reduite 5.5%, CEE. Nous verifions cette mention sur la source officielle avant de l'afficher.`,
  },
  {
    question: `Comment contester la position d'un ${metierObj.nom.toLowerCase()} dans le classement ?`,
    answer: `Vous pouvez ecrire a ${siteConfig.legal.email} en precisant le professionnel concerne et les elements de contestation. Notre redaction reexamine les dossiers signales sous 15 jours ouvres.`,
  },
  {
    question: "La liste est-elle exhaustive ?",
    answer: `Cette selection regroupe tous les professionnels actifs au Sirene de l'INSEE dans le code NAF ${metierObj.code_naf || ""} du departement ${deptObj.nom} a la date du dernier recalcul. Les Scores de Confiance sont recalcules a chaque synchronisation mensuelle.`,
  },
];

const jsonLd = [
  jsonLdBreadcrumbs([
    { name: "Accueil", url: siteConfig.url },
    { name: metierObj.nom_pluriel, url: `${siteConfig.url}/${metier}/` },
    { name: deptObj.nom, url },
  ]),
  jsonLdRanking({
    name: `Classement ${metierObj.nom_pluriel} ${deptObj.nom}`,
    items: pros.slice(0, 50).map((p, i) => ({
      name: p.nom_entreprise,
      url: `${siteConfig.url}/pro/${p.slug}/`,
      position: i + 1,
    })),
  }),
  jsonLdFAQ(faq),
];

// Score max en pts Sirene sans enrichissement = 4.5, on affiche tel quel
// (le score montera avec enrichissements RGE + avis + site + photos)
const hasPros = pros.length > 0;
const anciennete = (p: any) => {
  if (!p.date_creation_entreprise) return null;
  const y = parseInt(p.date_creation_entreprise.slice(0, 4), 10);
  return new Date().getFullYear() - y;
};
---

<BaseLayout title={titre} description={description} jsonLd={jsonLd}>
  <article class="classement-page">
    <div class="container-wide classement-head">
      <Breadcrumbs
        items={[
          { label: "Accueil", href: "/" },
          { label: metierObj.nom_pluriel, href: `/${metier}/` },
          { label: deptObj.nom },
        ]}
      />
      <Masthead category={`CLASSEMENT ${siteConfig.editionYear}`} signature={`${deptObj.nom} (${deptObj.code})`} />

      <h1 class="heading-display classement-title">
        Les meilleurs <span class="italic-fraunces">{metierObj.nom_pluriel.toLowerCase()}</span> du {deptObj.nom} <span class="folio">({deptObj.code})</span>
      </h1>

      <ByLine
        authors={[{ name: "La rédaction" }]}
        date={`${siteConfig.editionMonth} ${siteConfig.editionYear}`}
        updated="Mise à jour mensuelle"
        readingTime={Math.max(3, Math.ceil(pros.length / 20))}
      />

      {hasPros && (
        <aside class="encart-methodologie speakable" data-speakable>
          <strong>En résumé.</strong> L'édition {siteConfig.editionNumber} de L'Observatoire retient <strong>{pros.length} {metierObj.nom_pluriel.toLowerCase()}</strong> actifs dans le {deptObj.nom}, classés selon leur <strong>Score de Confiance /10</strong> calculé sur six critères publics. Données sourcées du registre Sirene de l'INSEE (code NAF {metierObj.code_naf}).
        </aside>
      )}
    </div>

    <div class="container-wide classement-intro prose">
      <DropCap>
        Cartographier les {metierObj.nom_pluriel.toLowerCase()} du {deptObj.nom} est un exercice d'observation autant qu'une question de méthode. Nous croisons les données Sirene avec l'annuaire RGE de l'État, les fiches Qualibat, les profils Google Business, puis vérifions manuellement les sites web et portfolios. Ce qui suit est notre sélection éditoriale pour l'édition {siteConfig.editionNumber}, classée par Score de Confiance décroissant.
      </DropCap>
      <p>
        Chaque portrait indique le score obtenu, les certifications vérifiées, l'ancienneté de l'entreprise, ses spécialités principales, sa ville d'exercice. La mention <strong>Lauréat</strong> distingue les entreprises ayant fait l'objet d'un entretien approfondi. La mention <strong>Vérifié</strong> signale un dossier complété et validé par notre rédaction.
      </p>
    </div>

    {hasPros ? (
      <section class="container-wide classement-liste">
        <EditorialHeader category="LA SÉLECTION" title={`Classement ${siteConfig.editionMonth} ${siteConfig.editionYear}`} subtitle={`${pros.length} professionnels retenus par notre rédaction.`} />
        <div class="classement-top3-marker folio">
          <span>Position actuelle :</span>
          <span class="current-rank" data-rank-current>01</span>
        </div>
        <div class="pros-list">
          {pros.slice(0, 60).map((p, i) => (
            <div data-rank-item={i + 1}>
              <ProCard
                rank={i + 1}
                name={p.nom_entreprise}
                slug={p.slug}
                score={p.score_confiance || 0}
                tier={p.tier as "or" | "argent" | "gratuit"}
                ville={p.ville || ""}
                zoneIntervention={p.code_postal || ""}
                ancienneteAnnees={anciennete(p) || undefined}
                rge={p.rge}
                qualibat={p.qualibat}
                specialites={[]}
                resumeCourt={p.description || `Entreprise active au Sirene, code NAF ${metierObj.code_naf}. Score calculé sur données publiques.`}
              />
            </div>
          ))}
        </div>
        {pros.length > 60 && (
          <p class="classement-more folio">
            + {pros.length - 60} autres professionnels actifs dans le {deptObj.nom}, en cours d'examen éditorial pour les prochaines éditions.
          </p>
        )}
      </section>
    ) : (
      <section class="container-editorial classement-empty">
        <EditorialHeader category="EN COURS" title={`Classement ${metierObj.nom_pluriel} ${deptObj.nom} en cours de constitution`} align="center" />
        <p class="lead" style="text-align: center;">
          Notre rédaction constitue actuellement le classement des {metierObj.nom_pluriel.toLowerCase()} du {deptObj.nom}. Il sera publié dans la prochaine édition mensuelle.
        </p>
        <p style="text-align: center; margin-top: 2rem;">
          <a class="btn btn-outline" href="/selection/">Voir les classements disponibles</a>
        </p>
      </section>
    )}

    {hasPros && (
      <section class="container-wide">
        <MethodologyBlock
          appliedTo={`Pour ce classement, ${pros.length} candidats actifs Sirene ont été examinés dans le ${deptObj.nom}.`}
        />
      </section>
    )}

    {tarifs.length > 0 && (
      <section class="section-tarifs container-wide">
        <EditorialHeader category="GUIDE TARIFAIRE" title={`Combien coûte un ${metierObj.nom.toLowerCase()} dans le ${deptObj.nom} ?`} subtitle="Fourchettes indicatives observées dans le département. Hors TVA sauf mention contraire. Exiger un devis écrit reste obligatoire au-dessus de 150€ TTC." />
        <div class="tarifs-grid stagger-children">
          {tarifs.map((t) => (
            <div class="tarif-row card-editorial">
              <span class="meta-label">Prestation</span>
              <p class="tarif-nom italic-fraunces">{t.prestation}</p>
              <span class="meta-label-or">Fourchette</span>
              <p class="tarif-prix">{t.fourchette}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <section class="container-editorial section-faq-page">
      <EditorialHeader category="QUESTIONS FRÉQUENTES" title={`${metierObj.nom_pluriel} du ${deptObj.nom} , questions posées`} />
      <div class="faq-list stagger-children">
        {faq.map((q, i) => (
          <details class="faq-item">
            <summary>
              <span class="folio faq-num">{String(i+1).padStart(2, "0")}</span>
              <span class="faq-question">{q.question}</span>
              <span class="faq-toggle" aria-hidden="true">+</span>
            </summary>
            <div class="faq-answer"><p>{q.answer}</p></div>
          </details>
        ))}
      </div>
    </section>

    <section class="section-cta-page">
      <div class="container-editorial cta-page-inner">
        <p class="meta-label-or">Vous êtes professionnel ?</p>
        <h2 class="heading-display" style="font-size: clamp(1.8rem, 3.5vw, 2.8rem);">Rejoindre l'édition suivante.</h2>
        <p class="lead">
          Votre entreprise exerce dans le {deptObj.nom} et vous estimez qu'elle mérite une position supérieure ? Soumettez votre candidature Vérifié ou Lauréat. L'examen est gratuit. L'abonnement optionnel.
        </p>
        <a href="/candidater/" class="btn btn-primary magnetic">Candidater à l'édition suivante</a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .classement-page { padding: 2rem 0 4rem; }
  .classement-head { max-width: 62rem; margin: 0 auto; padding-block: 0 1.5rem; }
  .classement-title { max-width: 22ch; margin: 0.6rem 0 1rem; }
  .classement-intro { max-width: 46rem; margin: 2rem auto 3rem; }
  .speakable { margin: 1.5rem 0 0; }

  .classement-liste { max-width: 62rem; margin: 2rem auto 3rem; }
  .classement-top3-marker {
    display: flex; align-items: baseline; gap: 0.7rem;
    margin: 0 0 1rem; padding-bottom: 0.6rem;
    border-bottom: 1px solid rgba(26, 22, 20, 0.1);
  }
  .current-rank {
    font-family: var(--font-display); font-size: 1.3rem; font-weight: 500;
    color: var(--or-deep); font-variant-numeric: tabular-nums;
  }
  .pros-list { display: grid; gap: 1.1rem; }
  .classement-more {
    margin-top: 2rem; padding: 1rem 1.2rem;
    background: var(--paper-warm); border-left: 2px solid var(--or);
    border-radius: 0 2px 2px 0; color: var(--ink-soft);
    max-width: 52rem;
  }
  .classement-empty { padding: 4rem 0; text-align: center; }

  .section-tarifs { padding: 3rem 0; max-width: 62rem; margin: 0 auto; }
  .tarifs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1.6rem; }
  @media (max-width: 640px) { .tarifs-grid { grid-template-columns: 1fr; } }
  .tarif-row { padding: 1.2rem 1.4rem 1.3rem; display: grid; gap: 0.25rem; }
  .tarif-nom { font-size: 1.1rem; color: var(--ink); margin: 0.15rem 0; font-weight: 400; }
  .tarif-prix { font-family: var(--font-display); font-size: 1.15rem; color: var(--or-deep); margin: 0; font-weight: 400; }

  .section-faq-page { padding: 2rem 0 3rem; }
  .faq-list { display: grid; gap: 0.4rem; margin-top: 1.6rem; }
  .faq-item { background: var(--paper); border: 1px solid rgba(26, 22, 20, 0.08); border-radius: 2px; }
  .faq-item[open] { border-color: rgba(184, 134, 61, 0.4); }
  .faq-item summary {
    display: grid; grid-template-columns: auto 1fr auto;
    gap: 1rem; align-items: center; padding: 1.1rem 1.4rem;
    cursor: pointer; list-style: none;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-num { color: var(--or-deep); }
  .faq-question {
    font-family: var(--font-display); font-size: 1.1rem; font-weight: 500;
    color: var(--ink); letter-spacing: -0.012em;
  }
  .faq-toggle { font-size: 1.5rem; color: var(--or-deep); transition: transform 240ms var(--ease-out-quart); }
  .faq-item[open] .faq-toggle { transform: rotate(45deg); }
  .faq-answer { padding: 0 1.4rem 1.3rem 3.4rem; color: var(--ink-soft); font-size: 0.96rem; }
  .faq-answer p { margin: 0; }

  .section-cta-page { padding: 4rem 0; background: var(--paper-warm); text-align: center; margin-top: 3rem; }
  .cta-page-inner { display: grid; gap: 0.8rem; place-items: center; }
</style>

---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Masthead from "../../../components/Masthead.astro";
import ByLine from "../../../components/ByLine.astro";
import ProCard from "../../../components/ProCard.astro";
import ProCompactRow from "../../../components/ProCompactRow.astro";
import ClassementMap from "../../../components/ClassementMap.astro";
import MethodologyBlock from "../../../components/MethodologyBlock.astro";
import EditorialHeader from "../../../components/EditorialHeader.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import InkBleedDivider from "../../../components/InkBleedDivider.astro";
import SummaryHero from "../../../components/SummaryHero.astro";
import GlossaireTerm from "../../../components/GlossaireTerm.astro";
import InfoPill from "../../../components/InfoPill.astro";
import SpeakableTLDR from "../../../components/SpeakableTLDR.astro";
import DropCap from "../../../components/DropCap.astro";
import { siteConfig } from "../../../utils/config";
import { getMetiers, getZones, getProsByMetierDept, getMetierDeptCombos } from "../../../lib/supabase";
import { jsonLdBreadcrumbs, jsonLdRanking, jsonLdFAQ } from "../../../utils/seo";
import { deptGrammar } from "../../../utils/grammar";

export async function getStaticPaths() {
  const metiers = await getMetiers();
  const zones = await getZones("departement");
  const combos = await getMetierDeptCombos();
  const paths = [];
  for (const m of metiers) {
    for (const d of zones) {
      // Skip les combos sans pros actifs : évite thin content + index bloat
      if (!combos.has(`${m.slug}:${d.slug}`)) continue;
      paths.push({
        params: { metier: m.slug, departement: d.slug },
        props: { metier: m, zone: d },
      });
    }
  }
  return paths;
}

const { metier: metierObj, zone: deptObj } = Astro.props;
const { metier, departement } = Astro.params as { metier: string; departement: string };

const pros = await getProsByMetierDept(metier, departement);
const podium = pros.slice(0, 3);
const topPros = pros.slice(3, 15);
const restPros = pros.slice(15, 60);

// Grammaire du nom de departement (ex. Yonne → "de l'Yonne", "dans l'Yonne")
const dg = deptGrammar(deptObj.nom);

const titre = `Les meilleurs ${metierObj.nom_pluriel.toLowerCase()} ${dg.in} (${deptObj.code}) , Classement ${siteConfig.editionYear}`;
const description = `Classement éditorial des ${metierObj.nom_pluriel.toLowerCase()} ${dg.of} (${deptObj.code}). ${pros.length} professionnels classés selon notre grille de six critères objectifs. Édition N°${siteConfig.editionNumber} de L'Observatoire.`;
const url = `${siteConfig.url}/${metier}/${departement}/`;

const tarifsMetier: Record<string, { prestation: string; fourchette: string; unit?: string }[]> = {
  plombier: [
    { prestation: "Dépannage urgence", fourchette: "70 à 140", unit: "€ HT" },
    { prestation: "Pose salle de bain complète", fourchette: "3 200 à 8 500", unit: "€ HT" },
    { prestation: "Remplacement chaudière gaz", fourchette: "3 000 à 6 500", unit: "€ HT" },
    { prestation: "Détartrage ballon d'eau chaude", fourchette: "90 à 180", unit: "€ HT" },
  ],
  electricien: [
    { prestation: "Tableau électrique aux normes", fourchette: "1 200 à 2 800", unit: "€ HT" },
    { prestation: "Installation domotique basique", fourchette: "1 800 à 4 500", unit: "€ HT" },
    { prestation: "Prise / interrupteur supplémentaire", fourchette: "65 à 130", unit: "€ HT" },
    { prestation: "Rénovation électrique T3", fourchette: "6 000 à 14 000", unit: "€ HT" },
  ],
  couvreur: [
    { prestation: "Nettoyage toiture + démoussage", fourchette: "12 à 20", unit: "€ / m²" },
    { prestation: "Réfection toiture tuile", fourchette: "80 à 140", unit: "€ / m²" },
    { prestation: "Zinguerie (chéneaux)", fourchette: "55 à 90", unit: "€ / ml" },
    { prestation: "Dépannage urgence fuite", fourchette: "180 à 450", unit: "€ forfait" },
  ],
  menuisier: [
    { prestation: "Fenêtre bois sur mesure posée", fourchette: "700 à 1 800", unit: "€ / unité" },
    { prestation: "Escalier bois droit", fourchette: "2 500 à 6 000", unit: "€ HT" },
    { prestation: "Parquet massif posé", fourchette: "65 à 130", unit: "€ / m²" },
    { prestation: "Porte intérieure sur mesure", fourchette: "450 à 1 200", unit: "€ / unité" },
  ],
  isolation: [
    { prestation: "Combles perdus soufflée", fourchette: "25 à 55", unit: "€ / m²" },
    { prestation: "ITE (façade)", fourchette: "110 à 200", unit: "€ / m²" },
    { prestation: "Isolation rampant", fourchette: "55 à 110", unit: "€ / m²" },
    { prestation: "Bilan énergétique MaPrimeRénov'", fourchette: "Gratuit à 350", unit: "€" },
  ],
};
const tarifs = tarifsMetier[metier] || [];

const faq = [
  {
    question: `Comment trouver un bon ${metierObj.nom.toLowerCase()} ${dg.in} ?`,
    answer: `Le plus simple est de consulter notre classement sur cette page. Les ${pros.length} professionnels listés sont actifs au registre Sirene de l'INSEE dans le département ${deptObj.nom}. Leur position dans le classement est calculée selon notre grille de six critères publics : ancienneté, certifications RGE/Qualibat, avis clients, SIRET actif, site web, photos de réalisations. Vous pouvez consulter la méthode complète en lien direct depuis le menu.`,
  },
  {
    question: `Combien coûte un ${metierObj.nom.toLowerCase()} ${dg.in} ?`,
    answer: `Les tarifs dépendent de la prestation. Nous publions en bas de cette page des fourchettes indicatives pour les prestations courantes. Exiger un devis écrit, signé, détaillé est obligatoire au-dessus de 150€ TTC.`,
  },
  {
    question: "Que signifie la mention RGE ?",
    answer: `Reconnu Garant de l'Environnement est une qualification attribuée par l'État via france-renov.gouv.fr. Elle est obligatoire pour bénéficier des aides publiques MaPrimeRénov', TVA réduite 5.5%, CEE. Nous vérifions cette mention sur la source officielle avant de l'afficher.`,
  },
  {
    question: `Comment contester la position d'un ${metierObj.nom.toLowerCase()} dans ce classement ?`,
    answer: `Vous pouvez écrire à ${siteConfig.legal.email} en précisant le professionnel concerné et les éléments de contestation. Notre rédaction réexamine les dossiers signalés sous 15 jours ouvrés.`,
  },
  {
    question: "La liste est-elle exhaustive ?",
    answer: `Cette sélection regroupe tous les professionnels actifs au Sirene de l'INSEE dans le code NAF ${metierObj.code_naf || ""} du département ${deptObj.nom === "Paris" ? "de Paris" : deptObj.nom} à la date du dernier recalcul. Les Scores de Confiance sont recalculés à chaque synchronisation mensuelle.`,
  },
];

const jsonLd = [
  jsonLdBreadcrumbs([
    { name: "Accueil", url: siteConfig.url },
    { name: metierObj.nom_pluriel, url: `${siteConfig.url}/${metier}/` },
    { name: deptObj.nom, url },
  ]),
  jsonLdRanking({
    name: `Classement ${metierObj.nom_pluriel} ${dg.the}`,
    items: pros.slice(0, 50).map((p, i) => ({
      name: p.nom_entreprise,
      url: `${siteConfig.url}/pro/${p.slug}/`,
      position: i + 1,
    })),
  }),
  jsonLdFAQ(faq),
];

const anciennete = (p: any) => {
  if (!p.date_creation_entreprise) return null;
  const y = parseInt(p.date_creation_entreprise.slice(0, 4), 10);
  return new Date().getFullYear() - y;
};
const hasPros = pros.length > 0;

// Verdict editorial pour le Top 3 : une phrase qui differencie chaque pro
// de ses concurrents. Signee "La redaction". Sert a eviter l'effet
// "annuaire uniforme" quand 2 pros partagent le meme score.
function generateTopVerdict(p: any, rank: number, all: any[], metierLower: string): string {
  const age = anciennete(p) || 0;
  const certifs = [p.rge ? "RGE" : null, p.qualibat ? "Qualibat" : null].filter(Boolean);
  const topAge = Math.max(0, ...all.slice(0, 5).map((x) => anciennete(x) || 0));
  const isOldest = age === topAge && age > 0;
  const hasBothCertifs = p.rge && p.qualibat;

  if (rank === 1) {
    if (hasBothCertifs && age >= 20) {
      return `Ouvre l'édition pour la densité rare de ses deux qualifications actives et ${age} ans d'ancrage Sirene continu.`;
    }
    if (hasBothCertifs) {
      return `Ouvre l'édition pour sa double qualification ${certifs.join(" et ")}, vérifiées sur sources officielles.`;
    }
    if (age >= 25) {
      return `Ouvre l'édition pour ${age} ans d'activité Sirene continue, la plus longue du département sur ce métier.`;
    }
    if (p.rge) {
      return `Ouvre l'édition pour une certification RGE active et ${age || "plusieurs"} années d'activité vérifiable.`;
    }
    return `Ouvre l'édition pour la solidité de son dossier Sirene et son ancrage local.`;
  }
  if (rank === 2) {
    if (hasBothCertifs) {
      return `Tient tête au premier grâce à sa double certification ${certifs.join(" + ")} et une régularité sans faille au registre Sirene.`;
    }
    if (p.rge && age >= 15) {
      return `Appuie sa deuxième place sur ${age} ans de continuité et une mention RGE à jour.`;
    }
    if (isOldest) {
      return `Deuxième par le score, mais le plus ancien sur ce métier dans le département.`;
    }
    return `Tient la seconde place par la cohérence de son dossier public et de sa couverture éditoriale.`;
  }
  if (rank === 3) {
    if (certifs.length) {
      return `Ferme le podium pour son positionnement spécialisé et la mention ${certifs.join(", ")} que nous avons pu vérifier.`;
    }
    if (age >= 15) {
      return `Ferme le podium pour ${age} ans d'ancrage territorial dans le ${metierLower}.`;
    }
    return `Ferme le podium pour la qualité de son assise Sirene et sa visibilité locale.`;
  }
  return "";
}
---

<BaseLayout title={titre} description={description} jsonLd={jsonLd}>
  <article class="classement-v2">

    <!-- HEADER -->
    <header class="container-wide cl-top">
      <Breadcrumbs
        items={[
          { label: "Accueil", href: "/" },
          { label: metierObj.nom_pluriel, href: `/${metier}/` },
          { label: deptObj.nom },
        ]}
      />
      <Masthead category={`CLASSEMENT ${siteConfig.editionYear}`} signature={`${deptObj.nom} · ${deptObj.code}`} />

      <h1 class="heading-display cl-title blur-reveal">
        Les meilleurs <span class="italic-fraunces">{metierObj.nom_pluriel.toLowerCase()}</span> {dg.of}
      </h1>

      <ByLine
        authors={[{ name: "La rédaction" }]}
        date={`${siteConfig.editionMonth} ${siteConfig.editionYear}`}
        updated="mensuelle"
        readingTime={Math.max(3, Math.ceil(pros.length / 20))}
      />

      {hasPros && (
        <SpeakableTLDR label="En résumé">
          <p>
            <strong>{pros.length} {metierObj.nom_pluriel.toLowerCase()}</strong> actifs au registre
            Sirene {dg.in} ({deptObj.code}), classés par Score de Confiance sur six
            critères publics, dont {pros.filter((p: any) => p.rge).length} titulaires d'une certification
            <GlossaireTerm slug="rge">RGE</GlossaireTerm>. Données vérifiées sur INSEE, ADEME et
            Qualibat, recalcul mensuel.
          </p>
        </SpeakableTLDR>
      )}
    </header>

    <!-- SUMMARY HERO (visual impactant) -->
    {hasPros && (
      <section class="container-wide">
        <SummaryHero
          count={pros.length}
          unit={metierObj.nom_pluriel.toLowerCase()}
          zone={`${deptObj.nom} (${deptObj.code})`}
          naf={metierObj.code_naf}
          source="Sirene INSEE · France Rénov · Qualibat"
        />
      </section>
    )}

    <!-- METRICS BAR , pills contextualisees sous le hero -->
    {hasPros && (
      <section class="container-wide cl-metrics">
        <div class="cm-pills stagger-children">
          <InfoPill variant="verified" label="Actifs INSEE" value={`${pros.length}`} glossaireSlug="sirene" />
          <InfoPill variant="neutral" label="Code NAF" value={metierObj.code_naf || ""} glossaireSlug="naf" />
          <InfoPill variant="or" label="Avec RGE" value={`${pros.filter((p: any) => p.rge).length}`} glossaireSlug="rge" />
          <InfoPill variant="or" label="Qualibat" value={`${pros.filter((p: any) => p.qualibat).length}`} glossaireSlug="qualibat" />
          <InfoPill variant="info" label="Édition" value={`N°${siteConfig.editionNumber}`} />
        </div>
      </section>
    )}

    {hasPros ? (
      <>
        <!-- PODIUM , 3 cards pleine largeur avec traitement editorial renforce -->
        {podium.length > 0 && (
          <section class="container-wide cl-podium-section">
            <EditorialHeader
              category="LE PODIUM ÉDITORIAL"
              title={`Les trois entreprises que nous retenons en tête`}
              subtitle={`Parmi ${pros.length} ${metierObj.nom_pluriel.toLowerCase()} actifs au Sirene ${dg.in}, trois dossiers dominent l'édition ${siteConfig.editionMonth} ${siteConfig.editionYear}.`}
              align="center"
            />

            <div class="cl-podium-list stagger-children">
              {podium.map((p, i) => (
                <div data-rank-item={i + 1} class="cl-podium-item cl-podium-rank-{i + 1}">
                  <ProCard
                    rank={i + 1}
                    name={p.nom_entreprise}
                    slug={p.slug}
                    score={p.score_confiance || 0}
                    tier={p.tier as "or" | "argent" | "gratuit"}
                    ville={p.ville || ""}
                    zoneIntervention={p.code_postal || ""}
                    ancienneteAnnees={anciennete(p) || undefined}
                    rge={p.rge}
                    qualibat={p.qualibat}
                    specialites={[]}
                    resumeCourt={p.description || `Entreprise active au Sirene, NAF ${metierObj.code_naf}.`}
                    verdictEditorial={generateTopVerdict(p, i + 1, pros.slice(0, 5), metierObj.nom.toLowerCase())}
                  />
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- CARTE DU CLASSEMENT , tous les pros geolocalises -->
        {pros.filter((p: any) => p.lat && p.lng).length >= 3 && (
          <ClassementMap
            pros={pros.slice(0, 60).map((p: any, i: number) => ({
              id: p.id,
              slug: p.slug,
              nom_entreprise: p.nom_entreprise,
              ville: p.ville,
              code_postal: p.code_postal,
              score_confiance: p.score_confiance || 0,
              tier: p.tier,
              niveau_confiance: p.niveau_confiance,
              rge: p.rge,
              qualibat: p.qualibat,
              lat: p.lat,
              lng: p.lng,
            }))}
            metier={metierObj.nom.toLowerCase()}
            dept={deptObj.nom}
            deptCode={deptObj.code}
          />
        )}

        <!-- TOP 4-15 , cards standards en grille serree -->
        {topPros.length > 0 && (
          <section class="container-wide cl-top-section">
            <EditorialHeader
              category={`POSITIONS 04 À ${3 + topPros.length}`}
              title="La suite du classement"
              subtitle="Douze dossiers qui forment le second rang de l'édition."
            />

            <div class="cl-sticky-rank folio">
              <span>Position visible :</span>
              <span class="cl-current-rank" data-rank-current>04</span>
            </div>

            <div class="cl-pros-list">
              {topPros.map((p, i) => (
                <div data-rank-item={i + 4} class="cl-pros-item">
                  <ProCard
                    rank={i + 4}
                    name={p.nom_entreprise}
                    slug={p.slug}
                    score={p.score_confiance || 0}
                    tier={p.tier as "or" | "argent" | "gratuit"}
                    ville={p.ville || ""}
                    zoneIntervention={p.code_postal || ""}
                    ancienneteAnnees={anciennete(p) || undefined}
                    rge={p.rge}
                    qualibat={p.qualibat}
                    specialites={[]}
                    resumeCourt={p.description || `Entreprise active au Sirene, NAF ${metierObj.code_naf}.`}
                  />
                </div>
              ))}
            </div>
          </section>
        )}

        <InkBleedDivider variant="ornament" />

        <!-- INTRO ÉDITORIALE (deplacée apres le top , l'user l'a vu) -->
        <section class="container-wide cl-intro">
          <div class="cl-intro-inner prose">
            <DropCap>
              Cartographier les {metierObj.nom_pluriel.toLowerCase()} {dg.of} est un exercice d'observation autant qu'une question de méthode. Nous croisons les données <GlossaireTerm slug="sirene">Sirene</GlossaireTerm> avec l'annuaire <GlossaireTerm slug="rge">RGE</GlossaireTerm> de l'État, les fiches <GlossaireTerm slug="qualibat">Qualibat</GlossaireTerm>, les profils Google Business, puis vérifions manuellement les sites web et portfolios.
            </DropCap>
            <p>
              Le <GlossaireTerm slug="score-de-confiance">Score de Confiance /10</GlossaireTerm> visible sur chaque portrait ci-dessus additionne six critères publics et auditables. La mention <strong>Lauréat</strong> distingue les entreprises ayant fait l'objet d'un entretien approfondi. La mention <strong>Vérifié</strong> signalé un dossier complété et validé par notre rédaction.
            </p>
          </div>
        </section>

        {restPros.length > 0 && (
          <section class="container-wide cl-rest">
            <EditorialHeader
              category={`POSITIONS 16 À ${15 + restPros.length}`}
              title="Palmarès étendu"
              subtitle="Dossiers retenus à ce jour, format palmarès dense. Chaque nom ouvre le portrait complet."
            />
            <div class="cl-palmares-head folio">
              <span>Rang</span>
              <span>Entreprise</span>
              <span>Certifs</span>
              <span>Score</span>
              <span aria-hidden="true"></span>
            </div>
            <div class="cl-palmares-list stagger-children">
              {restPros.map((p, i) => (
                <ProCompactRow
                  rank={i + 16}
                  name={p.nom_entreprise}
                  slug={p.slug}
                  score={p.score_confiance || 0}
                  tier={p.tier as "or" | "argent" | "gratuit"}
                  ville={p.ville || ""}
                  ancienneteAnnees={anciennete(p) || undefined}
                  rge={p.rge}
                  qualibat={p.qualibat}
                />
              ))}
            </div>
          </section>
        )}

        {pros.length > 60 && (
          <p class="cl-more folio container-wide">
            + {pros.length - 60} autres professionnels actifs {dg.in}, en cours d'examen éditorial pour les prochaines éditions.
          </p>
        )}

        <InkBleedDivider variant="hairline" />

        <!-- MÉTHODE -->
        <section class="container-wide">
          <MethodologyBlock
            appliedTo={`Pour ce classement, ${pros.length} candidats actifs Sirene ont été examinés ${dg.in}.`}
          />
        </section>
      </>
    ) : (
      <section class="container-editorial cl-empty">
        <EditorialHeader
          category="EN COURS"
          title={`Classement ${metierObj.nom_pluriel} ${dg.of} en cours de constitution`}
          align="center"
        />
        <p class="lead" style="text-align: center;">
          Notre rédaction constitué actuellement le classement des {metierObj.nom_pluriel.toLowerCase()} {dg.of}. Il sera publié dans la prochaine édition mensuelle.
        </p>
        <p style="text-align: center; margin-top: 2rem;">
          <a class="btn btn-outline" href="/selection/">Voir les classements disponibles</a>
        </p>
      </section>
    )}

    {tarifs.length > 0 && (
      <!-- GUIDE TARIFAIRE , mockup moderne -->
      <section class="cl-tarifs">
        <div class="container-wide">
          <EditorialHeader
            category="GUIDE TARIFAIRE LOCAL"
            title={`Combien coûte un ${metierObj.nom.toLowerCase()} ${dg.in} ?`}
            subtitle="Fourchettes indicatives observées dans le département. Hors TVA sauf mention contraire."
          />
          <div class="cl-tarifs-grid stagger-children">
            {tarifs.map((t) => (
              <div class="tarif-v2 card-editorial">
                <span class="tarif-v2-meta meta-label">Prestation</span>
                <p class="tarif-v2-prestation">{t.prestation}</p>
                <div class="tarif-v2-price">
                  <span class="tarif-v2-range">{t.fourchette}</span>
                  <span class="tarif-v2-unit">{t.unit || "€"}</span>
                </div>
                <div class="tarif-v2-bar" aria-hidden="true">
                  <span class="tarif-v2-bar-fill"></span>
                </div>
              </div>
            ))}
          </div>
          <aside class="cl-tarifs-warning">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.2" />
              <path d="M10 6v5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
              <circle cx="10" cy="13.5" r="0.7" fill="currentColor" />
            </svg>
            <p>
              Un <GlossaireTerm slug="devis">devis</GlossaireTerm> écrit, daté, signé est <strong>obligatoire</strong> au-dessus de 150€ TTC. Vérifier la mention de l'<GlossaireTerm slug="decennale">assurance décennale</GlossaireTerm> sur le devis.
            </p>
          </aside>
        </div>
      </section>
    )}

    <!-- FAQ (reste tel quel, deja bien) -->
    <section class="container-editorial cl-faq">
      <EditorialHeader category="QUESTIONS FRÉQUENTES" title={`${metierObj.nom_pluriel} ${dg.of} , questions posées`} />
      <div class="faq-list stagger-children">
        {faq.map((q, i) => (
          <details class="faq-item">
            <summary>
              <span class="folio faq-num">{String(i+1).padStart(2, "0")}</span>
              <span class="faq-question">{q.question}</span>
              <span class="faq-toggle" aria-hidden="true">+</span>
            </summary>
            <div class="faq-answer"><p>{q.answer}</p></div>
          </details>
        ))}
      </div>
    </section>

    <!-- CTA PRO -->
    <section class="cl-cta-pro">
      <div class="container-editorial cl-cta-inner blur-reveal">
        <span class="meta-label-or">Vous êtes professionnel ?</span>
        <h2 class="heading-display cl-cta-title">Rejoindre l'édition suivante.</h2>
        <p class="lead">
          Votre entreprise exerce {dg.in} et vous estimez qu'elle mérite une position supérieure ? Soumettez votre candidature Vérifié ou Lauréat. L'examen est gratuit. L'abonnement optionnel.
        </p>
        <a href="/candidater/" class="btn btn-primary magnetic">Candidater à l'édition suivante</a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .classement-v2 { padding: 2rem 0 4rem; }
  .cl-top {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 5vw, 4rem) 0;
  }
  .cl-title {
    max-width: 20ch;
    margin: 0.6rem 0 1rem;
  }

  /* Metrics pills , centrees */
  .cl-metrics {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 5vw, 4rem) 0.5rem;
  }
  .cm-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    justify-content: center;
    max-width: 56rem;
    margin: 0 auto;
  }

  /* Podium , traitement visuel renforce pour les 3 premieres */

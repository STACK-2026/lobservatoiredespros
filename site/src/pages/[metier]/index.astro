---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Masthead from "../../components/Masthead.astro";
import EditorialHeader from "../../components/EditorialHeader.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ProCard from "../../components/ProCard.astro";
import MethodologyBlock from "../../components/MethodologyBlock.astro";
import { siteConfig } from "../../utils/config";
import {
  getMetiers,
  getZones,
  getMetierBySlug,
  getProsByMetier,
  getMetierDeptCombos,
} from "../../lib/supabase";
import { jsonLdBreadcrumbs } from "../../utils/seo";

export async function getStaticPaths() {
  const metiers = await getMetiers();
  const combos = await getMetierDeptCombos();
  const metiersWithPros = new Set<string>();
  for (const c of combos) metiersWithPros.add(c.split(":")[0]);
  return metiers
    .filter((m) => metiersWithPros.has(m.slug))
    .map((m) => ({ params: { metier: m.slug } }));
}

const { metier } = Astro.params as { metier: string };
const metierObj = await getMetierBySlug(metier);
if (!metierObj) {
  return new Response("Métier introuvable", { status: 404 });
}
const nomPluriel = metierObj.nom_pluriel;
const nom = metierObj.nom;

// Top pros nationaux (toutes zones) pour ce métier
const allPros = await getProsByMetier(metier);
const top10 = allPros.slice(0, 10);

// Départements où ce métier a au moins un pro actif (via combos)
const combos = await getMetierDeptCombos();
const zones = await getZones("departement");
const zoneBySlug = new Map(zones.map((z) => [z.slug, z]));
const deptSlugsPourCeMetier = Array.from(combos)
  .filter((c) => c.startsWith(`${metier}:`))
  .map((c) => c.split(":")[1])
  .filter((slug) => zoneBySlug.has(slug));
const depts = deptSlugsPourCeMetier
  .map((slug) => zoneBySlug.get(slug)!)
  .sort((a, b) => a.nom.localeCompare(b.nom, "fr"));

const title = `Meilleurs ${nomPluriel.toLowerCase()} en France ${siteConfig.editionYear} , Classement`;
const description = `Classement editorial des ${nomPluriel.toLowerCase()} par departement. ${allPros.length} pros observes, edition N°${siteConfig.editionNumber}.`;
const url = `${siteConfig.url}/${metier}/`;

const jsonLd = [
  jsonLdBreadcrumbs([
    { name: "Accueil", url: siteConfig.url },
    { name: nomPluriel, url },
  ]),
];

// Ancienneté (années) depuis date_creation_entreprise
function ancienneteAnnees(dateStr: string | null): number | undefined {
  if (!dateStr) return undefined;
  const year = parseInt(dateStr.substring(0, 4), 10);
  if (!year || isNaN(year)) return undefined;
  return Math.max(0, new Date().getFullYear() - year);
}
---

<BaseLayout title={title} description={description} jsonLd={jsonLd} noIndex={true}>
  <article class="metier-page">
    <div class="container-wide metier-head">
      <Breadcrumbs items={[{ label: "Accueil", href: "/" }, { label: nomPluriel }]} />
      <Masthead category={`METIER , ${nomPluriel.toUpperCase()}`} signature="France entière" />
      <h1 class="heading-display">Les meilleurs <span class="italic-fraunces">{nomPluriel.toLowerCase()}</span> de France</h1>
      <p class="lead">
        {allPros.length} professionnels retenus par notre rédaction dans l'édition N°{siteConfig.editionNumber}. Classement département par département, score par score.
      </p>
    </div>

    {depts.length > 0 && (
      <section class="container-wide metier-depts">
        <EditorialHeader category="PAR DÉPARTEMENT" title={`${nomPluriel} par zone géographique`} />
        <div class="depts-grid stagger-children">
          {depts.map((d) => (
            <a class="dept-card card-editorial curl" href={`/${metier}/${d.slug}/`}>
              <h3 class="italic-fraunces">{d.nom} ({d.code})</h3>
              <p class="folio">Consulter le classement &rarr;</p>
            </a>
          ))}
        </div>
      </section>
    )}

    {top10.length > 0 && (
      <section class="container-wide metier-top">
        <EditorialHeader
          category="TOP FRANCE"
          title={`Les ${top10.length} ${nomPluriel.toLowerCase()} les mieux notés, toutes zones confondues`}
          subtitle="Extrait transversal. Pour le classement complet départemental, choisissez une zone ci-dessus."
        />
        <div class="top-list">
          {top10.map((p, i) => (
            <ProCard
              rank={i + 1}
              name={p.nom_entreprise}
              slug={p.slug}
              score={p.score_confiance}
              tier={p.tier}
              ville={p.ville || undefined}
              ancienneteAnnees={ancienneteAnnees(p.date_creation_entreprise)}
              rge={p.rge}
              qualibat={p.qualibat}
            />
          ))}
        </div>
      </section>
    )}

    <section class="container-wide metier-guide-cta">
      <div class="guide-cta-inner">
        <p class="guide-cta-eyebrow">GUIDE PRATIQUE</p>
        <h2 class="guide-cta-title">Avant de choisir un {nom.toLowerCase()}, lisez notre guide</h2>
        <p class="guide-cta-desc">
          Critères vérifiables, drapeaux rouges à fuir, questions à poser au devis : la grille
          éditoriale complète de notre rédaction.
        </p>
        <a href={`/guide/comment-choisir-un-${metier}/`} class="guide-cta-btn">Lire le guide complet &rarr;</a>
      </div>
    </section>

    <section class="container-wide"><MethodologyBlock /></section>
  </article>
</BaseLayout>

<style>
  .metier-page { padding: 2rem 0 4rem; }
  .metier-guide-cta {
    max-width: 60rem;
    margin: 3rem auto;
    padding: 2.5rem;
    background: var(--paper-warm, #f1ebdf);
    border-left: 4px solid var(--or, #b8863d);
    border-radius: 6px;
  }
  .guide-cta-inner { max-width: 50rem; }
  .guide-cta-eyebrow {
    font-family: var(--font-mono, JetBrains Mono, monospace);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: var(--observatoire);
    margin: 0 0 0.5rem;
  }
  .guide-cta-title {
    font-family: var(--font-display, Fraunces, serif);
    font-style: italic;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 400;
    margin: 0.4rem 0 0.75rem;
    color: var(--ink);
  }
  .guide-cta-desc {
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--text-soft);
    margin: 0 0 1.25rem;
  }
  .guide-cta-btn {
    display: inline-block;
    padding: 0.85rem 1.5rem;
    background: var(--observatoire, #1e3a52);
    color: var(--paper);
    text-decoration: none;
    border-radius: 4px;
    font-weight: 500;
  }
  .guide-cta-btn:hover { background: var(--ink); }
  .metier-head { max-width: 60rem; margin: 0 auto; padding-bottom: 2rem; }
  .metier-head .heading-display { margin: 0.4rem 0 1rem; }

  .metier-depts { padding: 2rem 0 3rem; max-width: 62rem; margin: 0 auto; }
  .depts-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; margin-top: 1.6rem; }
  @media (max-width: 760px) { .depts-grid { grid-template-columns: 1fr; } }
  .dept-card { padding: 1.2rem 1.3rem; text-decoration: none; color: var(--ink); display: grid; gap: 0.3rem; }
  .dept-card h3 { font-size: 1.25rem; margin: 0.2rem 0; font-weight: 500; color: var(--ink); }

  .metier-top { padding: 2rem 0 3rem; max-width: 62rem; margin: 0 auto; }
  .top-list { display: grid; gap: 1rem; }
</style>

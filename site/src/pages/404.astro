---
import BaseLayout from "../layouts/BaseLayout.astro";
import Seal from "../components/Seal.astro";
import { siteConfig } from "../utils/config";
---

<BaseLayout
  title={`Page introuvable , ${siteConfig.name}`}
  description="Cette page n'existe pas dans nos archives. Notre rédaction n'a pas observé cette adresse."
  noIndex
>
  <main class="notfound">
    <!-- Mesh atmosphere -->
    <div class="notfound-mesh" aria-hidden="true">
      <span class="mesh-blob mesh-blob-1"></span>
      <span class="mesh-blob mesh-blob-2"></span>
    </div>

    <div class="notfound-inner">
      <div class="notfound-seal fade-up">
        <Seal size={120} variant="or" animated={true} stamp={true} />
      </div>

      <p class="notfound-eyebrow meta-label-or fade-up" style="transition-delay: 100ms">
        Archives &middot; erreur 404
      </p>

      <h1 class="notfound-title blur-reveal" style="transition-delay: 200ms">
        Hors-champ.
      </h1>

      <p class="notfound-lead fade-up" style="transition-delay: 400ms">
        Notre rédaction n'a pas observé cette adresse. La page demandée est
        soit introuvable, soit déplacée dans les archives.
      </p>

      <div class="notfound-links stagger-children">
        <a class="notfound-link" href="/">
          <span class="nfl-kicker">Accueil</span>
          <span class="nfl-label">Consulter l'édition en cours</span>
          <span class="nfl-arrow" aria-hidden="true">&rarr;</span>
        </a>
        <a class="notfound-link" href="/selection/">
          <span class="nfl-kicker">La sélection</span>
          <span class="nfl-label">Parcourir les classements</span>
          <span class="nfl-arrow" aria-hidden="true">&rarr;</span>
        </a>
        <a class="notfound-link" href="/methode/">
          <span class="nfl-kicker">La méthode</span>
          <span class="nfl-label">Comprendre notre démarche</span>
          <span class="nfl-arrow" aria-hidden="true">&rarr;</span>
        </a>
        <a class="notfound-link" href="/candidater/">
          <span class="nfl-kicker">Candidater</span>
          <span class="nfl-label">Postuler à l'édition {siteConfig.editionYear}</span>
          <span class="nfl-arrow" aria-hidden="true">&rarr;</span>
        </a>
      </div>

      <p class="notfound-signature italic-fraunces fade-up">
        « Ce qu'on n'observe pas n'existe pas encore. »
      </p>
      <p class="notfound-folio folio fade-up">
        La rédaction &middot; Édition N°{siteConfig.editionNumber}
      </p>
    </div>
  </main>
</BaseLayout>

<style>
  .notfound {
    min-height: calc(100vh - 180px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(2.5rem, 6vw, 5rem) clamp(1.25rem, 5vw, 3rem);
    position: relative;
    overflow: hidden;
  }

  /* Mesh atmosphere en arriere-plan */
  .notfound-mesh {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }
  .notfound-mesh .mesh-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    opacity: 0.45;
  }
  .notfound-mesh .mesh-blob-1 {
    top: -15%;
    right: -5%;
    width: 45vw;
    height: 45vw;
    max-width: 520px;
    max-height: 520px;
    background: radial-gradient(circle, rgba(184, 134, 61, 0.28) 0%, transparent 70%);
  }
  .notfound-mesh .mesh-blob-2 {
    bottom: -15%;
    left: -5%;
    width: 40vw;
    height: 40vw;
    max-width: 480px;
    max-height: 480px;
    background: radial-gradient(circle, rgba(30, 58, 82, 0.18) 0%, transparent 70%);
  }

  .notfound-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 44rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .notfound-seal {
    margin-bottom: 1.4rem;
  }

  .notfound-eyebrow {
    margin: 0 0 1.1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.9rem;
    background: rgba(247, 243, 236, 0.65);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(184, 134, 61, 0.3);
    border-radius: 999px;
  }

  .notfound-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 440;
    font-size: clamp(3.2rem, 8vw, 6.4rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin: 0 0 1.3rem;
    font-variation-settings: "SOFT" 45, "opsz" 144, "wght" 440;
  }

  .notfound-lead {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.5vw, 1.18rem);
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0 auto 2.2rem;
    max-width: 34rem;
  }

  .notfound-links {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.7rem;
    width: 100%;
    max-width: 36rem;
    margin: 0 auto 2.4rem;
  }
  @media (max-width: 540px) {
    .notfound-links { grid-template-columns: 1fr; }
  }
  .notfound-link {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.35rem;
    padding: 0.95rem 1.15rem;
    text-align: left;
    text-decoration: none;
    background: rgba(247, 243, 236, 0.85);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(26, 22, 20, 0.08);
    border-radius: 14px;
    color: var(--ink);
    transition:
      transform 320ms var(--spring, cubic-bezier(0.34, 1.56, 0.64, 1)),
      border-color 300ms,
      background 300ms,
      box-shadow 300ms;
    overflow: hidden;
    align-items: center;
  }
  .notfound-link:hover {
    transform: translateY(-3px);
    border-color: rgba(184, 134, 61, 0.45);
    background: rgba(247, 243, 236, 0.95);
    box-shadow: 0 10px 24px -12px rgba(26, 22, 20, 0.18);
  }
  .nfl-kicker {
    display: block;
    font-family: var(--font-body);
    font-size: 0.62rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--or-deep);
    font-weight: 600;
    grid-column: 1;
    grid-row: 1;
  }
  .nfl-label {
    display: block;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 480;
    color: var(--ink);
    line-height: 1.3;
    margin-top: 0.18rem;
    grid-column: 1;
    grid-row: 2;
    font-variation-settings: "SOFT" 50, "opsz" 48;
  }
  .nfl-arrow {
    grid-column: 2;
    grid-row: 1 / 3;
    align-self: center;
    font-size: 1.05rem;
    color: var(--or-deep);
    transition: transform 260ms var(--ease-out-quart);
  }
  .notfound-link:hover .nfl-arrow { transform: translateX(3px); }

  .notfound-signature {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    color: var(--ink-muted);
    margin: 0.5rem 0 0.3rem;
  }
  .notfound-folio {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink-muted);
    letter-spacing: 0.04em;
  }
</style>

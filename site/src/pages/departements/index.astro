---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Masthead from "../../components/Masthead.astro";
import EditorialHeader from "../../components/EditorialHeader.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { siteConfig } from "../../utils/config";
import { getZones, getMetierDeptCombos, supabase } from "../../lib/supabase";
import { jsonLdBreadcrumbs, ORG_ID } from "../../utils/seo";
import { REGION_BY_DEPT_CODE } from "../../data/geo_fr";

const title = "Départements couverts , L'Observatoire des Pros";
const description = "Tous les départements observés par L'Observatoire. Classement par région, par métier. Observation éditoriale mensuelle, données publiques Sirene INSEE.";
const url = `${siteConfig.url}/departements/`;

// Source de vérité : zones DB avec au moins un combo (métier × dpt) valide.
const allZones = await getZones("departement");
const combos = await getMetierDeptCombos();
const deptsWithPros = new Set<string>();
const metiersByDept = new Map<string, Set<string>>();
for (const c of combos) {
  const [m, d] = c.split(":");
  deptsWithPros.add(d);
  if (!metiersByDept.has(d)) metiersByDept.set(d, new Set());
  metiersByDept.get(d)!.add(m);
}

// Count pros par zone (pagination pro_zones pour bypass PostgREST 1000 cap)
const countsByZoneId = new Map<string, number>();
{
  const page = 1000;
  for (let start = 0; ; start += page) {
    const { data } = await supabase
      .from("pro_zones")
      .select("zone_id")
      .range(start, start + page - 1);
    if (!data || data.length === 0) break;
    for (const row of data as { zone_id: string }[]) {
      countsByZoneId.set(row.zone_id, (countsByZoneId.get(row.zone_id) || 0) + 1);
    }
    if (data.length < page) break;
  }
}

const deptsActifs = allZones
  .filter((z) => deptsWithPros.has(z.slug))
  .map((z) => ({
    ...z,
    region: REGION_BY_DEPT_CODE[z.code || ""] || "France",
    count: countsByZoneId.get(z.id) || 0,
    metierCount: metiersByDept.get(z.slug)?.size || 0,
    firstMetier: Array.from(metiersByDept.get(z.slug) || []).sort()[0] || "",
  }))
  .sort((a, b) => b.count - a.count);

// Groupement par région
const byRegion = new Map<string, typeof deptsActifs>();
for (const d of deptsActifs) {
  if (!byRegion.has(d.region)) byRegion.set(d.region, []);
  byRegion.get(d.region)!.push(d);
}
const regionsActives = Array.from(byRegion.keys()).sort();

const totalPros = deptsActifs.reduce((n, d) => n + d.count, 0);
const totalDepts = deptsActifs.length;
const totalRegions = regionsActives.length;
const deptsEnAttente = allZones.filter((z) => !deptsWithPros.has(z.slug)).length;

const jsonLd = [
  jsonLdBreadcrumbs([{ name: "Accueil", url: siteConfig.url }, { name: "Départements", url }]),
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "@id": `${url}#collection`,
    url,
    name: "Départements couverts par L'Observatoire des Pros",
    description,
    isPartOf: { "@id": `${siteConfig.url}/#website` },
    publisher: { "@id": ORG_ID },
    hasPart: deptsActifs.map((d) => ({
      "@type": "AdministrativeArea",
      name: d.nom,
      identifier: d.code,
      containedInPlace: { "@type": "AdministrativeArea", name: d.region },
    })),
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <div class="container-wide" style="padding: 2rem 0 4rem;">
    <Breadcrumbs items={[{ label: "Accueil", href: "/" }, { label: "Départements" }]} />
    <Masthead category="COUVERTURE NATIONALE" signature={`Édition N°${siteConfig.editionNumber}`} />
    <h1 class="heading-display">{totalDepts} départements, {totalRegions} région{totalRegions > 1 ? "s" : ""}.</h1>
    <p class="lead" data-speakable>
      {totalPros.toLocaleString("fr-FR")} professionnels observés dans {totalDepts} départements, {totalRegions} région{totalRegions > 1 ? "s" : ""} française{totalRegions > 1 ? "s" : ""}. {deptsEnAttente > 0 ? `Extension progressive prévue aux ${deptsEnAttente} départements métropolitains restants.` : "Couverture nationale complète."}
    </p>

    <div class="dept-search" role="search">
      <label class="dept-search-label" for="dept-search-input">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7" />
          <path d="m21 21-4.3-4.3" />
        </svg>
        <input
          id="dept-search-input"
          type="search"
          autocomplete="off"
          placeholder="Chercher un département (Yonne, 89, Bourgogne…)"
          aria-label="Chercher un département par nom, code ou région"
        />
      </label>
      <p class="dept-search-count" id="dept-search-count" aria-live="polite">{totalDepts} départements affichés</p>
    </div>

    {regionsActives.map((region) => {
      const depts = byRegion.get(region)!;
      return (
        <section class="region-section" style="margin-top: 3rem;">
          <EditorialHeader
            category={region.toUpperCase()}
            title={`${depts.length} département${depts.length > 1 ? "s" : ""} observé${depts.length > 1 ? "s" : ""}`}
          />
          <div class="depts-national stagger-children">
            {depts.map((d) => (
              <article
                class="dept-national card-editorial curl"
                data-dept-search={`${d.nom} ${d.code || ""} ${d.region} ${d.slug}`.toLowerCase()}
              >
                <span class="meta-label-or">{d.region}</span>
                <h2 class="italic-fraunces">{d.nom}</h2>
                <p class="folio">
                  Code {d.code} · {d.count.toLocaleString("fr-FR")} professionnels · {d.metierCount} métier{d.metierCount > 1 ? "s" : ""}
                </p>
                {d.firstMetier && (
                  <a class="dept-link" href={`/${d.firstMetier}/${d.slug}/`}>
                    Consulter les classements <span aria-hidden="true">-&gt;</span>
                  </a>
                )}
                <a class="dept-link dept-link-snapshot" href={`/observations/etat-du-marche/${d.slug}/`}>
                  Lire le snapshot du marché <span aria-hidden="true">-&gt;</span>
                </a>
              </article>
            ))}
          </div>
        </section>
      );
    })}

    {deptsEnAttente > 0 && (
      <p class="meta-label" style="margin-top: 3rem; text-align: center; max-width: 34rem; margin-inline: auto;">
        Prochaine édition : extension progressive aux {deptsEnAttente} départements métropolitains restants.
      </p>
    )}
  </div>
</BaseLayout>

<style>
  .region-section { max-width: 62rem; margin-inline: auto; }
  .depts-national {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.3rem; margin-top: 1.6rem;
  }
  @media (max-width: 860px) { .depts-national { grid-template-columns: 1fr; } }
  .dept-national {
    padding: 1.6rem 1.7rem 1.8rem;
    display: grid; gap: 0.4rem;
  }
  .dept-national h2 { font-size: 1.7rem; margin: 0.2rem 0; font-weight: 500; color: var(--ink); }
  .dept-link {
    display: inline-flex; margin-top: 0.8rem; padding-top: 0.7rem;
    border-top: 1px solid rgba(26, 22, 20, 0.08);
    font-family: var(--font-body); font-size: 0.88rem; color: var(--or-deep);
    text-decoration: none;
  }
  .dept-link:hover { text-decoration: underline; }
  .dept-link-snapshot {
    margin-top: 0.4rem;
    padding-top: 0.4rem;
    border-top: none;
    color: var(--observatoire, #1e3a52);
    font-style: italic;
  }

  /* Search bar — bandeau discret, ne touche pas la DA des cards */
  .dept-search {
    margin: 1.5rem auto 0;
    max-width: 32rem;
    display: grid;
    gap: 0.5rem;
  }
  .dept-search-label {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 0.95rem;
    background: var(--paper);
    border: 1px solid rgba(26, 22, 20, 0.12);
    border-radius: 12px;
    color: var(--ink-muted);
    transition: border-color 240ms, box-shadow 240ms;
  }
  .dept-search-label:focus-within {
    border-color: rgba(184, 134, 61, 0.55);
    box-shadow: 0 0 0 3px rgba(184, 134, 61, 0.12);
  }
  .dept-search-label input {
    appearance: none;
    border: 0;
    outline: 0;
    background: transparent;
    font: inherit;
    font-family: var(--font-body);
    font-size: 0.94rem;
    color: var(--ink);
    width: 100%;
    padding: 0.1rem 0;
  }
  .dept-search-label input::placeholder { color: var(--ink-muted); }
  .dept-search-count {
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.78rem;
    color: var(--ink-muted);
    text-align: center;
    letter-spacing: 0.02em;
  }
  .dept-national.is-hidden { display: none; }
  .region-section.is-empty { display: none; }
</style>

<script>
  (function () {
    var input = document.getElementById("dept-search-input");
    var count = document.getElementById("dept-search-count");
    if (!input || !count) return;
    var cards = Array.prototype.slice.call(document.querySelectorAll(".dept-national[data-dept-search]"));
    var sections = Array.prototype.slice.call(document.querySelectorAll(".region-section"));
    var totalLabel = count.textContent || "";

    function normalize(s) {
      return (s || "")
        .toString()
        .toLowerCase()
        .normalize("NFD")
        .replace(/[̀-ͯ]/g, "")
        .trim();
    }

    function apply() {
      var q = normalize(input.value);
      var visible = 0;
      cards.forEach(function (card) {
        var hay = card.getAttribute("data-dept-search") || "";
        var match = !q || normalize(hay).indexOf(q) !== -1;
        card.classList.toggle("is-hidden", !match);
        if (match) visible++;
      });
      sections.forEach(function (section) {
        var anyVisible = section.querySelectorAll(".dept-national:not(.is-hidden)").length > 0;
        section.classList.toggle("is-empty", !anyVisible);
      });
      if (!q) {
        count.textContent = totalLabel;
      } else if (visible === 0) {
        count.textContent = "Aucun département ne correspond à « " + input.value + " »";
      } else {
        count.textContent = visible + " département" + (visible > 1 ? "s" : "") + " correspondant" + (visible > 1 ? "s" : "");
      }
    }

    input.addEventListener("input", apply, { passive: true });
    input.addEventListener("search", apply, { passive: true });
  })();
</script>

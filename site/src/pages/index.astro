---
import BaseLayout from "../layouts/BaseLayout.astro";
import Seal from "../components/Seal.astro";
import CounterLive from "../components/CounterLive.astro";
import EditorialHeader from "../components/EditorialHeader.astro";
import Medaille from "../components/Medaille.astro";
import ProCard from "../components/ProCard.astro";
import PullQuote from "../components/PullQuote.astro";
import TelescopeWatermark from "../components/TelescopeWatermark.astro";
import { siteConfig } from "../utils/config";

// Classements populaires , 8 combinaisons métier × dept
const classementsPopulaires = [
  { metier: "Plombier", slug: "plombier", dept: "Paris", deptSlug: "paris-75", count: 142 },
  { metier: "Électricien", slug: "electricien", dept: "Paris", deptSlug: "paris-75", count: 198 },
  { metier: "Couvreur", slug: "couvreur", dept: "Yonne", deptSlug: "yonne-89", count: 38 },
  { metier: "Menuisier", slug: "menuisier", dept: "Côte-d'Or", deptSlug: "cote-dor-21", count: 54 },
  { metier: "Isolation", slug: "isolation", dept: "Yonne", deptSlug: "yonne-89", count: 29 },
  { metier: "Plombier", slug: "plombier", dept: "Côte-d'Or", deptSlug: "cote-dor-21", count: 67 },
  { metier: "Électricien", slug: "electricien", dept: "Yonne", deptSlug: "yonne-89", count: 41 },
  { metier: "Couvreur", slug: "couvreur", dept: "Côte-d'Or", deptSlug: "cote-dor-21", count: 33 },
];

// "À la Une" , 3 observations vedettes
const alaUne = [
  {
    category: "ENQUETE",
    title: "Dans l'Yonne, la fin programmee des fausses mentions RGE",
    excerpt: "Six entreprises referencees ont perdu leur label en six mois. Notre redaction a verifie les certifications affichees sur 412 sites web d'artisans.",
    author: "Camille Fabre",
    date: "19 avril 2026",
    readingTime: 12,
    slug: "enquete-rge-yonne-412-sites",
  },
  {
    category: "METHODOLOGIE",
    title: "Pourquoi le Score de Confiance ne compte pas les etoiles Google",
    excerpt: "La moyenne d'etoiles est un indicateur fragile. Voici comment notre redaction croise quatre sources avant de retenir un pourcentage.",
    author: "Antoine Delaunay",
    date: "15 avril 2026",
    readingTime: 7,
    slug: "methodologie-score-confiance-etoiles",
  },
  {
    category: "PORTRAIT",
    title: "Atelier Maurel, menuiserie d'art a Dijon depuis 1974",
    excerpt: "Quatre generations, deux compagnons du devoir, et l'une des trois medailles d'Or decernees cette annee en Cote-d'Or.",
    author: "Sarah Poitevin",
    date: "11 avril 2026",
    readingTime: 9,
    slug: "portrait-atelier-maurel-dijon",
  },
];

// Portrait vedette (Lauréat du mois)
const portraitVedette = {
  name: "Dubois & Fils , Plomberie generale",
  slug: "dubois-fils-plomberie-generale",
  ville: "Auxerre (89)",
  citation:
    "Nous refusons un chantier sur trois. Cela etonne les clients. Mais refuser, c'est aussi proteger la reputation qu'on a mise quarante ans a construire.",
  citationAuteur: "Jean-Paul Dubois, gerant",
  score: 9.4,
  fondation: 1984,
  salaries: 12,
  resume:
    "Entreprise familiale de plomberie generale basee a Auxerre depuis 1984. Specialisee en renovation de reseaux anciens et depannage d'urgence dans l'Yonne. Deux plombiers compagnons du devoir, trois apprentis. Certifiee RGE et Qualibat depuis 2011. Portrait Laureat 2026.",
};

// Top 3 du classement mis en avant (Plomberie Yonne)
const topClassementMisEnAvant = [
  {
    rank: 1, name: "Dubois & Fils", slug: "dubois-fils-plomberie-generale", score: 9.4,
    tier: "or" as const, ville: "Auxerre (89)", zoneIntervention: "Yonne, Cote-d'Or",
    ancienneteAnnees: 42, rge: true, qualibat: true,
    specialites: ["Reseaux anciens", "Depannage urgence", "Salles de bain"],
    resumeCourt: "Entreprise familiale plomberie generale Yonne, 4 generations, deux compagnons du devoir.",
    previewImages: [],
  },
  {
    rank: 2, name: "Lefevre Thermique", slug: "lefevre-thermique", score: 9.1,
    tier: "argent" as const, ville: "Sens (89)", zoneIntervention: "Nord Yonne",
    ancienneteAnnees: 22, rge: true, qualibat: false,
    specialites: ["Chaudieres gaz", "Pompes a chaleur", "Sanitaires"],
    resumeCourt: "Specialiste PAC et chaudieres gaz a condensation, certifie RGE depuis 2014.",
  },
  {
    rank: 3, name: "SARL Martin", slug: "sarl-martin-plombier", score: 8.7,
    tier: "gratuit" as const, ville: "Joigny (89)", zoneIntervention: "Joigny et alentours",
    ancienneteAnnees: 18, rge: false, qualibat: true,
    specialites: ["Depannage", "Pose sanitaires"],
    resumeCourt: "Artisan installe depuis 2008, qualification Qualibat confirmee.",
  },
];

// Titre SEO homepage , target 55-60 chars pour eviter la troncature Google
const title = `${siteConfig.name} , Classement des artisans de France`;
const description = siteConfig.description;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: siteConfig.name,
  description: siteConfig.description,
  publisher: { "@type": "NewsMediaOrganization", name: siteConfig.name, url: siteConfig.url },
  hasPart: classementsPopulaires.map((c) => ({
    "@type": "ItemList",
    name: `Classement ${c.metier} ${c.dept}`,
    url: `${siteConfig.url}/${c.slug}/${c.deptSlug}/`,
  })),
  mainEntity: {
    "@type": "FAQPage",
    mainEntity: siteConfig.faq.map((q) => ({
      "@type": "Question",
      name: q.question,
      acceptedAnswer: { "@type": "Answer", text: q.answer },
    })),
  },
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>

  <!-- ═══════════════════ HERO ═══════════════════ -->
  <section class="hero-section" aria-label="Accueil éditorial">
    <TelescopeWatermark side="right" size={520} parallax={0.05} />

    <div class="container-wide hero-inner">
      <div class="hero-text">
        <div class="hero-overline fade-up">
          <span class="live-dot" aria-hidden="true"></span>
          <span class="meta-label-ink">Édition N°{siteConfig.editionNumber} &middot; {siteConfig.editionMonth} {siteConfig.editionYear}</span>
        </div>

        <h1 class="heading-hero hero-title" data-split-words>
          {siteConfig.baseline}
        </h1>

        <p class="lead hero-lead fade-up">
          Chaque mois, notre rédaction observe, vérifie et classe les meilleurs artisans de France. Sans algorithme opaque. Avec méthode. Avec patience.
        </p>

        <div class="hero-counter fade-up">
          <CounterLive initial={47382} label="professionnels sous observation" />
        </div>

        <div class="hero-cta-row fade-up">
          <a href="/selection/" class="btn btn-primary magnetic">Explorer la sélection</a>
          <a href="/methode/" class="btn btn-ghost">Consulter la méthode <span class="arrow">&rarr;</span></a>
        </div>

        <div class="hero-proof meta-label fade-up">
          Sources : INSEE &middot; France Rénov &middot; Qualibat &middot; Google Business &middot; DGCCRF
        </div>
      </div>

      <div class="hero-seal scale-reveal">
        <Seal size={280} variant="or" animated={true} stamp={true} />
        <p class="hero-seal-caption meta-label-or">Sceau de la rédaction 2026</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ À LA UNE ═══════════════════ -->
  <section class="section-alaune container-wide">
    <EditorialHeader category="À LA UNE CETTE SEMAINE" title="Observations de la rédaction" subtitle="Trois sujets que notre rédaction a jugés dignes d'être mis à la une cette semaine." />

    <div class="alaune-grid stagger-children">
      {alaUne.map((item, i) => (
        <article class={`alaune-card card-editorial curl ${i === 0 ? "alaune-card-hero" : ""}`}>
          <div class="alaune-visual" aria-hidden="true">
            <span class="alaune-visual-initial">{item.category.charAt(0)}</span>
            <svg width="100%" height="100%" viewBox="0 0 400 260" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
              <defs>
                <pattern id={`grid-${i}`} width="24" height="24" patternUnits="userSpaceOnUse">
                  <path d="M 24 0 L 0 0 0 24" fill="none" stroke="currentColor" stroke-width="0.4" />
                </pattern>
              </defs>
              <rect width="400" height="260" fill="var(--paper-warm)" />
              <rect width="400" height="260" fill={`url(#grid-${i})`} style="color: var(--ink-muted); opacity: 0.25" />
              <text x="50%" y="50%" text-anchor="middle" font-family="Instrument Serif, Georgia, serif" font-size="148" font-weight="400" fill="var(--ink)" opacity="0.12" dy=".38em" font-style="italic">{String(i+1).padStart(2, "0")}</text>
            </svg>
          </div>
          <div class="alaune-body">
            <p class="meta-label-or">{item.category}</p>
            <h3 class="alaune-title"><a href={`/observations/${item.slug}/`}>{item.title}</a></h3>
            <p class="alaune-excerpt">{item.excerpt}</p>
            <p class="byline folio">{item.author} &middot; {item.date} &middot; {item.readingTime} min</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ═══════════════════ PORTRAIT DE LA SEMAINE ═══════════════════ -->
  <section class="section-portrait">
    <div class="container-wide portrait-inner">
      <div class="portrait-meta slide-left">
        <span class="meta-label-or">Portrait Lauréat &middot; Avril 2026</span>
        <h2 class="heading-display portrait-title">
          <span class="italic-fraunces">{portraitVedette.name}</span>
        </h2>
        <p class="lead portrait-lead">
          Portrait long format de la seule entreprise de plomberie générale de l'Yonne distinguée d'une médaille d'Or cette année.
        </p>
        <ul class="portrait-stats">
          <li><span class="stat-val">{portraitVedette.score}</span><span class="stat-lbl">/ 10 Score de Confiance</span></li>
          <li><span class="stat-val">{new Date().getFullYear() - portraitVedette.fondation}</span><span class="stat-lbl">années d'activité</span></li>
          <li><span class="stat-val">{portraitVedette.salaries}</span><span class="stat-lbl">salariés et apprentis</span></li>
        </ul>
        <a href={`/pro/${portraitVedette.slug}/`} class="btn btn-observatoire magnetic">Lire le portrait complet</a>
      </div>

      <div class="portrait-citation slide-right">
        <PullQuote cite={portraitVedette.citationAuteur} align="left">
          {portraitVedette.citation}
        </PullQuote>
        <p class="portrait-resume prose">{portraitVedette.resume}</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ LES 3 TEMPS DE LA MÉTHODE ═══════════════════ -->
  <section class="section-methode container-wide">
    <EditorialHeader category="LA MÉTHODE" title="Observer. Vérifier. Recommander." subtitle="Trois temps, six critères, une méthode publique, vérifiable, décrite par écrit." align="center" />

    <ol class="methode-trois-temps stagger-children">
      <li class="methode-temps card-editorial">
        <span class="rank-num rank-outlined">01</span>
        <h3>Observer</h3>
        <p>Nous cartographions les 47 382 artisans référencés au Sirene sur nos zones pilotes. Données publiques uniquement. Sources citées.</p>
      </li>
      <li class="methode-temps card-editorial">
        <span class="rank-num rank-outlined">02</span>
        <h3>Vérifier</h3>
        <p>Chaque candidat est confronté à six critères documentés : ancienneté, RGE, avis, SIRET, site web, portfolio. Pas de score, pas de publication.</p>
      </li>
      <li class="methode-temps card-editorial">
        <span class="rank-num rank-outlined">03</span>
        <h3>Recommander</h3>
        <p>La rédaction classe. Médailles Or et Argent décernées après examen éditorial. Archivées chaque année. Consultables indéfiniment.</p>
      </li>
    </ol>

    <p class="methode-foot-cta">
      <a href="/methode/" class="btn-ghost">Lire la méthode complète <span class="arrow">&rarr;</span></a>
    </p>
  </section>

  <!-- ═══════════════════ CLASSEMENTS POPULAIRES ═══════════════════ -->
  <section class="section-classements container-wide">
    <EditorialHeader category="LA SÉLECTION" title="Les classements les plus consultés" subtitle="Huit classements départementaux les plus consultés cette semaine par les lecteurs." />

    <div class="classements-grid stagger-children">
      {classementsPopulaires.map((c) => (
        <a href={`/${c.slug}/${c.deptSlug}/`} class="classement-card card-editorial curl">
          <span class="meta-label">{c.dept}</span>
          <h3 class="classement-title italic-fraunces">{c.metier}s</h3>
          <p class="classement-count folio">{c.count} observations &middot; édition en cours</p>
          <span class="classement-arrow">&rarr;</span>
        </a>
      ))}
    </div>

    <p class="classements-tous">
      <a href="/selection/" class="btn-ghost">Voir tous les classements <span class="arrow">&rarr;</span></a>
    </p>
  </section>

  <!-- ═══════════════════ TOP 3 , EXTRAIT D'UN CLASSEMENT ═══════════════════ -->
  <section class="section-top3 container-wide">
    <EditorialHeader category="EXTRAIT DU CLASSEMENT" title="Plomberie générale dans l'Yonne" subtitle="Trois premières places du classement 2026, extrait de l'édition mensuelle." />

    <div class="top3-list">
      {topClassementMisEnAvant.map((p) => (
        <div data-rank-item={p.rank}>
          <ProCard {...p} />
        </div>
      ))}
    </div>

    <p class="top3-link">
      <a href="/plombier/yonne-89/" class="btn btn-outline">Consulter le classement intégral <span class="arrow">&rarr;</span></a>
    </p>
  </section>

  <!-- ═══════════════════ STATS MENSUELLES ═══════════════════ -->
  <section class="section-stats">
    <div class="container-wide stats-grid stagger-children">
      <div class="stat-block">
        <p class="stat-num" data-count="47382">47 382</p>
        <p class="stat-label">professionnels sous observation</p>
      </div>
      <div class="stat-block">
        <p class="stat-num" data-count="6">6</p>
        <p class="stat-label">critères objectifs de scoring</p>
      </div>
      <div class="stat-block">
        <p class="stat-num" data-count="3">3</p>
        <p class="stat-label">départements pilotes cette édition</p>
      </div>
      <div class="stat-block">
        <p class="stat-num" data-count="128">128</p>
        <p class="stat-label">dossiers candidats examinés</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ ESPACE PRO ═══════════════════ -->
  <section class="section-pro">
    <div class="container-editorial pro-cta-inner blur-reveal">
      <span class="meta-label-or">Candidater à l'édition 2026</span>
      <h2 class="heading-display">Votre entreprise mérite-t-elle de figurer dans notre guide ?</h2>
      <p class="lead">
        Chaque année, notre rédaction examine quelques milliers de dossiers. Les meilleurs reçoivent la médaille d'Argent ou d'Or. Votre candidature est gratuite. Le passage en Portrait Vérifié ou Lauréat est optionnel, payant, et sans engagement de durée.
      </p>
      <div class="pro-cta-row">
        <a href="/candidater/" class="btn btn-primary magnetic">Soumettre ma candidature</a>
        <a href="/portraits/laureat/" class="btn btn-ghost">En savoir plus sur le Portrait Lauréat <span class="arrow">&rarr;</span></a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ DERNIÈRES OBSERVATIONS ═══════════════════ -->
  <section class="section-observations container-wide">
    <EditorialHeader category="NOS OBSERVATIONS" title="Dernières publications de la rédaction" />
    <div class="observations-list">
      {alaUne.map((o) => (
        <a class="observation-row curl" href={`/observations/${o.slug}/`}>
          <div class="observation-meta">
            <span class="meta-label-or">{o.category}</span>
            <span class="folio">{o.date}</span>
          </div>
          <h3 class="observation-title">{o.title}</h3>
          <p class="observation-excerpt">{o.excerpt}</p>
          <span class="observation-arrow">&rarr;</span>
        </a>
      ))}
    </div>
    <p><a href="/observations/" class="btn-ghost">Toutes les observations <span class="arrow">&rarr;</span></a></p>
  </section>

  <!-- ═══════════════════ FAQ ═══════════════════ -->
  <section class="section-faq">
    <div class="container-editorial">
      <EditorialHeader category="QUESTIONS FRÉQUENTES" title="Ce que nous répondons, publiquement" align="center" />
      <div class="faq-list stagger-children">
        {siteConfig.faq.map((q, i) => (
          <details class="faq-item">
            <summary>
              <span class="folio faq-num">{String(i+1).padStart(2, "0")}</span>
              <span class="faq-question">{q.question}</span>
              <span class="faq-toggle" aria-hidden="true">+</span>
            </summary>
            <div class="faq-answer"><p>{q.answer}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════ NEWSLETTER ═══════════════════ -->
  <section class="section-newsletter">
    <div class="container-editorial newsletter-inner">
      <Seal size={72} variant="or" animated={true} />
      <h2 class="heading-display newsletter-title">La lettre de L'Observatoire</h2>
      <p class="lead">
        Chaque mois, notre rédaction adresse une lettre à ses lecteurs. Une observation majeure, un portrait, une question de méthode. Pas de publicité, pas de tracking invasif. Désabonnement en un clic.
      </p>
      <form class="newsletter-form" method="post" action="#">
        <label class="sr-only" for="nl-email">Adresse email</label>
        <input id="nl-email" type="email" name="email" required placeholder="votre adresse email" />
        <button type="submit" class="btn btn-observatoire">S'abonner</button>
      </form>
      <p class="meta-label newsletter-meta">Gratuit. Ouvert à tous. Archives consultables.</p>
    </div>
  </section>

</BaseLayout>

<style>
  /* ═══════ HERO ═══════ */
  .hero-section {
    position: relative;
    padding: clamp(3rem, 7vw, 7rem) 0 clamp(3rem, 6vw, 6rem);
    overflow: hidden;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }
  @media (max-width: 960px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-seal { order: -1; justify-self: center; }
  }
  .hero-overline {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.4rem 0.75rem 0.4rem 0.6rem;
    border: 1px solid rgba(26, 22, 20, 0.15);
    border-radius: 2px;
    background: rgba(247, 243, 236, 0.75);
    margin-bottom: 1.6rem;
  }
  .hero-title {
    margin: 0.4rem 0 1.5rem;
    max-width: 16ch;
  }
  .hero-lead {
    max-width: 36rem;
    margin: 0 0 1.8rem;
  }
  .hero-counter {
    margin: 0 0 1.8rem;
    padding: 1rem 1.2rem;
    border-left: 2px solid var(--or);
    background: rgba(239, 231, 214, 0.4);
  }
  .hero-cta-row {
    display: flex;
    gap: 1.2rem;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .hero-proof {
    font-size: 0.72rem;
    color: var(--ink-muted);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .hero-seal {
    position: relative;
    display: grid;
    place-items: center;
    gap: 0.8rem;
  }
  .hero-seal-caption {
    text-align: center;
    margin-top: 0.5rem;
  }

  /* ═══════ À LA UNE ═══════ */
  .section-alaune { padding: clamp(2rem, 5vw, 4rem) 0 clamp(3rem, 5vw, 5rem); }
  .alaune-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 1.8rem;
    align-items: start;
  }
  @media (max-width: 960px) {
    .alaune-grid { grid-template-columns: 1fr 1fr; }
    .alaune-card-hero { grid-column: 1 / -1; }
  }
  @media (max-width: 640px) {
    .alaune-grid { grid-template-columns: 1fr; }
    .alaune-card-hero { grid-column: 1; }
  }
  .alaune-card { padding: 0; overflow: hidden; }
  .alaune-visual { position: relative; aspect-ratio: 4 / 3; background: var(--paper-warm); overflow: hidden; }
  .alaune-visual-initial { display: none; }
  .alaune-card-hero .alaune-visual { aspect-ratio: 16 / 9; }
  .alaune-body { padding: 1.4rem 1.6rem 1.7rem; }
  .alaune-title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2vw, 1.7rem);
    font-weight: 500;
    letter-spacing: -0.015em;
    line-height: 1.15;
    margin: 0.4rem 0 0.6rem;
  }
  .alaune-card-hero .alaune-title { font-size: clamp(1.6rem, 2.8vw, 2.1rem); }
  .alaune-title a { color: var(--ink); text-decoration: none; border-bottom: 1px solid transparent; transition: border-color 200ms; }
  .alaune-title a:hover { border-color: var(--or); }
  .alaune-excerpt { color: var(--ink-soft); font-size: 0.98rem; line-height: 1.55; margin-bottom: 0.7rem; }

  /* ═══════ PORTRAIT VEDETTE ═══════ */
  .section-portrait { padding: clamp(2rem, 5vw, 5rem) 0; background: var(--paper-warm); }
  .portrait-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  @media (max-width: 860px) { .portrait-inner { grid-template-columns: 1fr; } }
  .portrait-title { margin: 0.5rem 0 1rem; }
  .portrait-lead { margin-bottom: 1.4rem; }
  .portrait-stats {
    list-style: none;
    padding: 0;
    margin: 0 0 1.8rem;
    display: flex;
    gap: 2.5rem;
    flex-wrap: wrap;
  }
  .portrait-stats li { display: flex; flex-direction: column; gap: 0.1rem; }
  .stat-val { font-family: var(--font-display); font-size: 1.6rem; font-weight: 600; color: var(--ink); letter-spacing: -0.01em; }
  .stat-lbl { font-size: 0.78rem; color: var(--ink-muted); text-transform: uppercase; letter-spacing: 0.12em; }
  .portrait-resume { font-size: 0.98rem; }

  /* ═══════ MÉTHODE 3 TEMPS ═══════ */
  .section-methode { padding: clamp(3rem, 6vw, 6rem) 0 clamp(2rem, 4vw, 4rem); }
  .methode-trois-temps {

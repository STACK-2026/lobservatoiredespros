---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Masthead from "../../components/Masthead.astro";
import EditorialHeader from "../../components/EditorialHeader.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ProCard from "../../components/ProCard.astro";
import { siteConfig } from "../../utils/config";
import { supabase } from "../../lib/supabase";
import { jsonLdBreadcrumbs } from "../../utils/seo";

const title = `La sélection ${siteConfig.editionYear} , L'Observatoire des Pros`;
const description = "La sélection éditoriale de l'édition en cours. Les professionnels retenus, triés par Score de Confiance, toutes zones et tous métiers.";
const url = `${siteConfig.url}/selection/`;

// Fetch les vrais pros classes par niveau de confiance
const { data: allPros } = await supabase
  .from("pros")
  .select("slug, nom_entreprise, ville, code_postal, score_confiance, tier, niveau_confiance, rge, qualibat, date_creation_entreprise")
  .eq("active", true)
  .not("slug", "is", null)
  .order("score_confiance", { ascending: false })
  .limit(100);

const pros = allPros || [];
const laureats = pros.filter((p) => p.niveau_confiance === "or" || p.niveau_confiance === "platine");
const verifies = pros.filter((p) => p.niveau_confiance === "argent");
const autres = pros.filter((p) => p.niveau_confiance === "bronze");

function anciennete(p: any): number | undefined {
  if (!p.date_creation_entreprise) return undefined;
  try {
    return new Date().getFullYear() - parseInt(p.date_creation_entreprise.slice(0, 4), 10);
  } catch {
    return undefined;
  }
}

const jsonLd = [jsonLdBreadcrumbs([{ name: "Accueil", url: siteConfig.url }, { name: "Sélection", url }])];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <div class="container-wide" style="padding: 2rem 0 4rem;">
    <Breadcrumbs items={[{ label: "Accueil", href: "/" }, { label: "La sélection" }]} />
    <Masthead category="LA SÉLECTION" signature={`Édition N°${siteConfig.editionNumber} , ${siteConfig.editionMonth} ${siteConfig.editionYear}`} />
    <h1 class="heading-display">La sélection {siteConfig.editionYear}.</h1>
    <p class="lead">
      Les professionnels retenus par notre rédaction, toutes zones et tous métiers confondus.
      <strong>{laureats.length}</strong> niveau Or · <strong>{verifies.length}</strong> niveau Argent
      · {autres.length} niveau Bronze. Classement calculé sur Sirene, ADEME, BODACC.
    </p>

    {laureats.length > 0 && (
      <section style="margin-top: 3rem;">
        <EditorialHeader
          category="NIVEAU OR"
          title={`${laureats.length} professionnel${laureats.length > 1 ? "s" : ""} distingué${laureats.length > 1 ? "s" : ""} en Or`}
          subtitle="Dossiers les plus solides : ancienneté, qualifications actives, transparence comptable, cumul de signaux positifs."
        />
        <div class="selection-list">
          {laureats.map((p, i) => (
            <ProCard
              rank={i + 1}
              name={p.nom_entreprise}
              slug={p.slug}
              score={p.score_confiance || 0}
              tier="or"
              ville={p.ville || ""}
              zoneIntervention={p.code_postal || ""}
              ancienneteAnnees={anciennete(p)}
              rge={p.rge}
              qualibat={p.qualibat}
              specialites={[]}
            />
          ))}
        </div>
      </section>
    )}

    {verifies.length > 0 && (
      <section style="margin-top: 4rem;">
        <EditorialHeader
          category="NIVEAU ARGENT"
          title={`${verifies.length} professionnel${verifies.length > 1 ? "s" : ""} en Argent`}
          subtitle="Dossiers vérifiés aux signaux publics probants mais n'ayant pas atteint le seuil du niveau Or."
        />
        <div class="selection-list">
          {verifies.map((p, i) => (
            <ProCard
              rank={i + 1}
              name={p.nom_entreprise}
              slug={p.slug}
              score={p.score_confiance || 0}
              tier="argent"
              ville={p.ville || ""}
              zoneIntervention={p.code_postal || ""}
              ancienneteAnnees={anciennete(p)}
              rge={p.rge}
              qualibat={p.qualibat}
              specialites={[]}
            />
          ))}
        </div>
      </section>
    )}

    {autres.length > 0 && (
      <p class="foot-note">
        + {autres.length} autres professionnels en niveau Bronze, consultables via les classements par métier/département.
      </p>
    )}
  </div>
</BaseLayout>

<style>
  .selection-list { display: grid; gap: 1rem; max-width: 62rem; margin: 1.6rem auto 0; }
  .foot-note {
    max-width: 56rem;
    margin: 3rem auto 0;
    padding: 0.9rem 1.1rem;
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: var(--ink-muted);
    background: rgba(247, 243, 236, 0.5);
    border-left: 2px solid var(--or);
    border-radius: 0 8px 8px 0;
    text-align: center;
  }
</style>
